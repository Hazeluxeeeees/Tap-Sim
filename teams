importBtn.AutoButtonColor=false; importBtn.BorderSizePixel=0
Corner(importBtn,7); Stroke(importBtn,D.Cyan,1,0.2)
importBtn.MouseEnter:Connect(function() Tw(importBtn,{BackgroundTransparency=0.05}) end)
importBtn.MouseLeave:Connect(function() Tw(importBtn,{BackgroundTransparency=0.15}) end)

local importFeedback = MkLbl(importCard,"",10,D.TextLow); importFeedback.Size=UDim2.new(1,0,0,16)

importBtn.MouseButton1Click:Connect(function()
    local code = (importBox.Text or ""):match("^%s*(.-)%s*$")
    if code == "" then
        importFeedback.Text="⚠ Bitte einen Code eingeben."; importFeedback.TextColor3=D.Orange; return
    end

    local team, err = importTeamCode(code)
    if not team then
        importFeedback.Text="❌ " .. tostring(err); importFeedback.TextColor3=D.Red; return
    end

    -- Duplikat: Namen anpassen
    local finalName = team.name
    local exists = false
    for _, t in ipairs(TM_State.Teams) do
        if t.name == finalName then exists = true; break end
    end
    if exists then
        local i = 2
        while (function()
            for _, t in ipairs(TM_State.Teams) do
                if t.name == finalName .. " (" .. i .. ")" then return true end
            end
            return false
        end)() do i = i + 1 end
        finalName = finalName .. " (" .. i .. ")"
        team.name = finalName
    end

    team.savedAt = os.time()  -- Import-Zeitstempel aktualisieren
    table.insert(TM_State.Teams, team)
    saveTeamsFile()

    importBox.Text = ""
    importFeedback.Text = "✅ Team '" .. finalName .. "' importiert!"
    importFeedback.TextColor3 = D.GreenBright
    rebuildList()
    setStatus("✅ Importiert: '" .. finalName .. "'", D.GreenBright)

    task.delay(5, function() pcall(function() importFeedback.Text="" end) end)
end)

-- ── LOAD-BUTTON ───────────────────────────────────────────────
loadBtn.MouseButton1Click:Connect(function()
    local idx = TM_State.SelIdx
    if not idx or not TM_State.Teams[idx] then
        loadFeedback.Text = "⚠ Kein Team ausgewählt!"; loadFeedback.TextColor3 = D.Orange; return
    end
    local team = TM_State.Teams[idx]

    loadBtn.Text = "⏳ Lade..."; loadBtn.TextColor3 = D.Yellow; loadBtn.Active = false
    loadFeedback.Text = ""; setStatus("⏳ Lade '" .. team.name .. "'...", D.Yellow)

    task.spawn(function()
        loadTeam(team,
            function(n, txt) -- onPhase
                pcall(function()
                    showPhase(n, txt)
                    loadFeedback.Text = txt; loadFeedback.TextColor3 = D.Yellow
                end)
            end,
            function(ok, total) -- onDone
                pcall(function()
                    hidePhase()
                    loadFeedback.Text = string.format("✅ %d/%d Units geladen!", ok, total)
                    loadFeedback.TextColor3 = D.GreenBright
                    loadBtn.Text = "⚡  Team laden"; loadBtn.TextColor3 = Color3.new(1,1,1)
                    loadBtn.Active = true
                    setStatus("✅ '" .. team.name .. "' aktiv.", D.Green)
                    task.delay(6, function()
                        pcall(function() loadFeedback.Text = "" end)
                    end)
                end)
            end,
            function(err) -- onError
                pcall(function()
                    hidePhase()
                    loadFeedback.Text = "❌ " .. tostring(err)
                    loadFeedback.TextColor3 = D.Red
                    loadBtn.Text = "⚡  Team laden"; loadBtn.TextColor3 = Color3.new(1,1,1)
                    loadBtn.Active = true
                    setStatus("❌ Fehler.", D.Red)
                end)
            end
        )
    end)
end)

