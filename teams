--  BASE64  (keine externe Abhängigkeit)
-- ════════════════════════════════════════════════════════════
local B64C = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
local function b64Encode(data)
    local r, bytes = {}, {data:byte(1,#data)}
    for i = 1,#bytes,3 do
        local b1,b2,b3 = bytes[i], bytes[i+1] or 0, bytes[i+2] or 0
        local n = b1*65536+b2*256+b3
        r[#r+1]=B64C:sub(math.floor(n/262144)%64+1,math.floor(n/262144)%64+1)
        r[#r+1]=B64C:sub(math.floor(n/4096)%64+1,  math.floor(n/4096)%64+1)
        r[#r+1]=bytes[i+1] and B64C:sub(math.floor(n/64)%64+1,math.floor(n/64)%64+1) or "="
        r[#r+1]=bytes[i+2] and B64C:sub(n%64+1,n%64+1) or "="
    end
    return table.concat(r)
end
local function b64Decode(s)
    s=s:gsub("[^A-Za-z0-9+/=]","")
    local r,lk={},{}
    for i=1,#B64C do lk[B64C:sub(i,i)]=i-1 end
    for i=1,#s,4 do
        local c1=lk[s:sub(i,i)] or 0
        local c2=lk[s:sub(i+1,i+1)] or 0
        local c3=lk[s:sub(i+2,i+2)]
        local c4=lk[s:sub(i+3,i+3)]
        local n=c1*262144+c2*4096
        r[#r+1]=string.char(math.floor(n/65536)%256)
        if c3 then n=n+(c3 or 0)*64; r[#r+1]=string.char(math.floor(n/256)%256) end
        if c4 then n=n+(c4 or 0);    r[#r+1]=string.char(n%256) end
    end
    return table.concat(r)
end

-- Export: Team-Eintrag → Base64-Code
local function exportTeamCode(teamEntry)
    local ok, json = pcall(function()
        return Svc.Http:JSONEncode({ v=1, team=teamEntry })
    end)
    if not ok then return nil, "JSON-Fehler: "..tostring(json) end
    return b64Encode(json)
end

-- Import: Base64-Code → Team-Eintrag (validiert)
local function importTeamCode(code)
    code = (code or ""):match("^%s*(.-)%s*$")
    if code == "" then return nil, "Leerer Code." end
    local json = b64Decode(code)
    if json == "" then return nil, "Ungültiger Code (Base64)." end
    local ok, payload = pcall(function() return Svc.Http:JSONDecode(json) end)
    if not ok or type(payload) ~= "table" then return nil, "Ungültiges Format (JSON)." end
    local t = payload.team
    if type(t) ~= "table"          then return nil, "Kein 'team'-Feld im Code." end
    if type(t.name) ~= "string" or t.name == "" then return nil, "Kein Team-Name." end
    if type(t.tags) ~= "table"     then return nil, "Keine Tags im Code." end
    return t, nil
end
