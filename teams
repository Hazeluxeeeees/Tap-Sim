-- Gibt die Collection-Instanz zurück (frischer Lookup, kein Cache)
local function GetCollection()
    local col = nil
    pcall(function()
        col = RS
            :WaitForChild("Player_Data", 5)
            :WaitForChild(LP.Name,       5)
            :WaitForChild("Collection",  5)
    end)
    return col
end

-- ★ PRÄZISE TAG-SUCHE — NUR für Gear-Operationen (UnequipGear / EquipGear)
-- Gibt die Unit-Instance zurück deren Tag.Value exakt übereinstimmt
local function findUnitByTag(tag)
    local col = GetCollection()
    if not col then return nil end
    for _, unit in pairs(col:GetChildren()) do
        if unit:FindFirstChild("Tag") and tostring(unit.Tag.Value) == tostring(tag) then
            return unit
        end
    end
    return nil
end

-- ORIGINAL Name-Suche — für Equip-Remote (wie v1.1.1, funktioniert zuverlässig)
-- Sucht: 1. Exakter Name  2. Exakter Tag  3. Case-insensitiv
local function FindUnitInCollection(nameOrTag)
    local col = GetCollection()
    if not col then return nil end
    local units = col:GetChildren()
    -- 1. Exakter Name
    for _, u in ipairs(units) do
        if u.Name == nameOrTag then return u end
    end
    -- 2. Exakter Tag
    for _, u in ipairs(units) do
        local t = u:FindFirstChild("Tag")
        if t and tostring(t.Value) == nameOrTag then return u end
    end
    -- 3. Case-insensitiv
    local low = nameOrTag:lower()
    for _, u in ipairs(units) do
        if u.Name:lower() == low then return u end
    end
    return nil
end

-- Liest einen Gear-Value aus einem Unit-Folder (nil wenn nicht vorhanden)
local function ReadGearValue(unitFolder, gearSlotName)
    local gearObj = unitFolder:FindFirstChild(gearSlotName)
    if not gearObj then return nil end
    local v = tostring(gearObj.Value)
    return (v ~= "" and v ~= "nil" and v ~= "0") and v or nil
end

-- ════════════════════════════════════════════════════════════
--  ★ SNAPSHOT ENGINE
--  Muss VOR jedem Remote-Call ausgeführt werden.
--  Gibt eine Tabelle zurück:  snapshot[tag] = { name, gears={} }
-- ════════════════════════════════════════════════════════════
local function BuildGearSnapshot()
    local snapshot = {}   -- key = Tag.Value (string)
    local col = GetCollection()
    if not col then
        warn("[HazeHub/Teams] Snapshot: Collection nicht gefunden!")
        return snapshot
    end

    for _, unitFolder in pairs(col:GetChildren()) do
        if unitFolder:IsA("Folder") then
            local tagObj = unitFolder:FindFirstChild("Tag")
            local tag    = tagObj and tostring(tagObj.Value) or ""

            if tag ~= "" then
                local gears = {}
                for _, gearSlot in ipairs(GEAR_SLOTS) do
                    gears[gearSlot] = ReadGearValue(unitFolder, gearSlot)
                end

                snapshot[tag] = {
                    name     = unitFolder.Name,
                    tag      = tag,
                    gears    = gears,
                    instance = unitFolder, -- Ref für sofortigen Zugriff (pre-unequip)
                }
            end
        end
    end

    local count = 0
    for _ in pairs(snapshot) do count = count + 1 end
    print(string.format("[HazeHub/Teams] Snapshot: %d Units gesichert.", count))
    return snapshot
end

