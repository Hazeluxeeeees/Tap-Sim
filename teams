--  REMOTE-HELPER
-- ════════════════════════════════════════════════════════════
local _remoteCache = {}
local function getRemote(...)
    local key = table.concat({...}, "/")
    if _remoteCache[key] then return _remoteCache[key] end
    local node = RS
    for _, seg in ipairs({...}) do
        local ok, child = pcall(function() return node:WaitForChild(seg, 8) end)
        if not ok or not child then
            warn("[HazeHub/Teams] Remote nicht gefunden: " .. key)
            return nil
        end
        node = child
    end
    _remoteCache[key] = node
    return node
end

local function fireUnEquipAll()
    local r = getRemote("Remote","Server","Units","UnEquipAll")
    if not r then return end
    pcall(function() r:FireServer() end)
    print("[HazeHub/Teams] UnEquipAll → gefeuert")
    task.wait(0.6)
end

-- Equip: findet Unit ausschließlich über Tag, übergibt Instance an Server
local function fireEquip(tag)
    local unit = getUnitByTag(tag)
    if not unit then
        warn("[HazeHub/Teams] fireEquip: kein Unit für Tag='" .. tostring(tag) .. "' gefunden")
        return false
    end
    local r = getRemote("Remote","Server","Units","Equip")
    if not r then return false end
    local ok, err = pcall(function() r:FireServer(unit) end)
    if not ok then
        warn("[HazeHub/Teams] fireEquip Fehler: " .. tostring(err))
        return false
    end
    print("[HazeHub/Teams] Equip ✓ Tag='" .. tag .. "'  (" .. unit.Name .. ")")
    return true
end

-- ════════════════════════════════════════════════════════════
--  GEAR / SOUL — UNEQUIP
--
--  Gears-Remote:
--    FireServer("Unequip", { UnitFolder = folder, GearName = "HeadGear" })
--  Soul-Remote:
--    FireServer("Unequip", { UnitFolder = folder, SoulName = "Soul" })
-- ════════════════════════════════════════════════════════════
local function fireUnequipGear(unitFolder, slotDef)
    -- slotDef = Eintrag aus GEAR_SLOTS: { key, remoteType, unequipKey }
    if not unitFolder or not slotDef then return end

    if slotDef.remoteType == "Soul" then
        local r = getRemote("Remote","Server","Units","Soul")
        if not r then return end
        pcall(function()
            r:FireServer(table.unpack({
                [1] = "Unequip",
                [2] = {
                    ["UnitFolder"] = unitFolder,
                    ["SoulName"]   = "Soul",   -- fester Wert beim Unequip
                },
            }))
        end)
        print("[HazeHub/Teams] Soul Unequip ✓  (" .. unitFolder.Name .. ")")
    else
        -- Gears-Remote (HeadGear / BodyGear / LegsGear / ArmsGear)
        local r = getRemote("Remote","Server","Units","Gears")
        if not r then return end
        pcall(function()
            r:FireServer(table.unpack({
                [1] = "Unequip",
                [2] = {
                    ["UnitFolder"] = unitFolder,
                    ["GearName"]   = slotDef.unequipKey,  -- z. B. "HeadGear"
                },
            }))
        end)
        print("[HazeHub/Teams] Gear Unequip ✓  " .. slotDef.unequipKey
            .. "  (" .. unitFolder.Name .. ")")
    end
end

-- ════════════════════════════════════════════════════════════
--  GEAR / SOUL — EQUIP
