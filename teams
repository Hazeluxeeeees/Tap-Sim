-- RebuildTeamsList (v2.0: Filter + Stage + Copy-Button)
local function rebuildList(filter)
    filter = (filter or ""):lower():match("^%s*(.-)%s*$")
    local useFilter = filter ~= ""

    for _, v in pairs(teamListFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    -- Filtern: Name + Stage
    local visible = {}
    for idx, team in ipairs(TM_State.Teams) do
        local nameMatch  = not useFilter or team.name:lower():find(filter,1,true)
        local stageMatch = _activeStage == "" or team.stage == _activeStage
        if nameMatch and stageMatch then
            table.insert(visible, { idx=idx, team=team })
        end
    end

    emptyLbl.Visible = (#visible == 0)

    for _, entry in ipairs(visible) do
        local idx      = entry.idx
        local team     = entry.team
        local sel      = (TM_State.SelIdx == idx)
        local hasTags  = team.tags ~= nil
        local hasStage = team.stage and team.stage ~= ""

        local row = Instance.new("Frame", teamListFrame)
        row.Size = UDim2.new(1,0,0,48)
        row.BackgroundColor3 = sel and D.TabActive or D.CardHover
        row.BackgroundTransparency = 0.3; row.BorderSizePixel = 0
        Corner(row,8); Stroke(row, sel and D.Cyan or D.Border, 1.5, sel and 0 or 0.5)

        local stripe = Instance.new("Frame", row)
        stripe.Size = UDim2.new(0,5,1,0)
        stripe.BackgroundColor3 = hasTags and D.Green or D.Orange
        stripe.BackgroundTransparency = 0.3; stripe.BorderSizePixel = 0; Corner(stripe,3)

        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Position = UDim2.new(0,13,0,4); nameLbl.Size = UDim2.new(1,-104,0,20)
        nameLbl.BackgroundTransparency = 1; nameLbl.Text = "⚔  " .. team.name
        nameLbl.TextColor3 = sel and D.Cyan or D.TextHi; nameLbl.TextSize = 12
        nameLbl.Font = Enum.Font.GothamBold; nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
        nameLbl.TextScaled=false; nameLbl.RichText=true; nameLbl.TextStrokeTransparency=1

        local cnt  = 0; for _ = 1,6 do if team.slots and team.slots[_] then cnt=cnt+1 end end
        local sub  = cnt .. "/6"
        if hasStage then sub = sub .. "  ·  🏷 " .. team.stage end
        sub = sub .. "  ·  " .. os.date("%d.%m.", team.savedAt or 0)

        local subLbl = Instance.new("TextLabel", row)
        subLbl.Position = UDim2.new(0,13,0,26); subLbl.Size = UDim2.new(1,-104,0,14)
        subLbl.BackgroundTransparency = 1; subLbl.Text = sub
        subLbl.TextColor3 = hasStage and D.CyanDim or (hasTags and D.TextMid or D.Orange)
        subLbl.TextSize = 10; subLbl.Font = Enum.Font.GothamMedium
        subLbl.TextXAlignment = Enum.TextXAlignment.Left
        subLbl.TextScaled=false; subLbl.RichText=true; subLbl.TextStrokeTransparency=1

        -- ★ Copy-Button (Export)
        local copyBtn = Instance.new("TextButton", row)
        copyBtn.Size=UDim2.new(0,28,0,28); copyBtn.Position=UDim2.new(1,-100,0.5,-14)
        copyBtn.BackgroundColor3=Color3.fromRGB(18,28,48); copyBtn.BackgroundTransparency=0.15
        copyBtn.Text="📋"; copyBtn.TextColor3=D.CyanDim; copyBtn.TextSize=12
        copyBtn.Font=Enum.Font.GothamBold; copyBtn.AutoButtonColor=false; copyBtn.BorderSizePixel=0
        Corner(copyBtn,6); Stroke(copyBtn,D.CyanDim,1,0.35)
        copyBtn.MouseEnter:Connect(function() Tw(copyBtn,{BackgroundColor3=Color3.fromRGB(22,40,70)}) end)
        copyBtn.MouseLeave:Connect(function() Tw(copyBtn,{BackgroundColor3=Color3.fromRGB(18,28,48)}) end)

        local delBtn = Instance.new("TextButton", row)
        delBtn.Size = UDim2.new(0,32,0,32); delBtn.Position = UDim2.new(1,-38,0.5,-16)
        delBtn.BackgroundColor3 = Color3.fromRGB(50,12,12); delBtn.Text = "✕"
        delBtn.TextColor3 = D.Red; delBtn.TextSize = 12; delBtn.Font = Enum.Font.GothamBold
        delBtn.AutoButtonColor = false; delBtn.BorderSizePixel = 0
        Corner(delBtn,7); Stroke(delBtn,D.Red,1,0.4)
        delBtn.MouseEnter:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(80,20,20)}) end)
        delBtn.MouseLeave:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(50,12,12)}) end)

        local selBtn = Instance.new("TextButton", row)
        selBtn.Size = UDim2.new(1,-104,1,0); selBtn.BackgroundTransparency = 1
        selBtn.Text = ""; selBtn.BorderSizePixel = 0
        selBtn.MouseEnter:Connect(function()
            if not sel then Tw(row,{BackgroundColor3=D.TabActive,BackgroundTransparency=0.2}) end
        end)
        selBtn.MouseLeave:Connect(function()
            if not sel then Tw(row,{BackgroundColor3=D.CardHover,BackgroundTransparency=0.3}) end
        end)

        local capIdx  = idx
        local capTeam = team

        -- ★ Copy-Button Logik
        copyBtn.MouseButton1Click:Connect(function()
            local code, err = exportTeamCode(capTeam)
            if code then
                if setclipboard then
                    setclipboard(code)
                    copyBtn.Text="✅"; copyBtn.TextColor3=D.GreenBright
                    task.delay(1.5, function() pcall(function()
                        copyBtn.Text="📋"; copyBtn.TextColor3=D.CyanDim
                    end) end)
                else
                    setStatus("⚠ setclipboard nicht verfügbar.", D.Orange)
                end
            else
                setStatus("❌ Export Fehler: " .. tostring(err), D.Red)
            end
        end)

        selBtn.MouseButton1Click:Connect(function()
            TM_State.SelIdx = capIdx
            local t = TM_State.Teams[capIdx]
            if t then
                detailCard.Visible = true
                for i = 1, 6 do
                    local dl   = detailLabels[i]
                    local name = t.slots and t.slots[i]
                    local tag  = t.tags  and (t.tags[tostring(i)] or t.tags[i])
                    if name then
                        local display = getDisplayName(name)
                        local tagStr  = tag and ("  [#" .. tag .. "]") or "  [kein Tag]"
                        local gearCnt = 0
                        if t.gears then
                            local g = t.gears[tostring(i)] or t.gears[i]
                            if g then for _, v in pairs(g) do if v then gearCnt=gearCnt+1 end end end
                        end
                        local gearStr = gearCnt > 0 and ("  🗡" .. gearCnt) or ""
                        dl.Text       = display .. tagStr .. gearStr
                        dl.TextColor3 = tag and D.TextHi or D.Orange
                    else
                        dl.Text = "—  (leer)"; dl.TextColor3 = D.TextLow
                    end
                end
            end
            rebuildList(teamSearchBox.Text)
        end)

        delBtn.MouseButton1Click:Connect(function()
            if TM_State.SelIdx == capIdx then
                TM_State.SelIdx = nil; detailCard.Visible = false
            end
            table.remove(TM_State.Teams, capIdx)
            saveTeamsFile(); rebuildList(teamSearchBox.Text)
            setStatus("🗑 Team gelöscht.", D.TextMid)
        end)
    end
end
_G._RebuildTeamsList = rebuildList

