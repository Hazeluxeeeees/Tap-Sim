-- ── Remotes ───────────────────────────────────────────────────
-- REQUIRED: Remote.Server.Units.Equip / UnEquip / AutoUpgradeConfig
local RemoteUnits = nil
task.spawn(function()
    pcall(function()
        RemoteUnits = RS:WaitForChild("Remote", 15)
                        :WaitForChild("Server", 15)
                        :WaitForChild("Units",  15)
    end)
end)

-- Equip: FireServer(Collection[UnitName])
local function FireEquip(unitName)
    pcall(function()
        local col = RS:WaitForChild("Player_Data", 5)[LP.Name].Collection
        RemoteUnits.Equip:FireServer(col[unitName])
    end)
end

-- UnEquip: FireServer(Player_Data[LP.Name].Collection["UnitName"])
local function FireUnEquip(unitName)
    pcall(function()
        local col = RS:WaitForChild("Player_Data", 5)[LP.Name].Collection
        RemoteUnits.UnEquip:FireServer(col[unitName])
    end)
end

-- AutoUpgrade: FireServer(Slot, Value)
local function FireAutoUpgrade(slot, value)
    pcall(function()
        RemoteUnits.AutoUpgradeConfig:FireServer(slot, value)
    end)
end

-- ── Scan aktuelles Loadout ─────────────────────────────────────
-- Liest UnitLoadout1..6 aus Player_Data[LP.Name].Data
-- Liest AutoUpgradeConfig aus Player_Data[LP.Name].AutoUpgradeConfig
local function ScanCurrentLoadout()
    local slots   = {}
    local autoUp  = {}
    pcall(function()
        local pd   = RS:WaitForChild("Player_Data", 5):WaitForChild(LP.Name, 5)
        local data = pd:WaitForChild("Data", 5)
        for i = 1, 6 do
            local lv = data:FindFirstChild("UnitLoadout" .. i)
            if lv then
                local v = tostring(lv.Value)
                slots[i] = (v ~= "" and v ~= "nil") and v or nil
            end
            -- AutoUpgradeConfig pro Slot
            local auConf = pd:FindFirstChild("AutoUpgradeConfig")
            if auConf then
                local auSlot = auConf:FindFirstChild(tostring(i))
                if auSlot then autoUp[i] = auSlot.Value end
            end
        end
    end)
    return slots, autoUp
end

-- ── Datei speichern / laden ────────────────────────────────────
local function SaveTeamsFile()
    if not writefile then return end
    pcall(function()
        writefile(TEAMS_FILE, Svc.Http:JSONEncode(TM_State.Teams))
    end)
end

local function LoadTeamsFile()
    if not (isfile and isfile(TEAMS_FILE)) then return end
    local ok, data = pcall(function()
        return Svc.Http:JSONDecode(readfile(TEAMS_FILE))
    end)
    if ok and type(data) == "table" then
        TM_State.Teams = data
    end
end

-- ── UnEquip alle aktuellen Slots ──────────────────────────────
local function UnEquipAll()
    local slots, _ = ScanCurrentLoadout()
    for i = 1, 6 do
        if slots[i] then
            FireUnEquip(slots[i])
            task.wait(0.25)
        end
    end
end

