-- _lastScanData: hält den letzten kompletten Scan (slots + unitSnapshots)
local _lastScanData = nil

local function RefreshSlotPreview()
    local slots, autoUp, unitSnaps = ScanCurrentLoadoutWithGear()
    _lastScanData = { slots = slots, autoUpgrade = autoUp, unitSnapshots = unitSnaps }

    for i = 1, 6 do
        local lbl  = slotPreviews[i]
        local snap = unitSnaps[i]
        if snap then
            local gearCount = 0
            for _, v in pairs(snap.gears or {}) do if v then gearCount = gearCount + 1 end end
            local tagStr = snap.tag ~= "" and ("  [Tag: " .. snap.tag .. "]") or "  [kein Tag]"
            local auTxt  = autoUp[i] ~= nil and ("  [AU:" .. tostring(autoUp[i]) .. "]") or ""
            local gearTxt = gearCount > 0 and ("  🗡" .. gearCount .. "G") or ""
            lbl.Text       = snap.name .. tagStr .. gearTxt .. auTxt
            lbl.TextColor3 = snap.tag ~= "" and D.TextHi or D.Yellow
        else
            lbl.Text       = "—  (leer)"
            lbl.TextColor3 = D.TextLow
        end
    end
    SetTMStatus("✅ Loadout + Gear gescannt!", D.Green)
end

