--  Gears-Remote:
--    FireServer("Equip", { UnitFolder = folder, GearName = "Crown of Eternity" })
--  Soul-Remote:
--    FireServer("Equip", { UnitFolder = folder, SoulName = "The Soul Of The Riches [I]" })
-- ════════════════════════════════════════════════════════════
local function fireEquipGear(tag, slotDef, itemName)
    -- itemName = gespeicherter Item-/Seelen-Name aus dem Save
    if not itemName or itemName == "" then return end
    local unitFolder = getUnitByTag(tag)
    if not unitFolder then
        warn("[HazeHub/Teams] fireEquipGear: kein Unit für Tag='" .. tostring(tag) .. "'")
        return
    end

    if slotDef.remoteType == "Soul" then
        local r = getRemote("Remote","Server","Units","Soul")
        if not r then return end
        pcall(function()
            r:FireServer(table.unpack({
                [1] = "Equip",
                [2] = {
                    ["UnitFolder"] = unitFolder,
                    ["SoulName"]   = itemName,   -- echter Seelen-Name
                },
            }))
        end)
        print("[HazeHub/Teams] Soul Equip ✓  '" .. itemName
            .. "'  (" .. unitFolder.Name .. ")")
    else
        -- Gears-Remote
        local r = getRemote("Remote","Server","Units","Gears")
        if not r then return end
        pcall(function()
            r:FireServer(table.unpack({
                [1] = "Equip",
                [2] = {
                    ["UnitFolder"] = unitFolder,
                    ["GearName"]   = itemName,   -- echter Item-Name
                },
            }))
        end)
        print("[HazeHub/Teams] Gear Equip ✓  '" .. itemName
            .. "'  [" .. slotDef.key .. "]  (" .. unitFolder.Name .. ")")
    end
end

local function fireAutoUpgrade(slot, value)
