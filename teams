-- Holt einen Remote-Pfad (gecacht per Session, nil-safe)
local _remoteCache = {}
local function GetRemote(...)
    local path = table.concat({...}, "/")
    if _remoteCache[path] then return _remoteCache[path] end
    local cur = RS
    for _, seg in ipairs({...}) do
        local ok, r = pcall(function()
            return cur:WaitForChild(seg, 8)
        end)
        if not ok or not r then
            warn("[HazeHub/Teams] Remote-Pfad nicht gefunden: " .. path)
            return nil
        end
        cur = r
    end
    _remoteCache[path] = cur
    return cur
end

-- UnEquipAll: leert alle Loadout-Slots serverseitig
local function FireUnEquipAll()
    local r = GetRemote("Remote","Server","Units","UnEquipAll")
    if not r then return false end
    local ok, err = pcall(function() r:FireServer() end)
    if not ok then warn("[HazeHub/Teams] UnEquipAll Fehler: " .. tostring(err)); return false end
    print("[HazeHub/Teams] UnEquipAll gefeuert.")
    task.wait(0.5)
    return true
end

-- Equip: originale Name-Suche via FindUnitInCollection (wie v1.1.1)
-- findUnitByTag wird hier NICHT verwendet — nur für Gear-Ops
local function FireEquip(unitName)
    if not unitName or unitName == "" then return false end
    local inst = FindUnitInCollection(unitName)
    if not inst then
        warn("[HazeHub/Teams] Equip: '" .. unitName .. "' nicht in Collection gefunden.")
        return false
    end
    local r = GetRemote("Remote","Server","Units","Equip")
    if not r then return false end
    local ok, err = pcall(function() r:FireServer(inst) end)
    if not ok then
        warn("[HazeHub/Teams] Equip Fehler für '" .. unitName .. "': " .. tostring(err))
        return false
    end
    return true
end

-- UnequipGear: entfernt ein einzelnes Gear-Item von einer Unit
-- Remote-Pfad: Remote.Server.Units.UnequipGear (FireServer(unitInstance, gearSlotName))
local function FireUnequipGear(unitInstance, gearSlotName)
    if not unitInstance or not gearSlotName then return end
    local r = GetRemote("Remote","Server","Units","UnequipGear")
    if not r then return end  -- Remote optional – kein warn (nicht alle Spiele haben diesen Remote)
    pcall(function() r:FireServer(unitInstance, gearSlotName) end)
end

-- EquipGear: stattet eine Unit (per Tag-Lookup) mit einem Gear-Item aus
-- Remote-Pfad: Remote.Server.Units.EquipGear (FireServer(unitInstance, gearSlotName, gearValue))
local function FireEquipGear(tag, gearSlotName, gearValue)
    if not gearValue then return end
    local inst = findUnitByTag(tag)
    if not inst then
        warn(string.format("[HazeHub/Teams] EquipGear: Unit Tag='%s' nicht gefunden.", tostring(tag)))
        return
    end
    local r = GetRemote("Remote","Server","Units","EquipGear")
    if not r then return end
    pcall(function() r:FireServer(inst, gearSlotName, gearValue) end)
end

-- AutoUpgrade
local function FireAutoUpgrade(slot, value)
    local r = GetRemote("Remote","Server","Units","AutoUpgradeConfig")
    if not r then return end
    pcall(function() r:FireServer(slot, value) end)
end

-- ════════════════════════════════════════════════════════════
--  ★ LOADOUT SCANNER (für Save-Funktion)
-- ════════════════════════════════════════════════════════════
local function ScanCurrentLoadout()
    local slots  = {}
    local autoUp = {}
    pcall(function()
        local pd   = RS:WaitForChild("Player_Data", 5):WaitForChild(LP.Name, 5)
        local data = pd:WaitForChild("Data", 5)
        for i = 1, 6 do
            local lv = data:FindFirstChild("UnitLoadout" .. i)
            if lv then
                local v = tostring(lv.Value)
                slots[i] = (v ~= "" and v ~= "nil") and v or nil
            end
        end
        local auConf = pd:FindFirstChild("AutoUpgradeConfig")
        if auConf then
            for i = 1, 6 do
                local auSlot = auConf:FindFirstChild(tostring(i))
                if auSlot then autoUp[i] = auSlot.Value end
            end
        end
    end)
    return slots, autoUp
end

-- Scan + Gear-Snapshot kombiniert (für Save)
-- Gibt { slots, autoUpgrade, unitSnapshots } zurück
-- unitSnapshots: { [slotIndex] = { name, tag, gears } }
local function ScanCurrentLoadoutWithGear()
    local slots, autoUp = ScanCurrentLoadout()
    local snapshot = BuildGearSnapshot()  -- Snapshot direkt beim Scan

    local unitSnapshots = {}
    for i = 1, 6 do
        local unitName = slots[i]
        if unitName then
            -- Finde den Tag für diesen Unit-Namen im Snapshot
            local foundEntry = nil
            for tag, entry in pairs(snapshot) do
                if entry.name == unitName then
                    foundEntry = entry
                    break
                end
            end
            if foundEntry then
                unitSnapshots[i] = {
                    name  = foundEntry.name,
                    tag   = foundEntry.tag,
                    gears = foundEntry.gears,
                }
            else
                -- Fallback: Name ohne Tag (kann bei späterem Load zu Problemen führen)
                unitSnapshots[i] = {
                    name  = unitName,
                    tag   = "",
                    gears = {},
                }
            end
        end
    end

    return slots, autoUp, unitSnapshots
end

-- ════════════════════════════════════════════════════════════
--  ★ LOAD TEAM — STRIKTE DREIPHASEN-SEQUENZ
--
--  PHASE 1: Snapshot (KEIN Remote darf vorher feuern)
--  PHASE 2: Gear-Strip + UnEquipAll
--  PHASE 3: Re-Equip (Units) + Gear-Restore + AutoUpgrade
-- ════════════════════════════════════════════════════════════
local function LoadTeam(team, onPhase, onDone, onError)
    onPhase = onPhase or function() end
    onDone  = onDone  or function() end
    onError = onError or function() end

    -- Validierung
    if not team or not team.slots then
        onError("Ungültiges Team-Objekt (kein slots-Feld).")
        return
    end

    -- ──────────────────────────────────────────────────────
    --  PHASE 1: SNAPSHOT
    --  Alle Daten sichern BEVOR ein einziger Remote gefeuert wird.
    --  Nach UnEquipAll sind Instance-Referenzen potenziell stale.
    -- ──────────────────────────────────────────────────────
    onPhase(1, "🔍 Phase 1/3: Snapshot der Collection...")
    print("[HazeHub/Teams] ═══ PHASE 1: SNAPSHOT ═══")

    local snapshot = BuildGearSnapshot()

    -- Baue die Equip-Queue auf Basis des gespeicherten Teams
    -- Jeder Eintrag: { slotIdx, tag, name, gears }
    local equipQueue = {}
    for i = 1, 6 do
        local savedUnit = team.slots and team.slots[i]
        if savedUnit and savedUnit ~= "" then
            -- Bevorzuge gespeicherten Tag aus unitSnapshots (v1.2.0+ saves)
            local savedTag  = team.unitSnapshots
                and team.unitSnapshots[tostring(i)]
                and team.unitSnapshots[tostring(i)].tag
                or ""
            local savedGear = team.unitSnapshots
                and team.unitSnapshots[tostring(i)]
                and team.unitSnapshots[tostring(i)].gears
                or {}

            -- Suche Tag im aktuellen Snapshot als Validierung
            -- (prüft ob Unit noch in Collection existiert)
            local liveEntry = nil
            if savedTag ~= "" then
                liveEntry = snapshot[savedTag]
            end
            -- Fallback: Name-Match über Snapshot
            if not liveEntry then
                for tag, entry in pairs(snapshot) do
                    if entry.name == savedUnit then
                        liveEntry = entry
                        savedTag  = tag
                        break
                    end
                end
            end

            if liveEntry then
                table.insert(equipQueue, {
                    slotIdx   = i,
                    tag       = liveEntry.tag,   -- Live-Tag (canonical)
                    name      = liveEntry.name,
                    gears     = savedGear,        -- Gear aus dem Save (nicht Live)
                    liveGears = liveEntry.gears,  -- Gear aus Live-Collection
                })
                print(string.format(
                    "[HazeHub/Teams]   Slot %d → '%s' (Tag: %s) — %d Gear-Felder gesichert",
                    i, liveEntry.name, liveEntry.tag,
                    (function()
                        local n = 0
                        for _, v in pairs(savedGear) do if v then n=n+1 end end
                        return n
                    end)()
                ))
            else
                warn(string.format(
                    "[HazeHub/Teams]   Slot %d: Unit '%s' nicht in Collection! Wird übersprungen.",
                    i, savedUnit
                ))
            end
        end
    end

    if #equipQueue == 0 then
        onError("Keine Units aus diesem Team in der Collection gefunden.")
        return
    end

    -- Snapshot der aktuell ausgerüsteten Units für Gear-Strip
    -- (muss vor UnEquipAll passieren, da danach Loadout-Slots leer sind)
    local currentSlots, _ = ScanCurrentLoadout()
    local stripTargets = {}  -- { tag, instance } — Units deren Gear zu strippen ist
    for i = 1, 6 do
        local unitName = currentSlots[i]
        if unitName and unitName ~= "" then
            -- Suche im Live-Snapshot
            for tag, entry in pairs(snapshot) do
                if entry.name == unitName then
                    table.insert(stripTargets, { tag = tag, instance = entry.instance })
                    break
                end
            end
        end
    end

    -- ──────────────────────────────────────────────────────
    --  PHASE 2: GEAR-STRIP + UNEQUIP-ALL
    --  Erst Gear entfernen, DANN Units aus Slots entfernen.
    --  Reihenfolge kritisch: kein UnEquipAll vor Gear-Strip.
    -- ──────────────────────────────────────────────────────
    onPhase(2, string.format("⚡ Phase 2/3: Strip %d Units + UnEquip...", #stripTargets))
    print("[HazeHub/Teams] ═══ PHASE 2: GEAR-STRIP + UNEQUIP ═══")

    -- 2a. Gear von aktuell ausgerüsteten Units entfernen
    for _, target in ipairs(stripTargets) do
        for _, gearSlot in ipairs(GEAR_SLOTS) do
            local gearVal = ReadGearValue(target.instance, gearSlot)
            if gearVal then
                FireUnequipGear(target.instance, gearSlot)
                task.wait(0.05)  -- Minimale Pause zwischen Gear-Remotes
            end
        end
    end

    if #stripTargets > 0 then
        task.wait(0.3)  -- Server-Bestätigung abwarten
    end

    -- 2b. Alle Units aus Loadout-Slots entfernen
    FireUnEquipAll()
    task.wait(0.6)  -- Wichtig: Server braucht Zeit, Collection zu aktualisieren

    -- ──────────────────────────────────────────────────────
    --  PHASE 3: RE-EQUIP UNITS + GEAR-RESTORE
    --  findUnitByTag liefert jetzt frische Instances (post-UnEquip).
    --  Gear wird aus dem gespeicherten Team-Snapshot wiederhergestellt.
    -- ──────────────────────────────────────────────────────
    onPhase(3, string.format("🎯 Phase 3/3: Equip %d Units + Gear...", #equipQueue))
    print("[HazeHub/Teams] ═══ PHASE 3: RE-EQUIP + GEAR-RESTORE ═══")

    local successCount = 0
    for _, entry in ipairs(equipQueue) do
        -- 3a. Unit equippen (originale Name-Suche, wie v1.1.1)
        local equipped = FireEquip(entry.name)
        if equipped then
            successCount = successCount + 1
            print(string.format(
                "[HazeHub/Teams]   ✅ Slot %d: '%s' (Tag: %s)",
                entry.slotIdx, entry.name, entry.tag
            ))
            task.wait(0.25)

            -- 3b. Gear wiederherstellen (aus gespeichertem Save)
            local anyGear = false
            for _, gearSlot in ipairs(GEAR_SLOTS) do
                local gearVal = entry.gears and entry.gears[gearSlot]
                if gearVal then
                    FireEquipGear(entry.tag, gearSlot, gearVal)
                    anyGear = true
                    task.wait(0.08)
                end
            end
            if anyGear then
                task.wait(0.1)  -- Gear-Batch abwarten
            end
        else
            warn(string.format(
                "[HazeHub/Teams]   ❌ Slot %d: '%s' konnte nicht equipped werden.",
                entry.slotIdx, entry.name
            ))
            task.wait(0.1)
        end
    end

    -- 3c. AutoUpgrade-Konfiguration wiederherstellen
    if team.autoUpgrade then
        for i = 1, 6 do
            local auVal = team.autoUpgrade[i]
            if auVal ~= nil then
                FireAutoUpgrade(i, auVal)
                task.wait(0.12)
            end
        end
    end

    print(string.format(
        "[HazeHub/Teams] ═══ FERTIG: %d/%d Units geladen (%s) ═══",
        successCount, #equipQueue, team.name or "?"
    ))

    onDone(successCount, #equipQueue)
end

