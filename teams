confirmSaveBtn.MouseButton1Click:Connect(function()
    local teamName = (nameBox.Text or ""):match("^%s*(.-)%s*$")
    if teamName == "" then
        saveFeedback.Text       = "⚠ Bitte einen Team-Namen eingeben!"
        saveFeedback.TextColor3 = D.Orange
        return
    end
    -- Loadout live scannen (nicht nur die Vorschau)
    local slots, autoUp = ScanCurrentLoadout()
    local unitCount = 0
    for i = 1, 6 do if slots[i] then unitCount = unitCount + 1 end end
    if unitCount == 0 then
        saveFeedback.Text       = "⚠ Kein Loadout gefunden. Bitte erst scannen."
        saveFeedback.TextColor3 = D.Orange
        return
    end
    -- Überschreibe ggf. vorhandenes Team mit gleichem Namen
    local existIdx = nil
    for i, t in ipairs(TM_State.Teams) do
        if t.name == teamName then existIdx = i; break end
    end
    local entry = {
        name        = teamName,
        slots       = slots,
        autoUpgrade = autoUp,
        savedAt     = os.time(),
        unitCount   = unitCount,
    }
    if existIdx then
        TM_State.Teams[existIdx] = entry
        saveFeedback.Text        = "✅ Team '" .. teamName .. "' überschrieben! (" .. unitCount .. "/6 Einheiten)"
    else
        table.insert(TM_State.Teams, entry)
        saveFeedback.Text        = "✅ Team '" .. teamName .. "' gespeichert! (" .. unitCount .. "/6 Einheiten)"
    end
    saveFeedback.TextColor3 = D.GreenBright
    nameBox.Text = ""
    SaveTeamsFile()
    task.delay(5, function()
        pcall(function() if saveFeedback then saveFeedback.Text = "" end end)
    end)
    pcall(_G._RebuildTeamsList)
end)

