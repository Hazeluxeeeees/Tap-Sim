-- ── RebuildTeamsList ──────────────────────────────────────────
local function RebuildTeamsList()
    for _, v in pairs(teamListFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    teamListEmpty.Visible = (#TM_State.Teams == 0)

    for idx, team in ipairs(TM_State.Teams) do
        local isSelected = (TM_State.SelIdx == idx)

        local row = Instance.new("Frame", teamListFrame)
        row.Size                   = UDim2.new(1, 0, 0, 48)
        row.BackgroundColor3       = isSelected and D.TabActive or D.CardHover
        row.BackgroundTransparency = 0.3
        row.BorderSizePixel        = 0
        Corner(row, 8)
        Stroke(row, isSelected and D.Cyan or D.Border, 1.5, isSelected and 0 or 0.5)

        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Position       = UDim2.new(0, 10, 0, 4)
        nameLbl.Size           = UDim2.new(1, -90, 0, 20)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text           = "⚔  " .. team.name
        nameLbl.TextColor3     = isSelected and D.Cyan or D.TextHi
        nameLbl.TextSize       = 12
        nameLbl.Font           = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate   = Enum.TextTruncate.AtEnd

        local unitCount = 0
        for i = 1, 6 do if team.slots and team.slots[i] then unitCount = unitCount + 1 end end

        local subLbl = Instance.new("TextLabel", row)
        subLbl.Position       = UDim2.new(0, 10, 0, 26)
        subLbl.Size           = UDim2.new(1, -90, 0, 14)
        subLbl.BackgroundTransparency = 1
        subLbl.Text           = unitCount .. "/6 Einheiten · " .. os.date("%d.%m.%Y", team.savedAt or 0)
        subLbl.TextColor3     = D.TextMid
        subLbl.TextSize       = 10
        subLbl.Font           = Enum.Font.GothamMedium
        subLbl.TextXAlignment = Enum.TextXAlignment.Left

        -- Löschen-Button
        local delBtn = Instance.new("TextButton", row)
        delBtn.Size              = UDim2.new(0, 32, 0, 32)
        delBtn.Position          = UDim2.new(1, -38, 0.5, -16)
        delBtn.BackgroundColor3  = Color3.fromRGB(50, 12, 12)
        delBtn.Text              = "✕"
        delBtn.TextColor3        = D.Red
        delBtn.TextSize          = 12
        delBtn.Font              = Enum.Font.GothamBold
        delBtn.AutoButtonColor   = false
        delBtn.BorderSizePixel   = 0
        Corner(delBtn, 7); Stroke(delBtn, D.Red, 1, 0.4)
        delBtn.MouseEnter:Connect(function() Tw(delBtn, { BackgroundColor3 = D.RedDark or Color3.fromRGB(80, 20, 20) }) end)
        delBtn.MouseLeave:Connect(function() Tw(delBtn, { BackgroundColor3 = Color3.fromRGB(50, 12, 12) }) end)

        -- Auswählen (ganzer Row außer Löschen-Button)
        local selBtn = Instance.new("TextButton", row)
        selBtn.Size                  = UDim2.new(1, -40, 1, 0)
        selBtn.BackgroundTransparency = 1
        selBtn.Text                  = ""
        selBtn.BorderSizePixel       = 0
        local capIdx = idx

        selBtn.MouseButton1Click:Connect(function()
            TM_State.SelIdx = capIdx
            local t = TM_State.Teams[capIdx]
            if t then
                detailCard.Visible = true
                for i = 1, 6 do
                    local lbl  = detailSlotLabels[i]
                    local unit = t.slots and t.slots[i]
                    if unit then
                        local auVal = t.autoUpgrade and t.autoUpgrade[i]
                        lbl.Text       = unit .. (auVal ~= nil and ("  [AutoUp: " .. tostring(auVal) .. "]") or "")
                        lbl.TextColor3 = D.TextHi
                    else
                        lbl.Text       = "—  (leer)"
                        lbl.TextColor3 = D.TextLow
                    end
                end
            end
            RebuildTeamsList()
        end)

        delBtn.MouseButton1Click:Connect(function()
            if TM_State.SelIdx == capIdx then
                TM_State.SelIdx    = nil
                detailCard.Visible = false
            end
            table.remove(TM_State.Teams, capIdx)
            SaveTeamsFile()
            RebuildTeamsList()
            SetTMStatus("🗑 Team gelöscht.", D.TextMid)
        end)
    end
end
_G._RebuildTeamsList = RebuildTeamsList

-- ── Team laden (Equip-Logik) ──────────────────────────────────
loadTeamBtn.MouseButton1Click:Connect(function()
    local idx = TM_State.SelIdx
    if not idx or not TM_State.Teams[idx] then
        loadFeedback.Text       = "⚠ Kein Team ausgewählt!"
        loadFeedback.TextColor3 = D.Orange
        return
    end
    local team = TM_State.Teams[idx]
    loadFeedback.Text       = "⏳ UnEquip alle..."
    loadFeedback.TextColor3 = D.Yellow
    loadTeamBtn.Text        = "⏳ Lade..."
    loadTeamBtn.TextColor3  = D.Yellow
    SetTMStatus("⏳ Lade Team '" .. team.name .. "'...", D.Yellow)

    task.spawn(function()
        -- 1) UnEquip alle aktuellen Einheiten
        loadFeedback.Text = "⏳ UnEquip alle Slots..."
        pcall(UnEquipAll)
        task.wait(0.5)

        -- 2) Equip gespeicherte Einheiten (Slot 1 → 6)
        loadFeedback.Text = "⏳ Equip gespeicherte Einheiten..."
        for i = 1, 6 do
            local unit = team.slots and team.slots[i]
            if unit and unit ~= "" then
                pcall(function() FireEquip(unit) end)
                task.wait(0.25)
            end
        end
        task.wait(0.3)

        -- 3) AutoUpgradeConfig feuern (Slot 1 → 6)
        loadFeedback.Text = "⏳ Setze AutoUpgrade-Konfiguration..."
        for i = 1, 6 do
            local auVal = team.autoUpgrade and team.autoUpgrade[i]
            if auVal ~= nil then
                pcall(function() FireAutoUpgrade(i, auVal) end)
                task.wait(0.15)
            end
        end

        loadFeedback.Text       = "✅ Team '" .. team.name .. "' geladen!"
        loadFeedback.TextColor3 = D.GreenBright
        loadTeamBtn.Text        = "⚡  Team laden (Equip)"
        loadTeamBtn.TextColor3  = Color3.new(1, 1, 1)
        SetTMStatus("✅ Team '" .. team.name .. "' aktiv.", D.Green)
        task.delay(5, function()
            pcall(function() loadFeedback.Text = "" end)
        end)
    end)
end)

