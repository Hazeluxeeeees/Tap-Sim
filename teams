--  ★ getUnitByTag — EINZIGE Methode um Units zu finden
--
--  Greift direkt auf Player_Data[LocalPlayer.Name].Collection zu.
--  Vergleicht folder.Tag.Value mit targetTag.
--  Gibt den Ordner zurück oder nil.
-- ════════════════════════════════════════════════════════════
local function getUnitByTag(targetTag)
    if not targetTag or targetTag == "" then return nil end
    local collection = game:GetService("ReplicatedStorage")
        .Player_Data[game.Players.LocalPlayer.Name].Collection
    for _, folder in pairs(collection:GetChildren()) do
        if folder:FindFirstChild("Tag") and folder.Tag.Value == targetTag then
            return folder
        end
    end
    return nil
end

-- Liest den Item-Namen aus dem Collection-Ordner (z. B. unitFolder.HeadGear.Value)
-- Gibt nil zurück wenn leer / nicht vorhanden
local function readGearValue(unitFolder, gearKey)
    local obj = unitFolder:FindFirstChild(gearKey)
    if not obj then return nil end
    local v = tostring(obj.Value)
    return (v ~= "" and v ~= "nil" and v ~= "0") and v or nil
end

