-- ════════════════════════════════════════════════════════════
--  SNAPSHOT — liest Gear aller aktuell geladenen Units
--  via getUnitByTag aus der Collection (pre-UnEquipAll).
--  Gibt zurück: { [tag] = { name, gears={}, instance } }
-- ════════════════════════════════════════════════════════════
local function buildSnapshot(tagList)
    local snap = {}
    for _, tag in pairs(tagList) do
        if tag and tag ~= "" then
            local unitFolder = getUnitByTag(tag)
            if unitFolder then
                local gears = {}
                for _, slot in ipairs(GEAR_SLOTS) do
                    gears[slot.key] = readGearValue(unitFolder, slot.key)
                end
                snap[tag] = {
                    name     = unitFolder.Name,
                    gears    = gears,
                    instance = unitFolder,
                }
            end
        end
    end
    local n = 0; for _ in pairs(snap) do n = n + 1 end
    print(string.format("[HazeHub/Teams] Snapshot: %d Units erfasst", n))
    return snap
end

-- ════════════════════════════════════════════════════════════
--  LOADOUT SCANNER (für Save)
--
--  UnitLoadout1–6 in Player_Data.Data enthalten den TAG der Einheit
--  (nicht den Namen). Dieser Tag wird direkt gespeichert.
--  Gear wird via getUnitByTag aus der Collection gelesen.
--
--  Gibt zurück:
--    tags[i]   = Tag-String (Primary Key — UnitLoadoutX.Value)
--    names[i]  = Anzeigename (unit.Name aus Collection, für UI)
--    gears[i]  = { HeadGear=..., BodyGear=..., ... }
--    autoUp[i] = AutoUpgrade-Value
-- ════════════════════════════════════════════════════════════
local function scanLoadout()
    local tags   = {}
    local names  = {}
    local gears  = {}
    local autoUp = {}

    local ok, err = pcall(function()
        local data  = PlayerData:WaitForChild("Data", 5)
        local auCfg = PlayerData:FindFirstChild("AutoUpgradeConfig")

        for i = 1, 6 do
            -- UnitLoadoutX.Value ist der Tag (nicht der Name)
            local lv = data:FindFirstChild("UnitLoadout" .. i)
            if lv then
                local tag = tostring(lv.Value)
                if tag ~= "" and tag ~= "nil" then
                    tags[i] = tag

                    -- Collection-Ordner per Tag suchen → Name + Gear lesen
                    local unitFolder = getUnitByTag(tag)
                    if unitFolder then
                        names[i] = unitFolder.Name

                        -- Gear-Values aus Collection-Ordner lesen
                        local unitGears = {}
                        for _, slot in ipairs(GEAR_SLOTS) do
                            unitGears[slot.key] = readGearValue(unitFolder, slot.key)
                        end
                        gears[i] = unitGears
                    else
                        -- Unit existiert, Tag ist valide, aber kein Collection-Eintrag
                        names[i] = "Tag:" .. tag
                        gears[i] = {}
                        warn("[HazeHub/Teams] scanLoadout: kein Collection-Ordner für Tag='" .. tag .. "'")
                    end
                end
            end

            -- AutoUpgrade
            if auCfg then
                local auSlot = auCfg:FindFirstChild(tostring(i))
                if auSlot then autoUp[i] = auSlot.Value end
            end
        end
    end)

    if not ok then
        warn("[HazeHub/Teams] scanLoadout Fehler: " .. tostring(err))
    end

    return tags, names, gears, autoUp
end

-- ════════════════════════════════════════════════════════════
--  ★ LOAD TEAM — Strikte Sequenz (4 Schritte)
--
--  1. Snapshot : Gear der aktuellen Units via getUnitByTag sichern
--  2. Clean    : Gear strippen → UnEquipAll
--  3. Equip    : getUnitByTag(tag) → fireEquip
--  4. Restore  : task.wait(0.1) → Gear aus Snapshot wieder ausrüsten
-- ════════════════════════════════════════════════════════════
local function loadTeam(team, onPhase, onDone, onError)
    onPhase = onPhase or function() end
    onDone  = onDone  or function() end
    onError = onError or function(e) warn("[HazeHub/Teams] " .. tostring(e)) end

    if not team or not team.tags then
        onError("Team hat kein 'tags'-Feld.\nBitte neu speichern (einmalig).")
        return
    end

    -- ── SCHRITT 1: SNAPSHOT ────────────────────────────────
    -- Gear der AKTUELL geladenen Units sichern, bevor irgendetwas verändert wird.
    onPhase(1, "🔍 1/3: Snapshot aktueller Units...")
    print("[HazeHub/Teams] ══ SCHRITT 1: SNAPSHOT ══")

    -- Aktuelle Tags aus Loadout lesen (UnitLoadoutX.Value = Tag)
    local currentTags, _, _, _ = scanLoadout()
    -- Snapshot der aktuellen Units für Gear-Strip
    local currentSnap = buildSnapshot(currentTags)

    -- Equip-Queue aus gespeichertem Team aufbauen
    local queue = {}
    for i = 1, 6 do
        local tag = team.tags[tostring(i)] or team.tags[i]
        if tag and tag ~= "" then
            local unitFolder = getUnitByTag(tag)
            if unitFolder then
                local savedGears = {}
                if team.gears then
                    savedGears = team.gears[tostring(i)] or team.gears[i] or {}
                end
                table.insert(queue, {
                    slotIdx    = i,
                    tag        = tag,
                    name       = unitFolder.Name,
                    savedGears = savedGears,
                })
                local gc = 0
                for _, v in pairs(savedGears) do if v then gc = gc + 1 end end
                print(string.format("  Queue Slot %d → Tag='%s' (%s)  Gear:%d",
                    i, tag, unitFolder.Name, gc))
            else
                warn(string.format("  ⚠ Slot %d: Tag='%s' nicht in Collection. Übersprungen.", i, tag))
            end
        end
    end

    if #queue == 0 then
        onError("Keine Units dieses Teams in der Collection gefunden.\nBitte Team neu speichern.")
        return
    end

    -- ── SCHRITT 2: CLEAN — Gear-Strip + UnEquipAll ─────────
    local stripCount = 0
    for _ in pairs(currentSnap) do stripCount = stripCount + 1 end
    onPhase(2, string.format("⚡ 2/3: Strip %d Units → UnEquipAll...", stripCount))
    print(string.format("[HazeHub/Teams] ══ SCHRITT 2: CLEAN (%d aktuelle Units) ══", stripCount))

    for _, entry in pairs(currentSnap) do
        for _, slotDef in ipairs(GEAR_SLOTS) do
            if entry.gears[slotDef.key] then
                fireUnequipGear(entry.instance, slotDef)
                task.wait(0.04)
            end
        end
    end
    if stripCount > 0 then task.wait(0.2) end

    fireUnEquipAll()  -- enthält intern task.wait(0.6)

    -- ── SCHRITT 3 + 4: EQUIP + GEAR-RESTORE ────────────────
    onPhase(3, string.format("🎯 3/3: Equip %d Units + Gear...", #queue))
    print("[HazeHub/Teams] ══ SCHRITT 3+4: EQUIP + GEAR-RESTORE ══")

    local successCount = 0
    for _, entry in ipairs(queue) do
        -- Schritt 3: Equip (getUnitByTag → frische Instance)
        local equipped = fireEquip(entry.tag)
        if equipped then
            successCount = successCount + 1
            -- Schritt 4: 0.1s warten, dann Gear wiederherstellen
            task.wait(0.1)
            for _, slotDef in ipairs(GEAR_SLOTS) do
                local gearVal = entry.savedGears[slotDef.key]
                if gearVal then
                    fireEquipGear(entry.tag, slotDef, gearVal)
                    task.wait(0.06)
                end
            end
        else
            task.wait(0.1)
        end
    end

    -- AutoUpgrade wiederherstellen
    if team.autoUpgrade then
        for i = 1, 6 do
            local v = team.autoUpgrade[tostring(i)] or team.autoUpgrade[i]
            if v ~= nil then
                fireAutoUpgrade(i, v)
                task.wait(0.1)
            end
        end
    end

    print(string.format("[HazeHub/Teams] ══ FERTIG: %d/%d ('%s') ══",
        successCount, #queue, team.name or "?"))
    onDone(successCount, #queue)
end


