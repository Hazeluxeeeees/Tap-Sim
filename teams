-- RebuildTeamsList
local function rebuildList()
    for _, v in pairs(teamListFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    emptyLbl.Visible = (#TM_State.Teams == 0)

    for idx, team in ipairs(TM_State.Teams) do
        local sel  = (TM_State.SelIdx == idx)
        local hasTags = team.tags ~= nil

        local row = Instance.new("Frame", teamListFrame)
        row.Size = UDim2.new(1,0,0,48)
        row.BackgroundColor3 = sel and D.TabActive or D.CardHover
        row.BackgroundTransparency = 0.3; row.BorderSizePixel = 0
        Corner(row,8); Stroke(row, sel and D.Cyan or D.Border, 1.5, sel and 0 or 0.5)

        -- Grüner/oranger Streifen: zeigt ob Team Tag-Daten hat
        local stripe = Instance.new("Frame", row)
        stripe.Size = UDim2.new(0,5,1,0); stripe.BackgroundColor3 = hasTags and D.Green or D.Orange
        stripe.BackgroundTransparency = 0.3; stripe.BorderSizePixel = 0; Corner(stripe,3)

        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Position = UDim2.new(0,13,0,4); nameLbl.Size = UDim2.new(1,-90,0,20)
        nameLbl.BackgroundTransparency = 1; nameLbl.Text = "⚔  " .. team.name
        nameLbl.TextColor3 = sel and D.Cyan or D.TextHi; nameLbl.TextSize = 12
        nameLbl.Font = Enum.Font.GothamBold; nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd

        local cnt   = 0; for _ = 1,6 do if team.slots and team.slots[_] then cnt=cnt+1 end end
        local note  = hasTags and "🏷 Tag-gespeichert" or "⚠ kein Tag (alt)"

        local subLbl = Instance.new("TextLabel", row)
        subLbl.Position = UDim2.new(0,13,0,26); subLbl.Size = UDim2.new(1,-90,0,14)
        subLbl.BackgroundTransparency = 1
        subLbl.Text = cnt .. "/6  ·  " .. note .. "  ·  " .. os.date("%d.%m.", team.savedAt or 0)
        subLbl.TextColor3 = hasTags and D.TextMid or D.Orange
        subLbl.TextSize = 10; subLbl.Font = Enum.Font.GothamMedium
        subLbl.TextXAlignment = Enum.TextXAlignment.Left

        local delBtn = Instance.new("TextButton", row)
        delBtn.Size = UDim2.new(0,32,0,32); delBtn.Position = UDim2.new(1,-38,0.5,-16)
        delBtn.BackgroundColor3 = Color3.fromRGB(50,12,12); delBtn.Text = "✕"
        delBtn.TextColor3 = D.Red; delBtn.TextSize = 12; delBtn.Font = Enum.Font.GothamBold
        delBtn.AutoButtonColor = false; delBtn.BorderSizePixel = 0
        Corner(delBtn,7); Stroke(delBtn,D.Red,1,0.4)
        delBtn.MouseEnter:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(80,20,20)}) end)
        delBtn.MouseLeave:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(50,12,12)}) end)

        local selBtn = Instance.new("TextButton", row)
        selBtn.Size = UDim2.new(1,-40,1,0); selBtn.BackgroundTransparency = 1
        selBtn.Text = ""; selBtn.BorderSizePixel = 0
        local capIdx = idx

        selBtn.MouseButton1Click:Connect(function()
            TM_State.SelIdx = capIdx
            local t = TM_State.Teams[capIdx]
            if t then
                detailCard.Visible = true
                for i = 1, 6 do
                    local dl   = detailLabels[i]
                    local name = t.slots and t.slots[i]
                    local tag  = t.tags  and (t.tags[tostring(i)] or t.tags[i])
                    if name then
                        local tagStr  = tag and ("  [" .. tag .. "]") or "  [kein Tag]"
                        local gearCnt = 0
                        if t.gears then
                            local g = t.gears[tostring(i)] or t.gears[i]
                            if g then for _, v in pairs(g) do if v then gearCnt=gearCnt+1 end end end
                        end
                        local gearStr = gearCnt > 0 and ("  🗡" .. gearCnt) or ""
                        dl.Text       = name .. tagStr .. gearStr
                        dl.TextColor3 = tag and D.TextHi or D.Orange
                    else
                        dl.Text = "—  (leer)"; dl.TextColor3 = D.TextLow
                    end
                end
            end
            rebuildList()
        end)

        delBtn.MouseButton1Click:Connect(function()
            if TM_State.SelIdx == capIdx then
                TM_State.SelIdx = nil; detailCard.Visible = false
            end
            table.remove(TM_State.Teams, capIdx)
            saveTeamsFile(); rebuildList()
            setStatus("🗑 Team gelöscht.", D.TextMid)
        end)
    end
end
_G._RebuildTeamsList = rebuildList

-- ── LOAD-BUTTON ───────────────────────────────────────────────
loadBtn.MouseButton1Click:Connect(function()
    local idx = TM_State.SelIdx
    if not idx or not TM_State.Teams[idx] then
        loadFeedback.Text = "⚠ Kein Team ausgewählt!"; loadFeedback.TextColor3 = D.Orange; return
    end
    local team = TM_State.Teams[idx]

    loadBtn.Text = "⏳ Lade..."; loadBtn.TextColor3 = D.Yellow; loadBtn.Active = false
    loadFeedback.Text = ""; setStatus("⏳ Lade '" .. team.name .. "'...", D.Yellow)

    task.spawn(function()
        loadTeam(team,
            function(n, txt) -- onPhase
                pcall(function()
                    showPhase(n, txt)
                    loadFeedback.Text = txt; loadFeedback.TextColor3 = D.Yellow
                end)
            end,
            function(ok, total) -- onDone
                pcall(function()
                    hidePhase()
                    loadFeedback.Text = string.format("✅ %d/%d Units geladen!", ok, total)
                    loadFeedback.TextColor3 = D.GreenBright
                    loadBtn.Text = "⚡  Team laden"; loadBtn.TextColor3 = Color3.new(1,1,1)
                    loadBtn.Active = true
                    setStatus("✅ '" .. team.name .. "' aktiv.", D.Green)
                    task.delay(6, function()
                        pcall(function() loadFeedback.Text = "" end)
                    end)
                end)
            end,
            function(err) -- onError
                pcall(function()
                    hidePhase()
                    loadFeedback.Text = "❌ " .. tostring(err)
                    loadFeedback.TextColor3 = D.Red
                    loadBtn.Text = "⚡  Team laden"; loadBtn.TextColor3 = Color3.new(1,1,1)
                    loadBtn.Active = true
                    setStatus("❌ Fehler.", D.Red)
                end)
            end
        )
    end)
end)

