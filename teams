loadTeamBtn.MouseButton1Click:Connect(function()
    local idx = TM_State.SelIdx
    if not idx or not TM_State.Teams[idx] then
        loadFeedback.Text       = "⚠ Kein Team ausgewählt!"
        loadFeedback.TextColor3 = D.Orange
        return
    end
    local team = TM_State.Teams[idx]

    -- UI sperren während LoadTeam läuft
    loadTeamBtn.Text       = "⏳ Lade..."
    loadTeamBtn.TextColor3 = D.Yellow
    loadTeamBtn.Active     = false
    loadFeedback.Text      = ""
    SetTMStatus("⏳ Lade Team '" .. team.name .. "'...", D.Yellow)

    task.spawn(function()
        LoadTeam(
            team,

            -- onPhase: UI-Update pro Phase
            function(phaseNum, text)
                pcall(function()
                    ShowPhase(phaseNum, text)
                    loadFeedback.Text       = text
                    loadFeedback.TextColor3 = D.Yellow
                end)
            end,

            -- onDone
            function(success, total)
                pcall(function()
                    HidePhase()
                    local msg = string.format("✅ Team '%s': %d/%d Units geladen!",
                        team.name, success, total)
                    loadFeedback.Text       = msg
                    loadFeedback.TextColor3 = D.GreenBright
                    loadTeamBtn.Text        = "⚡  Team laden (Snapshot-Modus)"
                    loadTeamBtn.TextColor3  = Color3.new(1, 1, 1)
                    loadTeamBtn.Active      = true
                    SetTMStatus("✅ Team '" .. team.name .. "' aktiv.", D.Green)
                    task.delay(6, function()
                        pcall(function() if loadFeedback then loadFeedback.Text = "" end end)
                    end)
                end)
            end,

            -- onError
            function(errMsg)
                pcall(function()
                    HidePhase()
                    loadFeedback.Text       = "❌ " .. tostring(errMsg)
                    loadFeedback.TextColor3 = D.Red
                    loadTeamBtn.Text        = "⚡  Team laden (Snapshot-Modus)"
                    loadTeamBtn.TextColor3  = Color3.new(1, 1, 1)
                    loadTeamBtn.Active      = true
                    SetTMStatus("❌ Fehler beim Laden.", D.Red)
                end)
            end
        )
    end)
end)

