local function loadTeamsFile()
    if not (isfile and isfile(TEAMS_FILE)) then return end
    local ok, data = pcall(function()
        return Svc.Http:JSONDecode(readfile(TEAMS_FILE))
    end)
    if ok and type(data) == "table" then
        TM_State.Teams = data
        print("[HazeHub/Teams] " .. #TM_State.Teams .. " Teams geladen.")
    end
end

local function saveTeamsFile()
    if not writefile then return end
    pcall(function()
        writefile(TEAMS_FILE, Svc.Http:JSONEncode(TM_State.Teams))
    end)
end

