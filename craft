end

-- ★ ShopItems-Check: Ist dieses Item im Shop kaufbar?
-- Gibt zurück: purchasable (bool), cost (number), shopName (string)
local function GetShopInfo(itemName)
    if not ShopItemsData then return false,0,"" end
    -- ShopItems ist normalerweise eine Tabelle: {ItemName = {Cost=N, ShopType="..."}}
    local info=nil
    pcall(function()
        if type(ShopItemsData)=="table" then
            info=ShopItemsData[itemName]
            -- Manchmal verschachtelt
            if not info then
                for _,shopCat in pairs(ShopItemsData) do
                    if type(shopCat)=="table" and shopCat[itemName] then info=shopCat[itemName]; break end
                end
            end
        end
    end)
    if not info then return false,0,"" end
    local cost=tonumber(info.Cost) or tonumber(info.Price) or tonumber(info.CurrencyAmount) or 0
    local shopType=tostring(info.ShopType or info.Shop or "Shop")
    return true,cost,shopType
end

-- ★ Auto-Buy: kaufe Item via Remote
local function AutoBuyItem(itemName,qty,shopType)
    qty=qty or 1
    local ok,err=pcall(function()
        -- Versuche bekannte Remotes
        local r=nil
        local shopMap={
            GhoulHunt = function() r=RS.Remote.Server.GhoulHuntExchange end,
            Merchant  = function() r=RS.Remote.Server.Merchant end,
        }
        if shopMap[shopType] then pcall(shopMap[shopType]) end
        if not r then
            -- Generischer Fallback: FireServer mit Name+Qty
            pcall(function() r=RS:FindFirstChild("Remote",true) and RS.Remote.Server[shopType] end)
        end
        if r then r:FireServer(itemName,qty)
        else warn("[HazeHub-Craft] Kein Remote für Shop: "..shopType) end
    end)
    return ok
end

local function AllMatsMet(recipeName,amount)
    amount=amount or 1
    if not CraftingRecipes or not CraftingRecipes[recipeName] then return false end
    local recipe=CraftingRecipes[recipeName]; if not recipe.Requirement then return false end
    for mat,amt in pairs(recipe.Requirement) do
        if GetItemAmt(mat)<(amt*amount) then return false end
    end
    return true
end

-- ★ Prüft ob alles bereit ist (inkl. kaufbarer Items die man sich leisten kann)
local function AllReady(recipeName,amount)
    amount=amount or 1
    if not CraftingRecipes or not CraftingRecipes[recipeName] then return false end
    local recipe=CraftingRecipes[recipeName]; if not recipe.Requirement then return false end
    local gold=GetGold()
    local totalCost=0
    for mat,amt in pairs(recipe.Requirement) do
        local need=amt*amount; local have=GetItemAmt(mat)
        if have<need then
            local purchasable,cost,_=GetShopInfo(mat)
            if purchasable then
                totalCost=totalCost+cost*(need-have)
            else return false end
        end
    end
    return gold>=totalCost
end

-- Beste Welt für Material finden
local function FindBestWorld(matName)
    local db=_G.HazeShared._AutoFarm_RewardDB
    if db then
        local bestChap,bestWorld,bestMode,bestRate=nil,nil,nil,-1
        for chapId,data in pairs(db) do
            if data.items and data.items[matName] then
                local r=data.items[matName].dropRate or 0
                if r>bestRate then bestRate=r; bestChap=data.chapId or chapId; bestWorld=data.world; bestMode=data.mode end
            end
        end
        if bestChap then return bestChap,bestWorld,bestMode end
    end
    local wData=HS.GetWorldData and HS.GetWorldData(); local wIds=HS.GetWorldIds and HS.GetWorldIds()
    if wData and wIds then
        for _,wid in ipairs(wIds) do
            local wd=wData[wid] or {}
            if wd.story and #wd.story>0 then return wd.story[1],wid,"Story" end
        end
    end
    return nil,nil,nil
end

