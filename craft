local function BuildRecipeCard(parent,itemName,recipeData,craftAmt)
    craftAmt=craftAmt or 1
    local allMet=true; local anyShop=false; local matLines={}
    if recipeData.Requirement then
        for mat,amt in pairs(recipeData.Requirement) do
            local have=GetItemAmt(mat); local need=amt*craftAmt; local met=have>=need
            local purchasable,shopCost,shopType=GetShopInfo(mat)
            local shopMet=false
            if not met and purchasable then
                -- Kaufbar – zählt als "bereit" wenn genug Gold
                local goldNeeded=shopCost*(need-have)
                shopMet=(GetGold()>=goldNeeded)
                if shopMet then anyShop=true end
            end
            if not met and not shopMet then allMet=false end
            table.insert(matLines,{name=mat,have=have,need=need,met=met,purchasable=purchasable,shopCost=shopCost,shopType=shopType,shopMet=shopMet})
        end
        table.sort(matLines,function(a,b)
            if a.met~=b.met then return not a.met end
            if a.shopMet~=b.shopMet then return not a.shopMet end
            return a.name<b.name
        end)
    end

    local card=Instance.new("Frame",parent); card.Size=UDim2.new(1,0,0,0); card.AutomaticSize=Enum.AutomaticSize.Y; card.BorderSizePixel=0; Corner(card,9)
    if allMet and anyShop then card.BackgroundColor3=Color3.fromRGB(0,35,18); Stroke(card,D.Gold,1.5,0.1)
    elseif allMet then card.BackgroundColor3=Color3.fromRGB(0,28,16); Stroke(card,D.GreenBright,1.5,0.1)
    else card.BackgroundColor3=D.Card; Stroke(card,D.Border,1,0.3) end

    local inner=Instance.new("Frame",card); inner.Size=UDim2.new(1,0,0,0); inner.AutomaticSize=Enum.AutomaticSize.Y; inner.BackgroundTransparency=1; Pad(inner,8,10,8,10); VList(inner,6)

    -- Header: Item-Preview + Name
    local headerRow=Instance.new("Frame",inner); headerRow.Size=UDim2.new(1,0,0,56); headerRow.BackgroundTransparency=1

    local preview=nil
    if HS.BuildItemPreview then
        preview=HS.BuildItemPreview(headerRow,itemName,52)
        preview.Position=UDim2.new(0,0,0,0)
    else
        local vp=Instance.new("ViewportFrame",headerRow); vp.Size=UDim2.new(0,52,0,52); vp.Position=UDim2.new(0,0,0,0); vp.BackgroundColor3=Color3.fromRGB(12,18,36); vp.BorderSizePixel=0; vp.ImageColor3=Color3.new(1,1,1); Corner(vp,7)
        task.spawn(function()
            local ok=LoadItemViewport(vp,itemName)
            if not ok then
                local fb=Instance.new("TextLabel",vp); fb.Size=UDim2.new(1,0,1,0); fb.BackgroundTransparency=1; fb.Text=itemName:sub(1,1):upper(); fb.TextColor3=D.TextMid; fb.TextSize=18; fb.Font=Enum.Font.GothamBold; fb.TextXAlignment=Enum.TextXAlignment.Center; fb.TextYAlignment=Enum.TextYAlignment.Center
            end
        end)
        preview=vp
