end

-- ============================================================
--  REZEPT-LISTE AUFBAUEN
-- ============================================================
function RebuildCraftingList()
    if not CraftingRecipes then
        SetCraftStatus("⚠ CraftingRecipes nicht geladen!", D.Orange)
        return
    end

    local filter    = (Craft.UI.Inp.Search.Text or ""):lower():match("^%s*(.-)%s*$")
    local craftAmt  = math.max(1, tonumber(Craft.UI.Inp.Amount.Text) or 1)

    -- Alte Karten entfernen
    for _, v in pairs(Craft.UI.Fr.RecipeList:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    -- Rezepte sammeln + filtern
    local recipes = {}
    for itemName, data in pairs(CraftingRecipes) do
        if type(data) == "table" and data.Requirement then
            if filter == "" or itemName:lower():find(filter, 1, true) then
                table.insert(recipes, { name = itemName, data = data })
            end
        end
    end

    -- Sortieren: zuerst craftbare Items, dann alphabetisch
    table.sort(recipes, function(a, b)
        local aOk = CheckRecipeMet(a.name, craftAmt)
        local bOk = CheckRecipeMet(b.name, craftAmt)
        if aOk ~= bOk then return aOk end
        return a.name:lower() < b.name:lower()
    end)

    if #recipes == 0 then
        Craft.UI.Lbl.NoRecipes.Visible = true
        Craft.UI.Lbl.NoRecipes.Text =
            filter ~= "" and ("Kein Rezept für '" .. filter .. "' gefunden.")
                          or "Keine Rezepte geladen."
        SetCraftStatus("0 Rezepte", D.TextLow)
        return
    end

    Craft.UI.Lbl.NoRecipes.Visible = false

    local craftable = 0
    for _, r in ipairs(recipes) do
        if CheckRecipeMet(r.name, craftAmt) then craftable = craftable + 1 end
        BuildRecipeCard(Craft.UI.Fr.RecipeList, r.name, r.data, craftAmt)
        -- Task-Yield um GUI nicht zu blockieren
        task.wait()
    end

    SetCraftStatus(
        string.format("✅ %d Rezept%s | %d craftbar",
            #recipes, #recipes == 1 and "" or "e", craftable),
        craftable > 0 and D.Green or D.TextMid)
end

-- ============================================================
--  AUTO-COLLECTOR LOGIK
-- ============================================================
local function RunAutoCollector()
    if Craft.Collecting then
        SetCraftStatus("⚠ Auto-Collector läuft bereits!", D.Yellow)
        return
    end
    if #Craft.CollectQueue == 0 then
        SetCraftStatus("⚠ Queue ist leer!", D.Orange)
        return
    end

    -- PlayRoom-Remote holen (nutzt R.PlayRoom aus Hauptskript falls vorhanden)
    local prRemote = nil
    pcall(function()
        prRemote = RS:WaitForChild("Remote", 5)
            :WaitForChild("Server", 5)
            :WaitForChild("PlayRoom", 5)
            :WaitForChild("Event", 5)
    end)

    local function Fire(action, data)
        if prRemote then
            pcall(function()
                if data then prRemote:FireServer(action, data)
                else         prRemote:FireServer(action) end
            end)
        end
    end

    local function IsInLobby()
        return game:GetService("Workspace"):FindFirstChild("Lobby") ~= nil
    end

    Craft.Collecting = true
    Craft.UI.Btn.StartCollect.Text = "⏳  Sammle..."
    Craft.UI.Btn.StartCollect.TextColor3 = D.Yellow
    Craft.UI.Fr.CollBarBg.Visible = true

    task.spawn(function()
        local totalItems = #Craft.CollectQueue

        while Craft.Collecting and #Craft.CollectQueue > 0 do
            -- Abgeschlossene Items entfernen
            for i = #Craft.CollectQueue, 1, -1 do
                local e = Craft.CollectQueue[i]
                if GetItemAmt(e.matName) >= e.needed then
                    SetCraftStatus(
                        string.format("✅ '%s' gesammelt! Nächstes...", e.matName),
                        D.Green)
                    table.remove(Craft.CollectQueue, i)
                    pcall(UpdateCollectQueueUI)
                    task.wait(0.5)
                end
            end

            if #Craft.CollectQueue == 0 then break end

            local current = Craft.CollectQueue[1]
            local cur     = GetItemAmt(current.matName)

            -- Fortschrittsbalken
            local pct = math.min(1, cur / math.max(1, current.needed))
            pcall(function()
                Tw(Craft.UI.Fr.CollBarFill,
                    { Size = UDim2.new(pct, 0, 1, 0),
                      BackgroundColor3 = pct >= 1 and D.Green or D.Purple }, TF)
            end)

            SetCraftStatus(
                string.format("🤖 Sammle '%s': %d/%d",
                    current.matName, cur, current.needed),
                D.Purple)

            if cur >= current.needed then
                -- Schon fertig, nächste Iteration räumt auf
                task.wait(0.3)
                continue
            end

            -- In Lobby-Phase: Stage starten
            if IsInLobby() then
                if not current.chapId then
                    SetCraftStatus(
                        string.format("⚠ Kein Chapter für '%s' bekannt – überspringe",
                            current.matName), D.Orange)
                    table.remove(Craft.CollectQueue, 1)
                    pcall(UpdateCollectQueueUI)
                    task.wait(1)
                    continue
                end

                SetCraftStatus(
                    string.format("🚀 Starte [%s] %s für '%s'",
                        current.mode or "Story",
                        current.chapId, current.matName),
                    D.Cyan)

                pcall(function()
                    local m = current.mode or "Story"
                    if m == "Story" then
                        Fire("Create");                                                task.wait(0.4)
                        Fire("Change-World",   { World   = current.worldId });        task.wait(0.4)
                        Fire("Change-Chapter", { Chapter = current.chapId })
                        task.wait(2.0)
                        Fire("Submit");                                                task.wait(0.5)
                        Fire("Start")
                    elseif m == "Ranger" then
                        Fire("Create");                                                task.wait(0.4)
                        Fire("Change-Mode",
                            { KeepWorld = current.worldId, Mode = "Ranger Stage" });  task.wait(0.6)
                        Fire("Change-World",   { World   = current.worldId });        task.wait(0.4)
                        Fire("Change-Chapter", { Chapter = current.chapId })
                        task.wait(2.0)
                        Fire("Submit");                                                task.wait(0.5)
                        Fire("Start")
                    elseif m == "Calamity" then
                        Fire("Create");                                                task.wait(0.4)
                        Fire("Change-Mode",    { Mode    = "Calamity" });             task.wait(0.4)
                        Fire("Change-Chapter", { Chapter = current.chapId })
                        task.wait(2.0)
                        Fire("Submit");                                                task.wait(0.5)
                        Fire("Start")
                    end
                end)

                -- Warten bis Lobby verlassen
                local leaveWait = 0
                while IsInLobby() and leaveWait < 20 and Craft.Collecting do
                    task.wait(1); leaveWait = leaveWait + 1
                end

            else
                -- In Runde: Inventar überwachen, auf Lobby warten
                local roundWait = 0
                while not IsInLobby() and roundWait < 360 and Craft.Collecting do
                    task.wait(3); roundWait = roundWait + 3
                    local nowHave = GetItemAmt(current.matName)
                    local nowPct  = math.min(1, nowHave / math.max(1, current.needed))
                    pcall(function()
                        Tw(Craft.UI.Fr.CollBarFill,
                            { Size = UDim2.new(nowPct, 0, 1, 0) }, TF)
                    end)
                    SetCraftStatus(
                        string.format("⚔ Runde läuft | '%s': %d/%d",
                            current.matName, nowHave, current.needed),
                        D.Orange)
                    if nowHave >= current.needed then
                        break
                    end
                end

                -- Nach Runde kurz warten
                if IsInLobby() then task.wait(2) end
            end

            pcall(UpdateCollectQueueUI)
        end

        -- Abschluss
        Craft.Collecting = false
        pcall(function()
            Craft.UI.Btn.StartCollect.Text = "🤖  Start Auto-Collector"
            Craft.UI.Btn.StartCollect.TextColor3 = D.Purple
            Tw(Craft.UI.Fr.CollBarFill,
                { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = D.Green }, TM)
        end)

        if #Craft.CollectQueue == 0 then
            SetCraftStatus("✅ Alle Materialien gesammelt! Bereit zum Craften.", D.GreenBright)
            -- Rezept-Liste aktualisieren
            task.delay(0.5, function()
                pcall(RebuildCraftingList)
            end)
        else
            SetCraftStatus("⏹ Auto-Collector gestoppt.", D.TextMid)
        end

        pcall(UpdateCollectQueueUI)
    end)
end

