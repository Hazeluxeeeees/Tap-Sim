-- ── Rezept-Liste aufbauen ─────────────────────────────────────
function RebuildCraftList()
    if not CraftingRecipes then SetStatus("⚠ CraftingRecipes nicht geladen!",D.Orange); return end
    local filter=(Craft.UI.Inp.Search.Text or ""):lower():match("^%s*(.-)%s*$")
    local craftAmt=math.max(1,tonumber(Craft.UI.Inp.Amount.Text) or 1)
    for _,v in pairs(Craft.UI.Fr.RecipeList:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local recipes={}
    for itemName,data in pairs(CraftingRecipes) do
        if type(data)=="table" and data.Requirement then
            if filter=="" or itemName:lower():find(filter,1,true) then table.insert(recipes,{name=itemName,data=data}) end
        end
    end
    table.sort(recipes,function(a,b)
        local aOk=AllReady(a.name,craftAmt); local bOk=AllReady(b.name,craftAmt)
        if aOk~=bOk then return aOk end; return a.name:lower()<b.name:lower()
    end)
    if #recipes==0 then
        Craft.UI.Lbl.NoRecipes.Visible=true; Craft.UI.Lbl.NoRecipes.Text=filter~="" and ("Kein Rezept für '"..filter.."'") or "Keine Rezepte."
        SetStatus("0 Rezepte",D.TextLow); return
    end
    Craft.UI.Lbl.NoRecipes.Visible=false; local craftable=0
    for _,r in ipairs(recipes) do
        if AllReady(r.name,craftAmt) then craftable=craftable+1 end
        BuildRecipeCard(Craft.UI.Fr.RecipeList,r.name,r.data,craftAmt)
        task.wait()
    end
    SetStatus(string.format("✅ %d Rezept%s | %d bereit",#recipes,#recipes==1 and "" or "e",craftable),craftable>0 and D.Green or D.TextMid)
end

-- ── Auto-Collector ────────────────────────────────────────────
local function RunCollector()
    if Craft.Collecting then SetStatus("⚠ Läuft bereits!",D.Yellow); return end
    if #Craft.Queue==0 then SetStatus("⚠ Queue leer!",D.Orange); return end
    local prRemote=nil; pcall(function() prRemote=RS:WaitForChild("Remote",5):WaitForChild("Server",5):WaitForChild("PlayRoom",5):WaitForChild("Event",5) end)
    local function Fire(a,d) if prRemote then pcall(function() if d then prRemote:FireServer(a,d) else prRemote:FireServer(a) end end) end end
    local function IsLobby() return game:GetService("Workspace"):FindFirstChild("Lobby")~=nil end
    Craft.Collecting=true; Craft.UI.Btn.Start.Text="⏳  Sammle..."; Craft.UI.Btn.Start.TextColor3=D.Yellow; Craft.UI.Fr.CollBarBg.Visible=true

    task.spawn(function()
        while Craft.Collecting and #Craft.Queue>0 do
            -- Erledigte Items und Shop-Items abarbeiten
            for i=#Craft.Queue,1,-1 do
                local e=Craft.Queue[i]
                -- ★ Shop-Items sofort kaufen
                if e.shopType then
                    local have=GetItemAmt(e.matName); local missing=e.needed-have
                    if missing>0 then
                        SetStatus(string.format("🛒 Kaufe %d × %s",missing,e.matName),D.Gold)
                        AutoBuyItem(e.matName,missing,e.shopType); task.wait(1)
                    end
                end
                if GetItemAmt(e.matName)>=e.needed then table.remove(Craft.Queue,i); pcall(UpdateQueueUI); task.wait(0.3) end
            end
            if #Craft.Queue==0 then break end
            local cur=Craft.Queue[1]; local have=GetItemAmt(cur.matName); local pct=math.min(1,have/math.max(1,cur.needed))
            pcall(function() Tw(Craft.UI.Fr.CollBarFill,{Size=UDim2.new(pct,0,1,0),BackgroundColor3=pct>=1 and D.Green or D.Purple},TF) end)
            SetStatus(string.format("🤖 '%s': %d/%d",cur.matName,have,cur.needed),D.Purple)
            if have>=cur.needed then task.wait(0.3); continue end
            if IsLobby() then
                if not cur.chapId then SetStatus(string.format("⚠ Kein Chapter für '%s'",cur.matName),D.Orange); table.remove(Craft.Queue,1); pcall(UpdateQueueUI); task.wait(1); continue end
                SetStatus(string.format("🚀 [%s] %s",cur.mode or "Story",cur.chapId),D.Cyan)
                pcall(function()
                    local m=cur.mode or "Story"
                    if m=="Story" then Fire("Create"); task.wait(0.4); Fire("Change-World",{World=cur.worldId}); task.wait(0.4); Fire("Change-Chapter",{Chapter=cur.chapId}); task.wait(2); Fire("Submit"); task.wait(0.5); Fire("Start")
                    elseif m=="Ranger" then Fire("Create"); task.wait(0.4); Fire("Change-Mode",{KeepWorld=cur.worldId,Mode="Ranger Stage"}); task.wait(0.6); Fire("Change-World",{World=cur.worldId}); task.wait(0.4); Fire("Change-Chapter",{Chapter=cur.chapId}); task.wait(2); Fire("Submit"); task.wait(0.5); Fire("Start")
                    elseif m=="Calamity" then Fire("Create"); task.wait(0.4); Fire("Change-Mode",{Mode="Calamity"}); task.wait(0.4); Fire("Change-Chapter",{Chapter=cur.chapId}); task.wait(2); Fire("Submit"); task.wait(0.5); Fire("Start") end
                end)
                local lw=0; while IsLobby() and lw<20 and Craft.Collecting do task.wait(1); lw=lw+1 end
            else
                local rw=0
                while not IsLobby() and rw<360 and Craft.Collecting do
                    task.wait(3); rw=rw+3; local nowHave=GetItemAmt(cur.matName); local np=math.min(1,nowHave/math.max(1,cur.needed))
                    pcall(function() Tw(Craft.UI.Fr.CollBarFill,{Size=UDim2.new(np,0,1,0)},TF) end)
                    SetStatus(string.format("⚔ Runde | '%s': %d/%d",cur.matName,nowHave,cur.needed),D.Orange)
                    if nowHave>=cur.needed then break end
                end
                if IsLobby() then task.wait(2) end
            end
            pcall(UpdateQueueUI)
        end
        Craft.Collecting=false
        pcall(function() Craft.UI.Btn.Start.Text="🤖  Start Auto-Farm"; Craft.UI.Btn.Start.TextColor3=D.Purple; Tw(Craft.UI.Fr.CollBarFill,{Size=UDim2.new(1,0,1,0),BackgroundColor3=D.Green},TM) end)
        if #Craft.Queue==0 then SetStatus("✅ Alle Materialien gesammelt! Bereit zum Craften.",D.GreenBright); task.delay(0.5,function() pcall(RebuildCraftList) end)
        else SetStatus("⏹ Auto-Collector gestoppt.",D.TextMid) end
        pcall(UpdateQueueUI)
    end)
end

