local function FmtNum(n)
    n = math.floor(tonumber(n) or 0)
    local s = tostring(n); local r = ""; local c = 0
    for i = #s, 1, -1 do
        c = c + 1; r = s:sub(i, i) .. r
        if c % 3 == 0 and i > 1 then r = "," .. r end
    end
    return r
end

-- Inventar-Menge live abrufen
local function GetItemAmt(itemName)
    local n = 0
    pcall(function()
        local itemsFolder = RS:WaitForChild("Player_Data", 3)
            :WaitForChild(LP.Name, 3)
            :WaitForChild("Items", 3)
        local item = itemsFolder:FindFirstChild(itemName)
        if not item then return end
        local vc = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
        if vc then
            n = tonumber(vc.Value) or 0
        elseif item:IsA("IntValue") or item:IsA("NumberValue") then
            n = tonumber(item.Value) or 0
        end
    end)
    return n
end

-- Rezept-Anforderungen prüfen: true = alle Items vorhanden
local function CheckRecipeMet(recipeName, amount)
    amount = amount or 1
    if not CraftingRecipes or not CraftingRecipes[recipeName] then return false end
    local recipe = CraftingRecipes[recipeName]
    if not recipe.Requirement then return false end
    for matName, matAmt in pairs(recipe.Requirement) do
        if GetItemAmt(matName) < (matAmt * amount) then
            return false
        end
    end
    return true
end

-- Viewport-Modell laden (Item ODER Unit)
local function LoadModelIntoViewport(viewport, itemName)
    -- Alte Inhalte bereinigen
    for _, v in pairs(viewport:GetDescendants()) do
        if v:IsA("Model") or v:IsA("Camera") or v:IsA("WorldModel") then
            v:Destroy()
        end
    end

    local wm = Instance.new("WorldModel")
    wm.Parent = viewport

    local model = nil
    pcall(function()
        if GetData then
            model = GetData.GetItemModel(itemName)
            if not model then
                model = GetData.GetUnitModel(itemName)
            end
        end
    end)

    if not model then return false end

    local ok = pcall(function()
        local clone = model:Clone()
        clone.Parent = wm

        local cam = Instance.new("Camera")
        cam.Parent = viewport
        viewport.CurrentCamera = cam

        if clone.PrimaryPart then
            cam.CFrame = clone.PrimaryPart.CFrame * CFrame.new(0, 0, 2.5)
            clone:SetPrimaryPartCFrame(
                CFrame.lookAt(clone.PrimaryPart.Position, cam.CFrame.Position)
            )
        end

        -- Idle-Animation
        local humanoid = clone:FindFirstChild("Humanoid", true)
        if humanoid then
            local anims = humanoid.Parent:FindFirstChild("Animations")
            if anims then
                local idle = anims:FindFirstChild("Idle")
                if idle then
                    humanoid:LoadAnimation(idle):Play()
                end
            end
        end
    end)
    return ok
end

-- Beste Welt für ein Material finden (aus RewardDB)
local function FindBestWorldForMaterial(matName)
    -- 1. Versuch: RewardDB aus autofarm (RAM)
    if _G.HazeShared._AutoFarm_RewardDB then
        local db = _G.HazeShared._AutoFarm_RewardDB
        local bestChap, bestWorld, bestMode, bestRate = nil, nil, nil, -1
        for chapId, data in pairs(db) do
            if data.items and data.items[matName] then
                local r = data.items[matName].dropRate or 0
                if r > bestRate then
                    bestRate  = r
                    bestChap  = data.chapId or chapId
                    bestWorld = data.world
                    bestMode  = data.mode
                end
            end
        end
        if bestChap then
            return bestChap, bestWorld, bestMode, bestRate
        end
    end

    -- 2. Versuch: WorldCache-Datei (WorldData aus Hauptskript)
    local worldData = nil
    local worldIds  = nil
    pcall(function()
        worldData = HS.GetWorldData and HS.GetWorldData()
        worldIds  = HS.GetWorldIds  and HS.GetWorldIds()
    end)

    if worldData and worldIds then
        for _, wid in ipairs(worldIds) do
            local wd = worldData[wid] or {}
            -- Fallback: ersten verfügbaren Chapter nehmen
            if wd.story and #wd.story > 0 then
                return wd.story[1], wid, "Story", 0
            end
        end
    end

    return nil, nil, nil, 0
end

