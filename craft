local function UpdateCollectQueueUI()
    -- Queue-Zeilen leeren
    for _, v in pairs(Craft.UI.Fr.CollQueue:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    if #Craft.CollectQueue == 0 then
        Craft.UI.Lbl.CollStatus.Text = "Queue leer."
        Craft.UI.Lbl.CollStatus.TextColor3 = D.TextLow
        Craft.UI.Fr.CollBarBg.Visible = false
        return
    end

    Craft.UI.Fr.CollBarBg.Visible = true
    Craft.UI.Lbl.CollStatus.Text = string.format(
        "🤖 %d Material%s in Queue", #Craft.CollectQueue,
        #Craft.CollectQueue == 1 and "" or "ien")
    Craft.UI.Lbl.CollStatus.TextColor3 = D.Purple

    for i, entry in ipairs(Craft.CollectQueue) do
        local cur    = GetItemAmt(entry.matName)
