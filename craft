local function FmtNum(n)
    n = math.floor(tonumber(n) or 0); local s = tostring(n); local r = ""; local c = 0
    for i = #s, 1, -1 do c=c+1; r=s:sub(i,i)..r; if c%3==0 and i>1 then r=","..r end end
    return r
end

local function GetItemAmt(name)
    local n = 0
    pcall(function()
        local f = RS:WaitForChild("Player_Data",3):WaitForChild(LP.Name,3):WaitForChild("Items",3)
        local it = f:FindFirstChild(name); if not it then return end
        local vc = it:FindFirstChild("Amount") or it:FindFirstChild("Value")
        if vc then n = tonumber(vc.Value) or 0
        elseif it:IsA("IntValue") or it:IsA("NumberValue") then n = tonumber(it.Value) or 0 end
    end)
    return n
end

local function AllMatsMet(recipeName, amount)
    amount = amount or 1
    if not CraftingRecipes or not CraftingRecipes[recipeName] then return false end
    local recipe = CraftingRecipes[recipeName]
    if not recipe.Requirement then return false end
    for mat, amt in pairs(recipe.Requirement) do
        if GetItemAmt(mat) < (amt * amount) then return false end
    end
    return true
end

-- Viewport-Modell laden
local function LoadViewport(vp, itemName)
    for _, v in pairs(vp:GetDescendants()) do
        if v:IsA("Model") or v:IsA("Camera") or v:IsA("WorldModel") then v:Destroy() end
    end
    local wm = Instance.new("WorldModel"); wm.Parent = vp
    local model = nil
    pcall(function()
        if GetData then
            model = GetData.GetItemModel(itemName)
            if not model then model = GetData.GetUnitModel(itemName) end
        end
    end)
    if not model then return false end
    local ok = pcall(function()
        local clone = model:Clone(); clone.Parent = wm
        local cam = Instance.new("Camera"); cam.Parent = vp; vp.CurrentCamera = cam
        if clone.PrimaryPart then
            cam.CFrame = clone.PrimaryPart.CFrame * CFrame.new(0,0,2.5)
            clone:SetPrimaryPartCFrame(CFrame.lookAt(clone.PrimaryPart.Position, cam.CFrame.Position))
        end
        local hum = clone:FindFirstChild("Humanoid",true)
        if hum then
            local anims = hum.Parent:FindFirstChild("Animations")
            if anims then local idle=anims:FindFirstChild("Idle"); if idle then hum:LoadAnimation(idle):Play() end end
        end
    end)
    return ok
end

-- Beste Welt für ein Material finden
local function FindBestWorld(matName)
    -- 1: RewardDB aus autofarm
    local db = _G.HazeShared._AutoFarm_RewardDB
    if db then
        local bestChap, bestWorld, bestMode, bestRate = nil, nil, nil, -1
        for chapId, data in pairs(db) do
            if data.items and data.items[matName] then
                local r = data.items[matName].dropRate or 0
                if r > bestRate then bestRate=r; bestChap=data.chapId or chapId; bestWorld=data.world; bestMode=data.mode end
            end
        end
        if bestChap then return bestChap, bestWorld, bestMode end
    end
    -- 2: WorldCache Fallback – ersten verfügbaren Chapter nehmen
    local wData = HS.GetWorldData and HS.GetWorldData()
    local wIds  = HS.GetWorldIds  and HS.GetWorldIds()
    if wData and wIds then
        for _, wid in ipairs(wIds) do
            local wd = wData[wid] or {}
            if wd.story and #wd.story > 0 then return wd.story[1], wid, "Story" end
        end
    end
    return nil, nil, nil
end

