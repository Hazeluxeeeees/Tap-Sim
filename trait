local function AutoRerollLoop()
    TR.Rolling = true
    TR.RollCount = 0
    startRerollBtn.Text = "⏳ Rollt..."; startRerollBtn.TextColor3 = D.Yellow; Stroke(startRerollBtn, D.Yellow, 2, 0.15)
