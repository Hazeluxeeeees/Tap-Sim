local function CheckGoalReached()
    if not TR.SelectedUnit then return false end
    local main,sub=GetUnitTraits(TR.SelectedUnit)
    if main and TR.TargetTraits[main] then SetStatus("🎉 Ziel-Trait '"..main.."' ERREICHT!",D.GreenBright); return true end
    if sub  and TR.TargetTraits[sub]  then SetStatus("🎉 Ziel-Trait '"..sub.."' ERREICHT!",D.GreenBright);  return true end
    return false
end

local function DoSingleReroll()
    if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!",D.Orange); return false end
    if not RerollRemote    then SetStatus("⚠ RerollTrait Remote fehlt!",D.Orange); return false end
    local curMain,curSub=GetUnitTraits(TR.SelectedUnit); curMain=curMain or ""; curSub=curSub or ""
    pcall(function() if TraitAckRemote then TraitAckRemote:FireServer() end end)
    task.wait(0.06)
    local ok=pcall(function()
        RerollRemote:FireServer(TR.SelectedUnit,"Reroll","Main",TR_SELECTED_CURRENCY,{curMain,curSub})
    end)
    if ok then TR.RollCount=TR.RollCount+1 end
    return ok
end

