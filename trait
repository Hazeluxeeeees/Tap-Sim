local function BuildTraitOverview(filter)
    for _,v in pairs(trListFrame:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    filter=(filter or ""):lower()
    local sorted={}
    for name,data in pairs(AllTraits) do
        if filter=="" or name:lower():find(filter,1,true) then table.insert(sorted,{name=name,data=data}) end
    end
    table.sort(sorted,function(a,b)
        local ra=RARITY_ORDER[(a.data and a.data.Rarity) or "Common"] or 99
        local rb=RARITY_ORDER[(b.data and b.data.Rarity) or "Common"] or 99
        if ra~=rb then return ra<rb end; return a.name:lower()<b.name:lower()
    end)
    for _,entry in ipairs(sorted) do
        local td=entry.data; local col=GetRarityColor(td and td.Rarity)
        local row=Instance.new("Frame",trListFrame); row.Size=UDim2.new(1,0,0,0); row.AutomaticSize=Enum.AutomaticSize.Y; row.BorderSizePixel=0; Corner(row,7); row.BackgroundColor3=D.Card; Stroke(row,col,1,0.5)
