-- ╔══════════════════════════════════════════════════════════╗
--  FIX #1 – GRADE_LIST: geordnete Array-Tabelle
--  GradeIndex(grade) liefert den Index (1–17).
--  RankAtLeast nutzt Index-Vergleich: robuster als Map-Lookup.
-- ╚══════════════════════════════════════════════════════════╝
local GRADE_LIST = {
    "C-","C","C+",
    "B-","B","B+",
    "A-","A","A+",
    "S-","S","S+",
    "SS","SSS",
    "O-","O","O+",
}
-- Schnelle Umkehrtabelle für O(1)-Lookup
local GRADE_INDEX = {}
for i, g in ipairs(GRADE_LIST) do GRADE_INDEX[g] = i end

-- Einheitliche StatValues-Tabelle (Alias für Rückwärtskompatibilität)
local StatValues = GRADE_INDEX
local STAT_RANK_VALUE = GRADE_INDEX

local ALL_RATINGS = GRADE_LIST

-- GradeIndex: gibt numerischen Index zurück (0 wenn unbekannt)
local function GradeIndex(grade)
    return GRADE_INDEX[grade] or 0
end

-- ToRankString: wandelt rohen Wert in Grade-String
local function ToRankString(v)
    local s = tostring(v or ""):upper():gsub("%s+",""):gsub("PLUS","+")
    if GRADE_INDEX[s] then return s end
    local n = tonumber(v)
    if n then
        if     n >= 17 then return "O+"
        elseif n >= 16 then return "O"
        elseif n >= 15 then return "O-"
        elseif n >= 14 then return "SSS"
        elseif n >= 13 then return "SS"
        elseif n >= 12 then return "S+"
        elseif n >= 11 then return "S"
        elseif n >= 10 then return "S-"
        elseif n >= 9  then return "A+"
        elseif n >= 8  then return "A"
        elseif n >= 7  then return "A-"
        elseif n >= 6  then return "B+"
        elseif n >= 5  then return "B"
        elseif n >= 4  then return "B-"
        elseif n >= 3  then return "C+"
        elseif n >= 2  then return "C"
        else                return "C-"
        end
    end
    return "C-"
end

-- FIX #1: RankAtLeast nutzt GradeIndex (Index-Vergleich, nicht Map)
-- Stoppt wenn current >= target (z. B. S+ stoppt bei Ziel S)
local function RankAtLeast(rank, target)
    local ri = GradeIndex(ToRankString(rank))
    local ti = GradeIndex(ToRankString(target))
    -- Beide müssen gültige Grades sein (Index > 0)
    return ri > 0 and ti > 0 and ri >= ti
end

