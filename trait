-- ── Live-Trait lesen ─────────────────────────────────────────
local function GetUnitTraits(unitInstance)
    local main, sub = nil, nil
    pcall(function()
        local tf = unitInstance:FindFirstChild("Traits") or unitInstance:FindFirstChild("Trait")
        if tf then
            local pm = tf:FindFirstChild("PrimaryTrait") or tf:FindFirstChild("Primary")
            local ps = tf:FindFirstChild("SecondaryTrait") or tf:FindFirstChild("Secondary") or tf:FindFirstChild("SubTrait")
            if pm then main = tostring(pm.Value) end
            if ps then sub  = tostring(ps.Value) end
        else
            -- Direkt am Instance
            local pm = unitInstance:FindFirstChild("PrimaryTrait") or unitInstance:FindFirstChild("Primary")
            local ps = unitInstance:FindFirstChild("SecondaryTrait") or unitInstance:FindFirstChild("Secondary")
            if pm then main = tostring(pm.Value) end
            if ps then sub  = tostring(ps.Value) end
        end
    end)
    return main, sub
end

local function UpdateLiveTraitDisplay()
    if not TR.SelectedUnit then
        TR.UI.Lbl.UnitName.Text="Keine Einheit gewählt"; TR.UI.Lbl.UnitName.TextColor3=D.TextLow
        TR.UI.Lbl.MainTrait.Text="–"; TR.UI.Lbl.MainTrait.TextColor3=D.TextLow
        TR.UI.Lbl.SubTrait.Text="–"; TR.UI.Lbl.SubTrait.TextColor3=D.TextLow
        TR.UI.Lbl.MainRarity.Text=""; TR.UI.Lbl.SubRarity.Text=""
        TR.UI.Lbl.TraitInfo.Text=""; return
    end
    local main, sub = GetUnitTraits(TR.SelectedUnit)
    main = main or "–"; sub = sub or "–"
    TR.UI.Lbl.UnitName.Text="✔ "..TR.SelectedUnit.Name; TR.UI.Lbl.UnitName.TextColor3=D.Cyan
    TR.UI.Lbl.MainTrait.Text=main
    TR.UI.Lbl.SubTrait.Text=sub
    -- Rarity & Farbe
    local function ApplyRarity(lbl, rarLbl, traitName)
        local td = AllTraits[traitName]
        if td and td.Rarity then
            local col = GetRarityColor(td.Rarity)
            lbl.TextColor3 = col; rarLbl.Text = "["..td.Rarity.."]"; rarLbl.TextColor3 = col
        else
            lbl.TextColor3 = D.TextHi; rarLbl.Text = ""
        end
    end
    ApplyRarity(TR.UI.Lbl.MainTrait, TR.UI.Lbl.MainRarity, main)
    ApplyRarity(TR.UI.Lbl.SubTrait,  TR.UI.Lbl.SubRarity,  sub)
    -- Stats Info
    local infoLines = {}
    for _, tn in ipairs({main, sub}) do
        local td = AllTraits[tn]
        if td and td.Stats then
            local statStrs = {}
            for stat, val in pairs(td.Stats) do
                local sign = val >= 0 and "+" or ""
                table.insert(statStrs, sign..val.."% "..stat)
            end
            if #statStrs > 0 then
                table.insert(infoLines, tn..": "..table.concat(statStrs, ", "))
            end
        end
    end
    TR.UI.Lbl.TraitInfo.Text = #infoLines > 0 and table.concat(infoLines,"\n") or ""
end

-- ── Einheiten scannen ─────────────────────────────────────────
local function ScanUnits()
    TR.Units = {}
    local collection = nil
    pcall(function()
        collection = RS:WaitForChild("Player_Data",10):WaitForChild(LP.Name,10):WaitForChild("Collection",5)
    end)
    if not collection then
        SetStatus("⚠ Collection nicht gefunden!",D.Orange); return false
    end
    local nameCount = {}
    for _, unit in pairs(collection:GetChildren()) do
        if unit:IsA("Folder") or unit:IsA("Model") or unit:IsA("Configuration") or unit:IsA("StringValue") or unit:IsA("IntValue") then
            local n = unit.Name
            nameCount[n] = (nameCount[n] or 0) + 1
        end
    end
    local nameSeen = {}
    for _, unit in pairs(collection:GetChildren()) do
        if unit:IsA("Folder") or unit:IsA("Model") or unit:IsA("Configuration") or unit:IsA("StringValue") or unit:IsA("IntValue") then
            local n = unit.Name
            nameSeen[n] = (nameSeen[n] or 0) + 1
            local displayName = n
            if nameCount[n] > 1 then
                displayName = n.." #"..nameSeen[n]
            end
            table.insert(TR.Units, { instance=unit, name=n, index=nameSeen[n], displayName=displayName })
        end
    end
    table.sort(TR.Units, function(a,b) return a.displayName:lower() < b.displayName:lower() end)
    SetStatus("✅ "..#TR.Units.." Einheiten gefunden", D.Green)
    return true
end

local function BuildUnitList(filter)
    for _,v in pairs(TR.UI.Fr.UnitList:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    filter = (filter or ""):lower()
    local shown = 0
    for _, u in ipairs(TR.Units) do
        if filter ~= "" and not u.displayName:lower():find(filter,1,true) then continue end
        shown = shown + 1
        local isSelected = (TR.SelectedUnit == u.instance)
        local row = Instance.new("Frame",TR.UI.Fr.UnitList)
        row.Size = UDim2.new(1,0,0,34); row.BorderSizePixel=0; Corner(row,7)
        if isSelected then row.BackgroundColor3=Color3.fromRGB(0,30,60); Stroke(row,D.Cyan,1.5,0)
        else row.BackgroundColor3=D.CardHover; Stroke(row,D.Border,1,0.4) end
        local bar=Instance.new("Frame",row); bar.Size=UDim2.new(0,3,0.6,0); bar.Position=UDim2.new(0,0,0.2,0); bar.BackgroundColor3=isSelected and D.Cyan or D.Border; bar.BorderSizePixel=0; Corner(bar,2)
        -- Traits lesen für Mini-Anzeige
        local main,sub = GetUnitTraits(u.instance)
        local mainColor = main and AllTraits[main] and GetRarityColor(AllTraits[main].Rarity) or D.TextLow
        local nL=Instance.new("TextLabel",row); nL.Position=UDim2.new(0,10,0,2); nL.Size=UDim2.new(1,-12,0,14); nL.BackgroundTransparency=1
        nL.Text=u.displayName; nL.TextColor3=isSelected and D.Cyan or D.TextHi; nL.TextSize=11; nL.Font=Enum.Font.GothamBold; nL.TextXAlignment=Enum.TextXAlignment.Left; nL.TextTruncate=Enum.TextTruncate.AtEnd
        local tL=Instance.new("TextLabel",row); tL.Position=UDim2.new(0,10,0,17); tL.Size=UDim2.new(1,-12,0,13); tL.BackgroundTransparency=1
        local tStr = (main or "?").." / "..(sub or "?")
        tL.Text=tStr; tL.TextColor3=mainColor; tL.TextSize=9; tL.Font=Enum.Font.GothamSemibold; tL.TextXAlignment=Enum.TextXAlignment.Left; tL.TextTruncate=Enum.TextTruncate.AtEnd
        local clickBtn=Instance.new("TextButton",row); clickBtn.Size=UDim2.new(1,0,1,0); clickBtn.BackgroundTransparency=1; clickBtn.Text=""; clickBtn.BorderSizePixel=0
        local capU = u
        clickBtn.MouseButton1Click:Connect(function()
            TR.SelectedUnit = capU.instance
            BuildUnitList(filter)
            UpdateLiveTraitDisplay()
        end)
        clickBtn.MouseEnter:Connect(function() if TR.SelectedUnit~=capU.instance then Tw(row,{BackgroundColor3=Color3.fromRGB(30,40,65)}) end end)
        clickBtn.MouseLeave:Connect(function() if TR.SelectedUnit~=capU.instance then Tw(row,{BackgroundColor3=D.CardHover}) end end)
    end
    TR.UI.Lbl.UnitEmpty.Visible = (shown==0)
end

