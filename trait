local function AutoStatRerollLoop()
    TR.StatRolling = true; TR.StatRollCount = 0
    TR.UI.Btn.StartStat.Text       = "⏳ Rollt..."
    TR.UI.Btn.StartStat.TextColor3 = D.Yellow
    Stroke(TR.UI.Btn.StartStat, D.Yellow, 2, 0.15)
    SetStatus("🎯 Auto-Stat-Reroll läuft...", D.Gold)
    print(string.format("[HazeHub-Trait] AutoStatRerollLoop v%s | unit=%s | statMode=%s | targets=%s",
        VERSION,
        tostring(TR.SelectedUnit and TR.SelectedUnit.Name),
        tostring(TR.SelectedStatMode),
        table.concat((function() local t = {}; for r in pairs(TR.TargetStatRatings) do table.insert(t, r) end; return t end)(), ",")))

    local t0 = os.clock()
    while TR.StatRolling do
        if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!", D.Orange); break end
        -- ★ Multi-Rating-Check: stoppe sobald EIN Stat-Rating in der Zielmenge liegt
        local reached, bestStatName, bestRank = StatGoalReachedMulti()
        if reached then
            SetStatus("✅ Zielrating erreicht: " .. tostring(bestRank) .. " (" .. tostring(bestStatName) .. ")", D.GreenBright)
            pcall(RefreshStatPanel)
            if RankAtLeast(bestRank, "S+") then
                SendStatSuccessWebhook(bestStatName, bestRank)
            end
            break
        end
        if not HasAnyStatKeyForMode() then SetStatus("⛔ Keys leer. Stop.", D.Orange); break end
        task.wait(0.1)
        local ok = DoSingleStatReroll()
        if not ok then SetStatus("❌ Stat-Reroll fehlgeschlagen.", D.Red); break end
        local dt = os.clock() - t0
        if dt > 0 and TR.UI.Lbl.StatRollRate then
            TR.UI.Lbl.StatRollRate.Text = string.format("%.1f r/min", TR.StatRollCount / dt * 60)
        end
        task.wait(math.max(0.15, tonumber(delayBox.Text) or 0.5))
        pcall(RefreshStatPanel)
    end
    TR.StatRolling = false
    TR.UI.Btn.StartStat.Text       = "▶  Start Stat-Reroll"
    TR.UI.Btn.StartStat.TextColor3 = D.GreenBright
    Stroke(TR.UI.Btn.StartStat, D.Green, 1.5, 0.3)
