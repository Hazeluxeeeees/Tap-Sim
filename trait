local RATING_TIER_COLORS = {
    ["C-"]="C"; ["C"]="C"; ["C+"]="C";
    ["B-"]="B"; ["B"]="B"; ["B+"]="B";
    ["A-"]="A"; ["A"]="A"; ["A+"]="A";
    ["S-"]="S"; ["S"]="S"; ["S+"]="S";
    ["SS"]="SS"; ["SSS"]="SS";
    ["O-"]="O"; ["O"]="O"; ["O+"]="O";
}
local TIER_COLORS = {
    C  = Color3.fromRGB(160, 160, 160),
    B  = Color3.fromRGB(50,  200,  80),
    A  = Color3.fromRGB(50,  120, 255),
    S  = Color3.fromRGB(200, 130, 255),
    SS = Color3.fromRGB(255, 180,   0),
    O  = Color3.fromRGB(255,  60,  60),
}
local function GetRatingColor(rating)
    local tier = RATING_TIER_COLORS[rating] or "C"
    return TIER_COLORS[tier] or D.TextMid
end

