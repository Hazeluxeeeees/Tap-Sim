local function ResolveStatRerollRemote()
    local rr=nil
    pcall(function()
        local g=RS:WaitForChild("Remote",5):WaitForChild("Server",5):WaitForChild("Gambling",5)
        rr=g:WaitForChild("RerollPotential",5)
    end)
    if rr then return rr end
    pcall(function()
        local g=RS:WaitForChild("Remote",5):WaitForChild("Server",5):WaitForChild("Gambling",5)
        for _,n in ipairs({"RerollPotential","RerollStat","RerollStats","PotentialReroll"}) do
            local r=g:FindFirstChild(n); if r then rr=r; break end
        end
    end)
    return rr
end

local function GetItemAmount(itemName)
    local n=0
    pcall(function()
        local items=RS:WaitForChild("Player_Data",3):WaitForChild(LP.Name,3):WaitForChild("Items",3)
        local it=items:FindFirstChild(itemName); if not it then return end
        local a=it:FindFirstChild("Amount") or it:FindFirstChild("Value")
        n=tonumber(a and a.Value or it.Value) or 0
    end)
    return n
end

