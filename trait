local function RebuildMultiStatUI()
    for _, entry in pairs(TR.UI.Btn.StatTargetRows) do
        if entry.frame and entry.frame.Parent then entry.frame:Destroy() end
    end
    TR.UI.Btn.StatTargetRows = {}

    for _, statName in ipairs(STAT_POTENTIAL_NAMES) do
        local displayName   = STAT_DISPLAY_NAMES[statName] or statName
        local currentTarget = TR.StatTargetRatings[statName]
        local isActive      = currentTarget ~= nil

        local statRowFrame = Instance.new("Frame", statsCard)
        statRowFrame.Size                  = UDim2.new(1, 0, 0, 0)
        statRowFrame.AutomaticSize         = Enum.AutomaticSize.Y
        statRowFrame.BackgroundTransparency = 1
        VList(statRowFrame, 3)

        local hRow = Instance.new("Frame", statRowFrame)
        hRow.Size                  = UDim2.new(1, 0, 0, 24)
        hRow.BackgroundColor3      = isActive and Color3.fromRGB(14, 42, 28) or D.CardHover
        hRow.BackgroundTransparency = 0.2
        hRow.BorderSizePixel       = 0
        Corner(hRow, 6)
        Stroke(hRow, isActive and D.Green or D.Border, 1, isActive and 0 or 0.5)

        local toggleBtn = Instance.new("TextButton", hRow)
        toggleBtn.Size                  = UDim2.new(0, 18, 0, 18)
        toggleBtn.Position              = UDim2.new(0, 3, 0.5, -9)
        toggleBtn.BackgroundColor3      = isActive and D.Green or D.CardHover
        toggleBtn.BackgroundTransparency = isActive and 0.1 or 0.5
        toggleBtn.Text                  = isActive and "✓" or ""
        toggleBtn.TextColor3            = Color3.new(1, 1, 1)
        toggleBtn.TextSize              = 10
        toggleBtn.Font                  = Enum.Font.GothamBold
        toggleBtn.AutoButtonColor       = false
        toggleBtn.BorderSizePixel       = 0
        Corner(toggleBtn, 4)
        Stroke(toggleBtn, isActive and D.Green or D.Border, 1, isActive and 0 or 0.5)

        local statNameLbl = Instance.new("TextLabel", hRow)
        statNameLbl.Position               = UDim2.new(0, 26, 0, 0)
        statNameLbl.Size                   = UDim2.new(0.45, -26, 1, 0)
        statNameLbl.BackgroundTransparency = 1
        statNameLbl.Text                   = displayName
        statNameLbl.TextColor3             = isActive and D.GreenBright or D.TextMid
        statNameLbl.TextSize               = 11
        statNameLbl.Font                   = Enum.Font.GothamBold
        statNameLbl.TextXAlignment         = Enum.TextXAlignment.Left

        local targetLbl = Instance.new("TextLabel", hRow)
        targetLbl.Position               = UDim2.new(0.45, 0, 0, 0)
        targetLbl.Size                   = UDim2.new(0.55, -4, 1, 0)
        targetLbl.BackgroundTransparency = 1
        -- FIX #2: Ziel-Label zeigt >= um den >= Vergleich klar zu kommunizieren
        targetLbl.Text                   = currentTarget and ("≥ " .. currentTarget) or "kein Ziel"
        targetLbl.TextColor3             = currentTarget and GetRatingColor(currentTarget) or D.TextLow
        targetLbl.TextSize               = 11
        targetLbl.Font                   = Enum.Font.GothamBold
        targetLbl.TextXAlignment         = Enum.TextXAlignment.Right

        local ratingPickerFrame = Instance.new("Frame", statRowFrame)
        ratingPickerFrame.Size                  = UDim2.new(1, 0, 0, 0)
        ratingPickerFrame.AutomaticSize         = Enum.AutomaticSize.Y
        ratingPickerFrame.BackgroundTransparency = 1
        ratingPickerFrame.Visible               = isActive

        local ratingGrid = Instance.new("UIGridLayout", ratingPickerFrame)
        ratingGrid.CellSize    = UDim2.new(0.25, -3, 0, 20)
        ratingGrid.CellPadding = UDim2.new(0, 3, 0, 3)

        for _, rating in ipairs(ALL_RATINGS) do
            local col = GetRatingColor(rating)
            local isThisTarget = currentTarget == rating
            local rBtn = Instance.new("TextButton", ratingPickerFrame)
            rBtn.BackgroundColor3      = isThisTarget and col or D.CardHover
            rBtn.BackgroundTransparency = isThisTarget and 0.15 or 0.55
            rBtn.BorderSizePixel       = 0
            Corner(rBtn, 4)
            Stroke(rBtn, isThisTarget and col or D.Border, 1, isThisTarget and 0 or 0.6)
            rBtn.Text            = rating
            rBtn.TextColor3      = isThisTarget and col or D.TextMid
            rBtn.TextSize        = 9
            rBtn.Font            = Enum.Font.GothamBold
            rBtn.AutoButtonColor = false

            local capStatName = statName
            local capRating   = rating
            rBtn.MouseButton1Click:Connect(function()
                TR.StatTargetRatings[capStatName] = capRating
                RebuildMultiStatUI()
            end)
        end

        local capStatName = statName
        toggleBtn.MouseButton1Click:Connect(function()
            if TR.StatTargetRatings[capStatName] then
                TR.StatTargetRatings[capStatName] = nil
            else
                TR.StatTargetRatings[capStatName] = "S"
            end
            RebuildMultiStatUI()
        end)

        TR.UI.Btn.StatTargetRows[statName] = {
            frame     = statRowFrame,
            targetLbl = targetLbl,
            toggleBtn = toggleBtn,
        }
    end

    local activeCount = 0
    local parts = {}
    for _, sn in ipairs(STAT_POTENTIAL_NAMES) do
        if TR.StatTargetRatings[sn] then
            activeCount = activeCount + 1
            -- FIX #2: >= Symbol in der Zusammenfassung
            table.insert(parts, (STAT_DISPLAY_NAMES[sn] or sn) .. "≥" .. TR.StatTargetRatings[sn])
        end
    end
    if TR.UI.Lbl.MultiStatSummary then
        if activeCount == 0 then
            TR.UI.Lbl.MultiStatSummary.Text       = "Kein Stat-Ziel aktiv → kein Auto-Stop"
            TR.UI.Lbl.MultiStatSummary.TextColor3 = D.TextLow
        else
            TR.UI.Lbl.MultiStatSummary.Text       = "Ziel (≥): " .. table.concat(parts, "  &  ")
            TR.UI.Lbl.MultiStatSummary.TextColor3 = D.Cyan
        end
    end
end

