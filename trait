-- Prüfe ob Ziel-Trait erreicht
local function CheckGoalReached()
    if not TR.SelectedUnit then return false end
    local main, sub = GetUnitTraits(TR.SelectedUnit)
    if TR.StopOnMain and main then
        if TR.TargetMain[main] then
            SetStatus("🎉 MAIN-ZIEL '"..main.."' ERREICHT! Gestoppt.", D.GreenBright)
            return true
        end
    end
    if TR.StopOnSub and sub then
        if TR.TargetSub[sub] then
            SetStatus("🎉 SUB-ZIEL '"..sub.."' ERREICHT! Gestoppt.", D.GreenBright)
            return true
        end
    end
    return false
end

local function DoSingleReroll(mode)
    mode = mode or "Main"
    if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!",D.Orange); return false end
    if not RerollRemote then SetStatus("⚠ RerollTrait Remote nicht gefunden!",D.Orange); return false end
    local currency = TR.SelectedCurrency or "Shards"
    -- FireServer(UnitInstance, "Reroll", "Main"/"Sub", "Shards", {"", ""})
    local ok = pcall(function()
        RerollRemote:FireServer(TR.SelectedUnit, "Reroll", mode, currency, {"",""})
    end)
    if ok then
        -- Bestätigung senden
        pcall(function()
            if TraitAckRemote then TraitAckRemote:FireServer() end
        end)
        TR.RollCount = TR.RollCount + 1
        pcall(function() TR.UI.Lbl.RollCount.Text = "Rolls: "..TR.RollCount end)
    end
    return ok
end

