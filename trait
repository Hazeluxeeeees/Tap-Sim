function HS.GetItemObjectTextures(itemOrName)
    local inst = itemOrName
    if typeof(itemOrName) == "string" then
        inst = nil
        pcall(function()
            local items = RS:WaitForChild("Player_Data", 5):WaitForChild(LP.Name, 5):WaitForChild("Items", 5)
            inst = items:FindFirstChild(itemOrName)
        end)
    end
    if not inst then return nil, nil end
    local o = inst:FindFirstChild("Objects")
    if not o then return nil, nil end
    local function readTex(x)
        if not x then return nil end
        if x:IsA("StringValue") or x:IsA("IntValue") then return tostring(x.Value) end
        if x:IsA("ImageLabel") or x:IsA("ImageButton") then return x.Image end
        for _, ch in ipairs(x:GetChildren()) do
            if ch:IsA("StringValue") and (ch.Name:lower() == "texture" or ch.Name:lower() == "image" or ch.Name:lower() == "id") then return tostring(ch.Value) end
        end
        local dec = x:FindFirstChildWhichIsA("Decal", true)
        if dec then return dec.Texture end
        return nil
    end
    return readTex(o:FindFirstChild("Front")), readTex(o:FindFirstChild("Back"))
end

