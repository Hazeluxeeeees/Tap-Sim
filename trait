--  LOGIK – CheckAllStatGoals
--  FIX #1: Nutzt GradeIndex für sicheren Vergleich
--  FIX #2: Bevorzugt GUI-Label (fresher), Fallback DataModel
-- ╚══════════════════════════════════════════════════════════╝
local function CheckAllStatGoals()
    if not TR.SelectedUnit then return false, {} end
    local hasAnyTarget=false
    for _ in pairs(TR.StatTargetRatings) do hasAnyTarget=true; break end
    if not hasAnyTarget then return false, {} end
    local ratings=GetStatRatings(TR.SelectedUnit)
    local allMet=true; local details={}
    for statName,targetRating in pairs(TR.StatTargetRatings) do
        local labelRating=ReadStatFromLabel(statName)
        local modelRating=ratings[statName] and ratings[statName].rating or "C-"
        -- FIX: Nimm den Wert mit höherem Index (konservativ)
        local li=GradeIndex(labelRating or "C-")
        local mi=GradeIndex(modelRating)
        local currentRating=(li>0 and li>=mi) and (labelRating or modelRating) or modelRating
        -- FIX #1: GradeIndex-Vergleich (nicht StatValues-Map)
        local ci=GradeIndex(currentRating)
        local ti=GradeIndex(ToRankString(targetRating))
        local met=(ci>0 and ti>0 and ci>=ti)
        details[statName]={current=currentRating,target=targetRating,met=met,ci=ci,ti=ti}
        if not met then allMet=false end
    end
    return allMet,details
end

