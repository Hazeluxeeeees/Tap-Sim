local function BuildTraitOverview(filter)
    for _, v in pairs(trListFrame:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    filter = (filter or ""):lower()
    local sorted = {}
    for name, data in pairs(AllTraits) do
        if filter == "" or name:lower():find(filter, 1, true) then table.insert(sorted, { name = name, data = data }) end
    end
    table.sort(sorted, function(a, b)
        local rarOrder = { Mythic = 1, Legendary = 2, Epic = 3, Rare = 4, Uncommon = 5, Common = 6 }
        local ra = rarOrder[(a.data and a.data.Rarity) or "Common"] or 99
        local rb = rarOrder[(b.data and b.data.Rarity) or "Common"] or 99
        if ra ~= rb then return ra < rb end
        return a.name:lower() < b.name:lower()
    end)
    for _, entry in ipairs(sorted) do
        local td = entry.data; local col = GetRarityColor(td and td.Rarity)
        local row = Instance.new("Frame", trListFrame); row.Size = UDim2.new(1, 0, 0, 0); row.AutomaticSize = Enum.AutomaticSize.Y; row.BorderSizePixel = 0; Corner(row, 7)
        row.BackgroundColor3 = D.Card; Stroke(row, col, 1, 0.5)
        local inner = Instance.new("Frame", row); inner.Size = UDim2.new(1, 0, 1, 0); inner.BackgroundTransparency = 1; Pad(inner, 5, 8, 5, 8)
        local acBar = Instance.new("Frame", row); acBar.Size = UDim2.new(0, 3, 1, 0); acBar.BackgroundColor3 = col; acBar.BorderSizePixel = 0; Corner(acBar, 2)
        local nL = Instance.new("TextLabel", inner); nL.Size = UDim2.new(0.65, 0, 0, 18); nL.BackgroundTransparency = 1; nL.Text = entry.name; nL.TextColor3 = col; nL.TextSize = 16; nL.Font = Enum.Font.GothamBold; nL.TextScaled = false; nL.RichText = true; nL.TextStrokeTransparency = 1; nL.TextXAlignment = Enum.TextXAlignment.Left
        local rL = Instance.new("TextLabel", inner); rL.Position = UDim2.new(0.65, 0, 0, 0); rL.Size = UDim2.new(0.35, 0, 0, 18); rL.BackgroundTransparency = 1; rL.Text = (td and td.Rarity) or ""; rL.TextColor3 = col; rL.TextSize = 14; rL.Font = Enum.Font.GothamMedium; rL.TextScaled = false; rL.RichText = true; rL.TextStrokeTransparency = 1; rL.TextXAlignment = Enum.TextXAlignment.Right
        if td and td.Description then
            local dL = Instance.new("TextLabel", inner); dL.Size = UDim2.new(1, 0, 0, 16); dL.Position = UDim2.new(0, 0, 0, 20); dL.BackgroundTransparency = 1; dL.Text = td.Description; dL.TextColor3 = D.TextLow; dL.TextSize = 14; dL.Font = Enum.Font.GothamMedium; dL.TextScaled = false; dL.RichText = true; dL.TextStrokeTransparency = 1; dL.TextXAlignment = Enum.TextXAlignment.Left; dL.TextWrapped = true
        end
        if td and td.Stats then
            local statParts = {}
            for stat, val in pairs(td.Stats) do
                local sign = val >= 0 and "+" or ""; table.insert(statParts, sign .. val .. "% " .. stat)
            end
            if #statParts > 0 then
                local sL = Instance.new("TextLabel", inner); sL.Size = UDim2.new(1, 0, 0, 16); sL.Position = UDim2.new(0, 0, 0, td and td.Description and 38 or 20); sL.BackgroundTransparency = 1; sL.Text = table.concat(statParts, ", "); sL.TextColor3 = col; sL.TextSize = 14; sL.Font = Enum.Font.GothamBold; sL.TextScaled = false; sL.RichText = true; sL.TextStrokeTransparency = 1; sL.TextXAlignment = Enum.TextXAlignment.Left; sL.TextWrapped = true
            end
        end
    end
    if #sorted == 0 then
        local eL = MkLbl(trListFrame, "Keine Traits gefunden.", 11, D.TextLow); eL.Size = UDim2.new(1, 0, 0, 26); eL.TextXAlignment = Enum.TextXAlignment.Center
    end
end

