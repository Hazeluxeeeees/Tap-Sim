local function GetUnitTraits(unitInstance)
    local main, sub = nil, nil
    pcall(function()
        local tf = unitInstance:FindFirstChild("Traits") or unitInstance:FindFirstChild("Trait")
        if tf then
            local pm = tf:FindFirstChild("PrimaryTrait")   or tf:FindFirstChild("Primary")
            local ps = tf:FindFirstChild("SecondaryTrait") or tf:FindFirstChild("Secondary") or tf:FindFirstChild("SubTrait")
            if pm then main = tostring(pm.Value) end
            if ps then sub  = tostring(ps.Value) end
        else
            local pm = unitInstance:FindFirstChild("PrimaryTrait")   or unitInstance:FindFirstChild("Primary")
            local ps = unitInstance:FindFirstChild("SecondaryTrait") or unitInstance:FindFirstChild("Secondary")
            if pm then main = tostring(pm.Value) end
            if ps then sub  = tostring(ps.Value) end
        end
    end)
    return main, sub
end

local function GetPotentialObject(unitInstance, statName)
    if not unitInstance then return nil end
    local direct = unitInstance:FindFirstChild(statName)
    if direct then return direct end
    local stats = unitInstance:FindFirstChild("Stats")
    if stats and stats:FindFirstChild(statName) then return stats:FindFirstChild(statName) end
    local pot = unitInstance:FindFirstChild("Potentials")
    if pot and pot:FindFirstChild(statName) then return pot:FindFirstChild(statName) end
    return unitInstance:FindFirstChild(statName, true)
end

local function GetStatRatings(unitInstance)
    local out = {}
    for _, statName in ipairs(STAT_POTENTIAL_NAMES) do
        local obj    = GetPotentialObject(unitInstance, statName)
        local raw    = obj and obj.Value or nil
        out[statName] = { raw = raw, rating = ToRankString(raw), obj = obj }
    end
    return out
end

-- ★ Tag aus Collection[LP.Name][UnitName].Tag.Value
local function GetUnitTagValue(unitName)
    local uName = unitName and tostring(unitName) or nil
    if not uName or uName == "" then return nil end
    local ok, tagValue = pcall(function()
        local playerData  = RS:WaitForChild("Player_Data", 10)
        local accountFolder = playerData:WaitForChild(LP.Name, 10)
        local collection  = accountFolder:WaitForChild("Collection", 5)
        local unitFolder  = collection:FindFirstChild(uName)
        if not unitFolder then
            for _, ch in ipairs(collection:GetChildren()) do
                if string.lower(ch.Name) == string.lower(uName) then
                    unitFolder = ch; break
                end
            end
        end
        if not unitFolder then return nil end
        local tagObj = unitFolder:FindFirstChild("Tag") or unitFolder:FindFirstChild("Tags")
        if not tagObj then return nil end
        local vObj = tagObj:FindFirstChild("Value")
        if vObj then return vObj.Value end
        if tagObj.Value ~= nil then return tagObj.Value end
        return nil
    end)
    if not ok then return nil end
    return tagValue
end

local function UpdateLiveTraitDisplay()
    if not TR.SelectedUnit then
        TR.UI.Lbl.UnitName.Text       = "Keine Einheit gewählt"
        TR.UI.Lbl.UnitName.TextColor3 = D.TextLow
        TR.UI.Lbl.MainTrait.Text      = "–"
        TR.UI.Lbl.MainTrait.TextColor3 = D.TextLow
        TR.UI.Lbl.SubTrait.Text       = "–"
        TR.UI.Lbl.SubTrait.TextColor3 = D.TextLow
        TR.UI.Lbl.MainRarity.Text     = ""
        TR.UI.Lbl.SubRarity.Text      = ""
        TR.UI.Lbl.TraitInfo.Text      = ""
        return
    end
    local main, sub = GetUnitTraits(TR.SelectedUnit)
    main = main or "–"; sub = sub or "–"
    TR.UI.Lbl.UnitName.Text = "✔ " .. (TR.SelectedUnitName or TR.SelectedUnit.Name)
    TR.UI.Lbl.UnitName.TextColor3 = D.Cyan
    TR.UI.Lbl.MainTrait.Text      = main
    TR.UI.Lbl.SubTrait.Text       = sub
    local function ApplyRarity(lbl, rarLbl, traitName)
        local td = AllTraits[traitName]
        if td and td.Rarity then
            local col = GetRarityColor(td.Rarity)
            lbl.TextColor3    = col
            rarLbl.Text       = "[" .. td.Rarity .. "]"
            rarLbl.TextColor3 = col
        else
            lbl.TextColor3 = D.TextHi
            rarLbl.Text    = ""
        end
    end
    ApplyRarity(TR.UI.Lbl.MainTrait, TR.UI.Lbl.MainRarity, main)
    ApplyRarity(TR.UI.Lbl.SubTrait,  TR.UI.Lbl.SubRarity,  sub)
    local infoLines = {}
    for _, tn in ipairs({ main, sub }) do
        local td = AllTraits[tn]
        if td and td.Stats then
            local statStrs = {}
            for stat, val in pairs(td.Stats) do
                local sign = val >= 0 and "+" or ""
                table.insert(statStrs, sign .. val .. "% " .. stat)
            end
            if #statStrs > 0 then
                table.insert(infoLines, tn .. ": " .. table.concat(statStrs, ", "))
            end
        end
    end
    TR.UI.Lbl.TraitInfo.Text = #infoLines > 0 and table.concat(infoLines, "\n") or ""
end

local function LooksLikeUnitInstance(obj)
    if not obj then return false end
    local tf = obj:FindFirstChild("Traits") or obj:FindFirstChild("Trait")
    if tf then
        if tf:FindFirstChild("PrimaryTrait") or tf:FindFirstChild("Primary") then return true end
        if tf:FindFirstChild("SecondaryTrait") or tf:FindFirstChild("Secondary") or tf:FindFirstChild("SubTrait") then return true end
    end
    if obj:FindFirstChild("PrimaryTrait")   or obj:FindFirstChild("Primary")   then return true end
    if obj:FindFirstChild("SecondaryTrait") or obj:FindFirstChild("Secondary") or obj:FindFirstChild("SubTrait") then return true end
    return false
end

local function GetCollection()
    local collection = nil
    pcall(function()
        collection = RS:WaitForChild("Player_Data", 10)
                        :WaitForChild(LP.Name, 10)
                        :WaitForChild("Collection", 5)
    end)
    return collection
end

local function ScanUnits()
    TR.Units = {}
    local collection = GetCollection()
    if not collection then SetStatus("⚠ Collection nicht gefunden!", D.Orange); return false end
    local sourceList = {}
    for _, unit in pairs(collection:GetChildren()) do
        if (unit:IsA("Folder") or unit:IsA("Model") or unit:IsA("Configuration"))
            and (LooksLikeUnitInstance(unit) or unit:FindFirstChild("Tag")) then
            table.insert(sourceList, { instance = unit, name = unit.Name })
        end
    end
    SetStatus("✅ " .. #sourceList .. " Einheiten gefunden", D.Green)
    local nameCount, nameSeen = {}, {}
    for _, entry in ipairs(sourceList) do nameCount[entry.name] = (nameCount[entry.name] or 0) + 1 end
    for _, entry in ipairs(sourceList) do
        local n = entry.name
        nameSeen[n] = (nameSeen[n] or 0) + 1
        local displayName = n
        if nameCount[n] > 1 then displayName = n .. " #" .. nameSeen[n] end
        table.insert(TR.Units, { instance = entry.instance, name = n, index = nameSeen[n], displayName = displayName })
    end
    table.sort(TR.Units, function(a, b) return a.displayName:lower() < b.displayName:lower() end)
    return #TR.Units > 0
end

-- ── Unit-Model-Viewer ─────────────────────────────────────────
local UnitModelsRoot = nil
local BucketModelIndex = { Unit = {}, Shiny = {}, Evo = {} }

local function NormalizeUnitKey(unitName)
    local key = tostring(unitName or ""):lower()
    return key:gsub(":shiny", ""):gsub(":evo", ""):gsub("%s+$", ""):gsub("^%s+", "")
end
local function ResolveTemplateBucket(unitName)
    local n = tostring(unitName or ""):lower()
    if n:find(":shiny", 1, true) then return "Shiny" end
    if n:find(":evo",   1, true) then return "Evo"   end
    return "Unit"
end
local function BuildBucketModelIndex()
    BucketModelIndex = { Unit = {}, Shiny = {}, Evo = {} }
    UnitModelsRoot = nil
    pcall(function() UnitModelsRoot = RS:WaitForChild("Assets", 8):WaitForChild("UnitModels", 8) end)
    if not UnitModelsRoot then return end
    for _, bucket in ipairs({ "Unit", "Shiny", "Evo" }) do
        local folder = UnitModelsRoot:FindFirstChild(bucket)
        if folder then
            for _, entry in ipairs(folder:GetDescendants()) do
                if entry:IsA("Model") then BucketModelIndex[bucket][entry.Name:lower()] = entry end
            end
        end
    end
end
local function BucketSearchOrder(preferred)
    if preferred == "Shiny" then return { "Shiny", "Unit" } end
    if preferred == "Evo"   then return { "Evo",   "Unit" } end
    return { "Unit", "Shiny", "Evo" }
end
local function FindUnitTemplate(unitName)
    if not UnitModelsRoot then BuildBucketModelIndex() end
    local key = NormalizeUnitKey(unitName)
    if key == "" then return nil end
    for _, bucket in ipairs(BucketSearchOrder(ResolveTemplateBucket(unitName))) do
        local idx = BucketModelIndex[bucket]
        if idx then
            local exact = idx[key]
            if exact then return exact end
            for n, mdl in pairs(idx) do
                if n:find(key, 1, true) or key:find(n, 1, true) then return mdl end
            end
        end
    end
    return nil
end

local CAM_DIST = 5.5
local function FillViewportWithUnit(vp, unitName)
    local ok = false
    pcall(function()
        for _, d in ipairs(vp:GetDescendants()) do
            if d:IsA("WorldModel") or d:IsA("Camera") then d:Destroy() end
        end
        local source = FindUnitTemplate(unitName)
        if not source then return end
        local world = Instance.new("WorldModel"); world.Parent = vp
        local clone = source:Clone(); clone.Parent = world
        if not clone.PrimaryPart then
            local pp0 = clone:FindFirstChildWhichIsA("BasePart", true)
            if pp0 then clone.PrimaryPart = pp0 end
        end
        clone:PivotTo(CFrame.new(0, 0, 0))
        local cam = Instance.new("Camera"); cam.Parent = vp; vp.CurrentCamera = cam
        cam.FieldOfView = 60
        local head       = clone:FindFirstChild("Head",       true)
        local upperTorso = clone:FindFirstChild("UpperTorso", true) or clone:FindFirstChild("Torso", true)
        local pp = clone.PrimaryPart
        if not pp or not pp:IsA("BasePart") then pp = clone:FindFirstChildWhichIsA("BasePart", true) end
        local aim = (head and head:IsA("BasePart") and head)
                 or (upperTorso and upperTorso:IsA("BasePart") and upperTorso)
                 or pp
        if not aim then return end
        local targetPos = aim.Position
        local look      = aim.CFrame.LookVector
        cam.CFrame = CFrame.new(targetPos + look * CAM_DIST + Vector3.new(0, 0.5, 0), targetPos)
        ok = true
    end)
    return ok
end

