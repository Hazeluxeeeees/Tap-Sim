-- ── RebuildTraitTargetList ────────────────────────────────────────────
local function RebuildTraitTargetList(searchFilter)
    for _,v in pairs(traitListFrame:GetChildren()) do
        if v:IsA("Frame") or v:IsA("TextLabel") then v:Destroy() end
    end
    searchFilter=(searchFilter or ""):lower()
    local rarities={"Divine","Mythic","Legendary","Epic","Rare","Uncommon","Common"}
    local function GetRarityOrder(r) for i,v in ipairs(rarities) do if v==r then return i end end; return 99 end
    local sorted={}
    for name,data in pairs(AllTraits) do
        if searchFilter=="" or name:lower():find(searchFilter,1,true) then
            if not ActiveRarityFilter or (data and data.Rarity==ActiveRarityFilter) then
                table.insert(sorted,{name=name,data=data})
            end
        end
    end
    table.sort(sorted,function(a,b)
        local ra=GetRarityOrder(a.data and a.data.Rarity); local rb=GetRarityOrder(b.data and b.data.Rarity)
        if ra~=rb then return ra<rb end; return a.name:lower()<b.name:lower()
    end)
    if #sorted==0 then
        local eL=MkLbl(traitListFrame,"Keine Traits gefunden.",10,D.TextLow); eL.Size=UDim2.new(1,0,0,22)
        task.defer(refreshTraitScrollCanvas); return
    end
    for _,entry in ipairs(sorted) do
        local td=entry.data; local col=GetRarityColor(td and td.Rarity)
        local isChosen=TR.TargetTraits[entry.name]~=nil
        local row=Instance.new("Frame",traitListFrame)
        row.Size=UDim2.new(1,0,0,22); row.BorderSizePixel=0; Corner(row,6)
        row.BackgroundColor3=isChosen and Color3.fromRGB(14,36,22) or D.CardHover
        row.BackgroundTransparency=isChosen and 0.1 or 0.45
        Stroke(row,isChosen and D.GreenBright or col,1,isChosen and 0.1 or 0.5)
        local bar=Instance.new("Frame",row); bar.Size=UDim2.new(0,3,0.7,0)
        bar.Position=UDim2.new(0,0,0.15,0); bar.BackgroundColor3=col; bar.BorderSizePixel=0; Corner(bar,2)
        local nL=Instance.new("TextLabel",row)
        nL.Position=UDim2.new(0,8,0,0); nL.Size=UDim2.new(0.70,-10,1,0); nL.BackgroundTransparency=1
        nL.Text=entry.name; nL.TextColor3=isChosen and D.GreenBright or col
        nL.TextSize=10; nL.Font=Enum.Font.GothamBold; nL.TextXAlignment=Enum.TextXAlignment.Left
        nL.TextTruncate=Enum.TextTruncate.AtEnd
        nL.TextScaled=false; nL.RichText=true; nL.TextStrokeTransparency=1
        local rL=Instance.new("TextLabel",row)
        rL.Position=UDim2.new(0.70,0,0,0); rL.Size=UDim2.new(0.17,-2,1,0); rL.BackgroundTransparency=1
        rL.Text=(td and td.Rarity) and td.Rarity:sub(1,3) or ""
        rL.TextColor3=col; rL.TextSize=9; rL.Font=Enum.Font.GothamMedium
        rL.TextXAlignment=Enum.TextXAlignment.Right
        rL.TextScaled=false; rL.RichText=true; rL.TextStrokeTransparency=1
        local chk=Instance.new("TextLabel",row)
        chk.Position=UDim2.new(0.87,0,0,0); chk.Size=UDim2.new(0.13,-4,1,0); chk.BackgroundTransparency=1
        chk.Text=isChosen and "✓" or ""; chk.TextColor3=D.GreenBright
        chk.TextSize=12; chk.Font=Enum.Font.GothamBold; chk.TextXAlignment=Enum.TextXAlignment.Center
        chk.TextScaled=false; chk.RichText=true; chk.TextStrokeTransparency=1
        local clickBtn=Instance.new("TextButton",row)
        clickBtn.Size=UDim2.new(1,0,1,0); clickBtn.BackgroundTransparency=1; clickBtn.Text=""; clickBtn.BorderSizePixel=0; clickBtn.ZIndex=2
        local capName=entry.name
        clickBtn.MouseButton1Click:Connect(function()
            if TR.TargetTraits[capName] then TR.TargetTraits[capName]=nil
            else TR.TargetTraits[capName]=true end
            UpdateTargetTraitInfo(); RebuildTraitTargetList(traitSearchBox.Text)
        end)
    end
    task.defer(refreshTraitScrollCanvas)
end

