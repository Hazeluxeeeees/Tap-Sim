--  FIX #1 – StatValues Priority Table
--  Einzige Wahrheitsquelle für Stat-Vergleiche im gesamten Modul.
--  Ersetzte das alte STAT_RANK_VALUE vollständig.
-- ╚══════════════════════════════════════════════════════════╝
local StatValues = {
    ["C-"]  = 1,  ["C"]   = 2,  ["C+"]  = 3,
    ["B-"]  = 4,  ["B"]   = 5,  ["B+"]  = 6,
    ["A-"]  = 7,  ["A"]   = 8,  ["A+"]  = 9,
    ["S-"]  = 10, ["S"]   = 11, ["S+"]  = 12,
    ["SS"]  = 13, ["SSS"] = 14,
    ["O-"]  = 15, ["O"]   = 16, ["O+"]  = 17,
}

-- Alias für Rückwärtskompatibilität (falls irgendwo intern referenziert)
local STAT_RANK_VALUE = StatValues

local ALL_RATINGS = {
    "C-", "C", "C+",
    "B-", "B", "B+",
    "A-", "A", "A+",
    "S-", "S", "S+",
    "SS", "SSS",
    "O-", "O", "O+",
}

-- ── Normalisierung eines Roh-Werts zu einem Ratings-String ────
local function ToRankString(v)
    local s = tostring(v or ""):upper():gsub("%s+", ""):gsub("PLUS", "+")
    if StatValues[s] then return s end
    local n = tonumber(v)
    if n then
        if n >= 17 then return "O+"  end
        if n >= 16 then return "O"   end
        if n >= 15 then return "O-"  end
        if n >= 14 then return "SSS" end
        if n >= 13 then return "SS"  end
        if n >= 12 then return "S+"  end
        if n >= 11 then return "S"   end
        if n >= 10 then return "S-"  end
        if n >= 9  then return "A+"  end
        if n >= 8  then return "A"   end
        if n >= 7  then return "A-"  end
        if n >= 6  then return "B+"  end
        if n >= 5  then return "B"   end
        if n >= 4  then return "B-"  end
        if n >= 3  then return "C+"  end
        if n >= 2  then return "C"   end
        return "C-"
    end
    return "C-"
end

-- ╔══════════════════════════════════════════════════════════╗
--  FIX #2 – Stop-Bedingung: >= (größer oder gleich)
--  RankAtLeast(rank, target) → true wenn rank >= target
--  Verwendet StatValues für einen sicheren numerischen Vergleich.
-- ╚══════════════════════════════════════════════════════════╝
local function RankAtLeast(rank, target)
    local rv = StatValues[ToRankString(rank)]   or 1
    local tv = StatValues[ToRankString(target)] or 1
    return rv >= tv  -- >= statt ==: S+ stoppt auch wenn Ziel S war
end

