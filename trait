-- Auto-Reroll Loop
local function AutoRerollLoop()
    TR.Rolling=true; TR.RollCount=0
    local startTime=tick()
    SetStatus("▶ Rerollt...",D.GreenBright)
    Tw(startRerollBtn,{BackgroundColor3=Color3.fromRGB(8,56,28),BackgroundTransparency=0.1})
    startRerollBtn.Text="⏳ Rerollt..."; startRerollBtn.TextColor3=D.Yellow

    while TR.Rolling do
        if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit!",D.Orange); TR.Rolling=false; break end
        pcall(UpdateLiveTraitDisplay); if CheckGoalReached() then TR.Rolling=false; break end
        local ok=DoSingleReroll()
        if not ok then SetStatus("⚠ Remote-Fehler! Warte 1s.",D.Orange); task.wait(1) end
        local delay=math.max(0.15, tonumber(delayBox.Text) or 0.5)
        task.wait(0.1); pcall(UpdateLiveTraitDisplay); if CheckGoalReached() then TR.Rolling=false; break end
        task.wait(delay)
        -- Rate-Anzeige
        local elapsed=tick()-startTime
        if elapsed>0 then
            local rate=TR.RollCount/elapsed*60
            pcall(function()
                TR.UI.Lbl.RollRate.Text=string.format("%.0f Rolls/min | %d total",rate,TR.RollCount)
            end)
        end
    end
    -- Cleanup
    pcall(function()
        startRerollBtn.Text="▶  Start Reroll"; startRerollBtn.TextColor3=D.GreenBright
        Stroke(startRerollBtn,D.Green,1.5,0.25)
        Tw(startRerollBtn,{BackgroundColor3=Color3.fromRGB(14,42,28),BackgroundTransparency=0.18})
    end)
    if not CheckGoalReached() then SetStatus("⏹ Gestoppt. "..TR.RollCount.." Rolls.",D.TextMid) end
end

