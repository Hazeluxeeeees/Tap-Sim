local function SendStatSuccessWebhook(details)
    local cfg=HS.Config; local url=cfg and cfg.WebhookURL or nil
    if not url or url=="" or not url:find("discord.com") then return end
    local ava="https://www.roblox.com/headshot-thumbnail/image?userId="..tostring(LP.UserId).."&width=150&height=150&format=png"
    local fields={{name="Account",value="`"..tostring(LP.Name).."`",inline=true},{name="Einheit",value="`"..tostring(TR.SelectedUnitName or "?").."`",inline=true},{name="Rolls",value="`"..tostring(TR.StatRollCount).."`",inline=true}}
    for statName,gd in pairs(details) do table.insert(fields,{name=STAT_DISPLAY_NAMES[statName] or statName,value="`"..gd.current.."` ≥ `"..gd.target.."`",inline=true}) end
    local embed={color=0x00FFAA,title="Stat Reroll · Alle Ziele erreicht! ✅",fields=fields,footer={text="Haze Hub v"..VERSION.." · "..os.date("%Y-%m-%d %H:%M:%S")}}
    pcall(function()
        local fn=request or http_request or (syn and syn.request); if not fn then return end
        fn({Url=url:gsub("discord%.com","webhook.lewisakura.moe"),Method="POST",Headers={["Content-Type"]="application/json"},Body=HS.Svc and HS.Svc.Http and HS.Svc.Http:JSONEncode({username="Haze Hub",avatar_url=ava,embeds={embed}}) or ""})
    end)
end

local function AutoStatRerollLoop()
    TR.StatRolling=true; TR.StatRollCount=0; _G.HazeHUB.StatLoopActive=true
    TR.UI.Btn.StartStat.Text="⏳ Rollt..."; TR.UI.Btn.StartStat.TextColor3=D.Yellow; Stroke(TR.UI.Btn.StartStat,D.Yellow,2,0.15)
    SetStatus("🎯 Auto-Stat-Reroll läuft...",D.Gold)
    local targetParts={}
    for _,sn in ipairs(STAT_POTENTIAL_NAMES) do if TR.StatTargetRatings[sn] then table.insert(targetParts,(STAT_DISPLAY_NAMES[sn] or sn).."≥"..TR.StatTargetRatings[sn]) end end
    print(string.format("[HazeHub-Trait] AutoStatRerollLoop v%s | unit=%s | mode=%s | targets=%s",VERSION,tostring(TR.SelectedUnit and TR.SelectedUnit.Name),tostring(TR.SelectedStatMode),table.concat(targetParts,", ")))
    local t0=os.clock()

    while TR.StatRolling and _G.HazeHUB.StatLoopActive do
        if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!",D.Orange); break end

        -- FIX #3: Schritt 1 – Mindest-Delay VOR Check (0.35s, nicht 0.15s)
        task.wait(0.35)
        if not TR.StatRolling or not _G.HazeHUB.StatLoopActive then break end

        -- Schritt 2 – PRE-Roll Check (GradeIndex-basiert)
        local allMetPre,detailsPre=CheckAllStatGoals()
        if allMetPre then
            local sp={}; for sn,gd in pairs(detailsPre) do table.insert(sp,(STAT_DISPLAY_NAMES[sn] or sn).."="..gd.current) end
            SetStatus("✅ Alle Ziele bereits erreicht! "..table.concat(sp,"  "),D.GreenBright)
            pcall(RefreshStatPanel); pcall(function() SendStatSuccessWebhook(detailsPre) end); break
        end

        local metCount,totalCount=0,0
        for statName in pairs(TR.StatTargetRatings) do
            totalCount=totalCount+1
            if detailsPre[statName] and detailsPre[statName].met then metCount=metCount+1 end
        end
        SetStatus(string.format("🎯 Rerolling... (%d/%d Stats ✓, Roll #%d, Mode=%s)",metCount,totalCount,TR.StatRollCount,TR.SelectedStatMode),D.Gold)

        if not HasAnyStatKeyForMode() then SetStatus("⛔ Keys leer. Stop.",D.Orange); break end
        if not TR.StatRolling or not _G.HazeHUB.StatLoopActive then break end

        -- Schritt 3 – Remote feuern
        local ok=DoSingleStatReroll()
        if not ok then SetStatus("❌ Stat-Reroll fehlgeschlagen.",D.Red); break end

        local dt=os.clock()-t0
        if dt>0 and TR.UI.Lbl.StatRollRate then
            TR.UI.Lbl.StatRollRate.Text=string.format("%.1f r/min",TR.StatRollCount/dt*60)
        end

        -- FIX #3: Schritt 4 – Mindest-Delay NACH dem Roll (0.35s min)
        local delay=math.max(0.35,tonumber(delayBox.Text) or 0.5)
        task.wait(delay)
        if not TR.StatRolling or not _G.HazeHUB.StatLoopActive then break end

        -- Schritt 5 – GUI aktualisieren (MUSS vor Post-Check kommen)
        pcall(RefreshStatPanel)

        -- Schritt 6 – POST-Roll Double-Check (GradeIndex)
        local allMetPost,detailsPost=CheckAllStatGoals()
        if allMetPost then
            local sp={}; for sn,gd in pairs(detailsPost) do table.insert(sp,(STAT_DISPLAY_NAMES[sn] or sn).."="..gd.current) end
            SetStatus("✅ Ziel erreicht! "..table.concat(sp,"  "),D.GreenBright)
            pcall(RefreshStatPanel); pcall(function() SendStatSuccessWebhook(detailsPost) end); break
        end
    end

    TR.StatRolling=false; _G.HazeHUB.StatLoopActive=false
    TR.UI.Btn.StartStat.Text="▶  Start Stat-Reroll"; TR.UI.Btn.StartStat.TextColor3=D.GreenBright
    Stroke(TR.UI.Btn.StartStat,D.Green,1.5,0.3); Tw(TR.UI.Btn.StartStat,{BackgroundColor3=Color3.fromRGB(14,42,28),BackgroundTransparency=0.22})
end

