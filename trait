    searchFilter = (searchFilter or ""):lower()

    local grouped = {}
    for traitName, data in pairs(AllTraits) do
        local rarity = (data and data.Rarity) or "Common"
        if ActiveRarityFilter and rarity ~= ActiveRarityFilter then continue end
        if searchFilter ~= "" and not traitName:lower():find(searchFilter, 1, true) then continue end
        if not grouped[rarity] then grouped[rarity] = {} end
        table.insert(grouped[rarity], traitName)
    end

    local rarityOrder = { "Divine", "Mythic", "Legendary", "Epic", "Rare", "Uncommon", "Common" }
