-- Trait-Reroll
local function CheckGoalReached()
    if not TR.SelectedUnit then return false end
    local main, sub = GetUnitTraits(TR.SelectedUnit)
    if main and TR.TargetTraits[main] then
        SetStatus("🎉 Ziel-Trait '" .. main .. "' ERREICHT! Gestoppt.", D.GreenBright); return true
    end
    if sub and TR.TargetTraits[sub] then
        SetStatus("🎉 Ziel-Trait '" .. sub .. "' ERREICHT! Gestoppt.", D.GreenBright); return true
    end
    return false
end

local function DoSingleReroll()
    if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!", D.Orange); return false end
    if not RerollRemote    then SetStatus("⚠ RerollTrait Remote nicht gefunden!", D.Orange); return false end
    local curMain, curSub = GetUnitTraits(TR.SelectedUnit)
    curMain = curMain or ""; curSub = curSub or ""
    pcall(function() if TraitAckRemote then TraitAckRemote:FireServer() end end)
    task.wait(0.06)
    local ok = pcall(function()
        RerollRemote:FireServer(TR.SelectedUnit, "Reroll", "Main", TR_SELECTED_CURRENCY, { curMain, curSub })
    end)
    if ok then TR.RollCount = TR.RollCount + 1 end
    return ok
end

local function ResolveStatRerollRemote()
    local rr = nil
    pcall(function()
        local g = RS:WaitForChild("Remote", 5):WaitForChild("Server", 5):WaitForChild("Gambling", 5)
        rr = g:WaitForChild("RerollPotential", 5)
    end)
    if rr then return rr end
    pcall(function()
        local g = RS:WaitForChild("Remote", 5):WaitForChild("Server", 5):WaitForChild("Gambling", 5)
        for _, n in ipairs({ "RerollPotential", "RerollStat", "RerollStats", "PotentialReroll" }) do
            local r = g:FindFirstChild(n)
            if r then rr = r; break end
        end
    end)
    return rr
end

local function GetItemAmount(itemName)
    local n = 0
    pcall(function()
        local items = RS:WaitForChild("Player_Data", 3):WaitForChild(LP.Name, 3):WaitForChild("Items", 3)
        local it = items:FindFirstChild(itemName)
        if not it then return end
        local a = it:FindFirstChild("Amount") or it:FindFirstChild("Value")
        n = tonumber(a and a.Value or it.Value) or 0
    end)
    return n
end

local function GetKeyCountForMode(mode)
    if mode == "All" then return GetItemAmount("Perfect Stats Key") end
    return GetItemAmount("Stats Key")
end
local function HasAnyStatKeyForMode()
    return GetKeyCountForMode(TR.SelectedStatMode) > 0
end

local function DoSingleStatReroll()
    if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!", D.Orange); return false end
    local statRemote = ResolveStatRerollRemote()
    if not statRemote then SetStatus("⚠ RerollPotential Remote nicht gefunden!", D.Orange); return false end
    if not HasAnyStatKeyForMode() then SetStatus("⚠ Keine Keys mehr für den ausgewählten Modus.", D.Orange); return false end
    -- ★ Tag-Fix: Collection[UnitName].Tag.Value als Security-Key
    if TR.SelectedUnitTagValue == nil then
        local tagUnitName = TR.SelectedUnitName or (TR.SelectedUnit and TR.SelectedUnit.Name) or nil
        local tagVal = GetUnitTagValue(tagUnitName)
        if tagVal == nil then
            SetStatus("⏳ TagValue wird aktualisiert...", D.Yellow); task.wait(0.5)
            tagVal = GetUnitTagValue(tagUnitName)
        end
        TR.SelectedUnitTagValue = tagVal
    end
    if TR.SelectedUnitTagValue == nil then
        SetStatus("⚠ TagValue nicht gefunden!", D.Orange); return false
    end
    local ok = pcall(function()
        if TR.SelectedStatMode == "All" then
            statRemote:FireServer("All", TR.SelectedUnitTagValue, "All")
        else
            local sendName = STAT_SEND_NAMES[TR.SelectedStatMode] or TR.SelectedStatMode
            statRemote:FireServer(sendName, TR.SelectedUnitTagValue, "Selective")
        end
    end)
    if ok then TR.StatRollCount = TR.StatRollCount + 1 end
    return ok
end

-- ★ v2.4.0: StatGoalReachedMulti – prüft ALLE Stats gegen alle ausgewählten Ratings
local function StatGoalReachedMulti()
    if not TR.SelectedUnit then return false, nil, nil end
    -- Kein Rating ausgewählt → nie stoppen
    if next(TR.TargetStatRatings) == nil then return false, nil, nil end
    local ratings = GetStatRatings(TR.SelectedUnit)
    for statName, data in pairs(ratings) do
        local rank = data.rating
        if TR.TargetStatRatings[rank] then
            return true, statName, rank
        end
    end
    return false, nil, nil
end

-- RefreshStatPanel
function RefreshStatPanel()
    if not TR.UI.Fr.StatRows then return end
    if not TR.SelectedUnit then
        TR.UI.Lbl.StatHeader.Text       = "Keine Einheit gewählt"
        TR.UI.Lbl.StatHeader.TextColor3 = D.TextLow
        for n, r in pairs(TR.UI.Fr.StatRows) do
            r.nameLbl.Text  = n; r.valLbl.Text = "–"; r.valLbl.TextColor3 = D.TextLow
        end
        return
    end
    TR.UI.Lbl.StatHeader.Text       = "Stat-Scan: " .. TR.SelectedUnit.Name
    TR.UI.Lbl.StatHeader.TextColor3 = D.Cyan
    local ratings = GetStatRatings(TR.SelectedUnit)
    for n, r in pairs(TR.UI.Fr.StatRows) do
        local d       = ratings[n]
        local rating  = d and d.rating or "C-"
        local raw     = d and d.raw    or "-"
        -- ★ Zeile grün highlighten wenn Rating in TargetStatRatings
        local isTarget = TR.TargetStatRatings[rating] == true
        local col = isTarget and D.GreenBright
                  or (RankAtLeast(rating, "S")  and D.Gold
                  or (RankAtLeast(rating, "A")  and D.Yellow
                  or D.TextMid))
        r.nameLbl.Text      = n
        r.valLbl.Text       = tostring(rating) .. "  (" .. tostring(raw) .. ")"
        r.valLbl.TextColor3 = col
        Stroke(r.row, isTarget and D.GreenBright or D.Border, 1, isTarget and 0 or 0.45)
    end
end

