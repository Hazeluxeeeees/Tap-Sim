function RefreshStatPanel()
    if not TR.UI.Fr.StatRows then return end
    if not TR.SelectedUnit then
        TR.UI.Lbl.StatHeader.Text = "Keine Einheit gewählt"; TR.UI.Lbl.StatHeader.TextColor3 = D.TextLow
        for n, r in pairs(TR.UI.Fr.StatRows) do
            r.nameLbl.Text = n; r.valLbl.Text = "–"; r.valLbl.TextColor3 = D.TextLow
        end
        return
    end
    TR.UI.Lbl.StatHeader.Text = "Stat-Scan: " .. TR.SelectedUnit.Name; TR.UI.Lbl.StatHeader.TextColor3 = D.Cyan
    local ratings = GetStatRatings(TR.SelectedUnit)
    for n, r in pairs(TR.UI.Fr.StatRows) do
        local d = ratings[n]
        local rating = d and d.rating or "C"
        local raw = d and d.raw or "-"
        local col = RankAtLeast(rating, "S") and D.GreenBright or (RankAtLeast(rating, "A") and D.Yellow or D.TextMid)
        r.nameLbl.Text = n
        r.valLbl.Text = tostring(rating) .. "  (" .. tostring(raw) .. ")"
        r.valLbl.TextColor3 = col
    end
end

local function AutoStatRerollLoop()
    TR.StatRolling = true
    TR.StatRollCount = 0
    TR.UI.Btn.StartStat.Text = "⏳ Rollt..."; TR.UI.Btn.StartStat.TextColor3 = D.Yellow; Stroke(TR.UI.Btn.StartStat, D.Yellow, 2, 0.15)
    SetStatus("🎯 Auto-Stat-Reroll läuft...", D.Gold)
    local t0 = os.clock()
    while TR.StatRolling do
        if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!", D.Orange); break end
        local reached, bestRank = StatGoalReached()
        if reached then
            SetStatus("✅ Zielrating erreicht: " .. tostring(bestRank), D.GreenBright)
            if RankAtLeast(bestRank, "S") and HS.SendWebhook then pcall(HS.SendWebhook) end
            break
        end
        if not HasAnyStatKey() then SetStatus("⛔ Stats Key leer. Stop.", D.Orange); break end
        local ok = DoSingleStatReroll()
        if not ok then SetStatus("❌ Stat-Reroll fehlgeschlagen.", D.Red); break end
        local dt = os.clock() - t0
        if dt > 0 and TR.UI.Lbl.StatRollRate then
            TR.UI.Lbl.StatRollRate.Text = string.format("%.1f r/min", TR.StatRollCount / dt * 60)
        end
        task.wait(math.max(0.15, tonumber(delayBox.Text) or 0.5))
        pcall(RefreshStatPanel)
    end
    TR.StatRolling = false
    TR.UI.Btn.StartStat.Text = "▶  Start Stat-Reroll"; TR.UI.Btn.StartStat.TextColor3 = D.GreenBright; Stroke(TR.UI.Btn.StartStat, D.Green, 1.5, 0.3)
    Tw(TR.UI.Btn.StartStat, { BackgroundColor3 = Color3.fromRGB(14, 42, 28), BackgroundTransparency = 0.22 })
end

