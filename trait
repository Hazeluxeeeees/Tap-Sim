    if TR.Rolling then SetStatus("⚠ Läuft bereits!",D.Yellow); return end
    if not TR.SelectedUnit then SetStatus("⚠ Keine Einheit gewählt!",D.Orange); return end
    if next(TR.TargetMain)==nil and next(TR.TargetSub)==nil then
        SetStatus("⚠ Keine Ziel-Traits gesetzt!",D.Orange); return
    end
    task.spawn(AutoRerollLoop)
end)
