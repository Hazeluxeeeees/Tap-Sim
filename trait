-- ── STAT_RANK_VALUE ───────────────────────────────────────────
local STAT_RANK_VALUE = {
    ["C-"]  = 0,  ["C"]   = 1,  ["C+"]  = 2,
    ["B-"]  = 3,  ["B"]   = 4,  ["B+"]  = 5,
    ["A-"]  = 6,  ["A"]   = 7,  ["A+"]  = 8,
    ["S-"]  = 9,  ["S"]   = 10, ["S+"]  = 11,
    ["SS"]  = 12, ["SSS"] = 13,
    ["O-"]  = 14, ["O"]   = 15, ["O+"]  = 16,
}

local function ToRankString(v)
    local s = tostring(v or ""):upper():gsub("%s+", ""):gsub("PLUS", "+")
    if STAT_RANK_VALUE[s] then return s end
    local n = tonumber(v)
    if n then
        if n >= 16 then return "O+"  end
        if n >= 15 then return "O"   end
        if n >= 14 then return "O-"  end
        if n >= 13 then return "SSS" end
        if n >= 12 then return "SS"  end
        if n >= 11 then return "S+"  end
        if n >= 10 then return "S"   end
        if n >= 9  then return "S-"  end
        if n >= 8  then return "A+"  end
        if n >= 7  then return "A"   end
        if n >= 6  then return "A-"  end
        if n >= 5  then return "B+"  end
        if n >= 4  then return "B"   end
        if n >= 3  then return "B-"  end
        if n >= 2  then return "C+"  end
        if n >= 1  then return "C"   end
        return "C-"
    end
    return "C-"
end

local function RankAtLeast(rank, target)
    return (STAT_RANK_VALUE[ToRankString(rank)] or 0) >= (STAT_RANK_VALUE[ToRankString(target)] or 0)
end

