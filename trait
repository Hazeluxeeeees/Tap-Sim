local function GetEquippedRoot(playerData)
    -- Different accounts/versions can store "equipped" in different containers.
    for _, key in ipairs({ "EquippedUnits", "Equipped", "Loadout", "UnitSlots", "ActiveUnits", "SelectedUnits" }) do
        local f = playerData and playerData:FindFirstChild(key)
        if f then return f end
    end
    return nil
end

local function ScanUnitsFromEquipped(equippedRoot, collection)
    local units = {}
    local seen = {}

    local function addUnit(inst, overrideName)
        if not inst then return end
        local key = (inst.GetFullName and inst:GetFullName()) or tostring(inst)
        if seen[key] then return end
        if not overrideName then overrideName = inst.Name end
        seen[key] = true
        table.insert(units, { instance = inst, name = tostring(overrideName) })
    end

    local foundAny = false
    pcall(function()
        -- 1) Prefer direct children that look like unit instances.
        for _, ch in ipairs(equippedRoot:GetChildren()) do
            if LooksLikeUnitInstance(ch) then
                foundAny = true
                addUnit(ch)
            elseif ch:IsA("StringValue") or ch:IsA("IntValue") or ch:IsA("NumberValue") then
                -- 2) If it stores a unit name, resolve into Collection.
                local vName = tostring(ch.Value)
                local resolved = collection and collection:FindFirstChild(vName)
                if resolved and LooksLikeUnitInstance(resolved) then
                    foundAny = true
                    addUnit(resolved, vName)
                end
            end
        end
    end)

    -- 3) Fallback: try to resolve any matching value from descendants.
    if not foundAny and collection then
        pcall(function()
            local colByName = {}
            for _, u in ipairs(collection:GetChildren()) do
                colByName[u.Name] = u
            end
            for _, vObj in ipairs(equippedRoot:GetDescendants()) do
                if vObj:IsA("StringValue") or vObj:IsA("IntValue") or vObj:IsA("NumberValue") then
                    local vName = tostring(vObj.Value)
                    local resolved = colByName[vName]
                    if resolved and LooksLikeUnitInstance(resolved) then
                        foundAny = true
                        addUnit(resolved, vName)
                    end
                end
            end
        end)
    end

    return units, foundAny
end

local function ScanUnits()
    TR.Units = {}

    local collection = GetCollection()
    if not collection then
        SetStatus("⚠ Collection nicht gefunden!", D.Orange)
        return false
    end

    -- Primary requirement: scan currently equipped units.
    local equippedUnits = nil
    local equippedFound = false
    pcall(function()
        local playerData = RS:WaitForChild("Player_Data", 10):WaitForChild(LP.Name, 10)
        local equippedRoot = GetEquippedRoot(playerData)
        if equippedRoot then
            equippedUnits, equippedFound = ScanUnitsFromEquipped(equippedRoot, collection)
        end
    end)

    local sourceList = nil
    if equippedFound and equippedUnits and #equippedUnits > 0 then
        sourceList = equippedUnits
        SetStatus("✅ Ausgerüstete Einheiten gefunden: " .. #sourceList, D.Green)
    else
        -- Fallback: scan all Collection entries.
        local all = {}
        for _, unit in pairs(collection:GetChildren()) do
            if (unit:IsA("Folder") or unit:IsA("Model") or unit:IsA("Configuration"))
                and LooksLikeUnitInstance(unit) then
                table.insert(all, { instance = unit, name = unit.Name })
            end
        end
        sourceList = all
        SetStatus("✅ " .. #sourceList .. " Einheiten gefunden", D.Green)
    end

    local nameCount = {}
    for _, entry in ipairs(sourceList) do
        local n = entry.name
        nameCount[n] = (nameCount[n] or 0) + 1
    end

    local nameSeen = {}
    for _, entry in ipairs(sourceList) do
        local n = entry.name
        nameSeen[n] = (nameSeen[n] or 0) + 1
        local displayName = n
        if nameCount[n] > 1 then displayName = n .. " #" .. nameSeen[n] end
        table.insert(TR.Units, { instance = entry.instance, name = n, index = nameSeen[n], displayName = displayName })
    end

    table.sort(TR.Units, function(a, b) return a.displayName:lower() < b.displayName:lower() end)
    return #TR.Units > 0
end

