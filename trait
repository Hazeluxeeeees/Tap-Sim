            if not loaded then local fb=Instance.new("TextLabel",vp); fb.Size=UDim2.new(1,0,1,0); fb.BackgroundTransparency=1; fb.Text=u.name:sub(1,1):upper(); fb.TextColor3=D.TextLow; fb.TextSize=18; fb.Font=Enum.Font.GothamBold end
