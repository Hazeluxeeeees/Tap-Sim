        if filter~="" and not u.displayName:lower():find(filter,1,true) then continue end
        shown=shown+1; local isSelected=(TR.SelectedUnit==u.instance)
        local row=Instance.new("Frame",TR.UI.Fr.UnitList)
        row.Size=UDim2.new(0,150,0,180); row.BorderSizePixel=0; Corner(row,8)
        if (HS._isTouchClient==true) or UserInputService.TouchEnabled then
            local ar=Instance.new("UIAspectRatioConstraint",row); ar.AspectRatio=1; ar.DominantAxis=Enum.DominantAxis.Width
        end
        if isSelected then row.BackgroundColor3=D.RowSelect or Color3.fromRGB(48,50,58); Stroke(row,D.Accent or D.Cyan,1.5,0)
        else row.BackgroundColor3=D.CardHover; Stroke(row,D.Border,1,0.4) end
        local bar=Instance.new("Frame",row); bar.Size=UDim2.new(0,3,0.92,0); bar.Position=UDim2.new(0,0,0.04,0); bar.BackgroundColor3=isSelected and D.Cyan or D.Border; bar.BorderSizePixel=0; Corner(bar,2)
