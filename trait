        if td and td.Description then
            local dL = Instance.new("TextLabel", inner)
            dL.Size = UDim2.new(1, 0, 0, 0)
            dL.AutomaticSize = Enum.AutomaticSize.Y
            dL.BackgroundTransparency = 1
            dL.Text = td.Description
            dL.TextColor3 = D.TextLow
            dL.TextSize = 12
            dL.Font = Enum.Font.GothamMedium
            dL.TextXAlignment = Enum.TextXAlignment.Left
            dL.TextWrapped = true
        end
        if td and td.Stats then
            local statParts = {}
            for stat, val in pairs(td.Stats) do
                local sign = val >= 0 and "+" or ""
                table.insert(statParts, sign .. val .. "% " .. stat)
            end
            if #statParts > 0 then
                local sL = Instance.new("TextLabel", inner)
                sL.Size = UDim2.new(1, 0, 0, 0)
                sL.AutomaticSize = Enum.AutomaticSize.Y
                sL.BackgroundTransparency = 1
                sL.Text = table.concat(statParts, ", ")
                sL.TextColor3 = col
                sL.TextSize = 12
                sL.Font = Enum.Font.GothamBold
                sL.TextXAlignment = Enum.TextXAlignment.Left
                sL.TextWrapped = true
            end
        end
    end
    if #sorted == 0 then
        local eL = MkLbl(trListFrame, "Keine Traits gefunden.", 11, D.TextLow)
        eL.Size           = UDim2.new(1, 0, 0, 26)
        eL.TextXAlignment = Enum.TextXAlignment.Center
    end
end

