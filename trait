-- ── Responsive Layout ────────────────────────────────────────
local function traitSetFramePad(fr, top, right, bottom, left)
    if not fr then return end
    local p = fr:FindFirstChildOfClass("UIPadding")
    if p then
        p.PaddingTop    = UDim.new(0, top)
        p.PaddingRight  = UDim.new(0, right)
        p.PaddingBottom = UDim.new(0, bottom)
        p.PaddingLeft   = UDim.new(0, left)
    end
end
local function traitSetVListGap(fr, gap)
    if not fr then return end
    local lay = fr:FindFirstChildOfClass("UIListLayout")
    if lay then lay.Padding = UDim.new(0, gap) end
end

local function ApplyTraitResponsiveLayout()
    local touch = (HS._isTouchClient == true) or UserInputService.TouchEnabled
    if touch then
        unitGrid.FillDirection = Enum.FillDirection.Horizontal
        unitGrid.FillDirectionMaxCells = 1
        unitGrid.CellPadding = UDim2.new(0, 4, 0, 5)
        syncMobileUnitTileCell()
        unitScroll.Size = UDim2.new(1, 0, 0, 268)
        unitScroll.ScrollBarThickness = 3
        unitScroll.ElasticBehavior = Enum.ElasticBehavior.Never
        unitCard.Size = UDim2.new(1, 0, 0, 0)
        unitCard.AutomaticSize = Enum.AutomaticSize.Y
        overviewCard.Size = UDim2.new(1, 0, 0, 0)
        overviewCard.AutomaticSize = Enum.AutomaticSize.Y
        traitListScroll.Size = UDim2.new(1, 0, 0, 180)
        traitListScroll.ScrollBarThickness = 3
        traitSetFramePad(unitCard, 6, 8, 6, 8)
        traitSetFramePad(currentTraitCard, 6, 8, 6, 8)
        traitSetFramePad(targetCard, 6, 8, 6, 8)
        traitSetFramePad(rerollCard, 6, 8, 6, 8)
        traitSetFramePad(statsCard, 6, 8, 6, 8)
        traitSetFramePad(overviewCard, 6, 8, 6, 8)
        traitSetVListGap(unitCard, 4)
        traitSetVListGap(currentTraitCard, 5)
        traitSetVListGap(targetCard, 5)
        traitSetVListGap(rerollCard, 5)
        traitSetVListGap(statsCard, 5)
        traitSetVListGap(overviewCard, 3)
        traitSetVListGap(TraitPage, 5)
    else
        unitGrid.FillDirection = Enum.FillDirection.Horizontal
        unitGrid.FillDirectionMaxCells = 0
        unitGrid.CellSize = UDim2.new(0, 150, 0, 180)
        unitGrid.CellPadding = UDim2.new(0, 6, 0, 8)
        unitScroll.Size = UDim2.new(1, 0, 0, 240)
        unitScroll.ScrollBarThickness = 0
        unitScroll.ElasticBehavior = Enum.ElasticBehavior.Never
        unitCard.Size = UDim2.new(1, 0, 0, 0)
        unitCard.AutomaticSize = Enum.AutomaticSize.Y
        overviewCard.Size = UDim2.new(1, 0, 0, 0)
        overviewCard.AutomaticSize = Enum.AutomaticSize.Y
        traitListScroll.Size = UDim2.new(1, 0, 0, 220)
        traitListScroll.ScrollBarThickness = 3
        traitSetFramePad(unitCard, 10, 12, 10, 12)
        traitSetFramePad(currentTraitCard, 10, 12, 10, 12)
        traitSetFramePad(targetCard, 10, 12, 10, 12)
        traitSetFramePad(rerollCard, 10, 12, 10, 12)
        traitSetFramePad(statsCard, 10, 12, 10, 12)
        traitSetFramePad(overviewCard, 10, 12, 10, 12)
        traitSetVListGap(unitCard, 7)
        traitSetVListGap(currentTraitCard, 8)
        traitSetVListGap(targetCard, 8)
        traitSetVListGap(rerollCard, 8)
        traitSetVListGap(statsCard, 8)
        traitSetVListGap(overviewCard, 6)
        traitSetVListGap(TraitPage, 8)
    end
    task.defer(function()
        pcall(refreshUnitScrollCanvas)
        pcall(refreshTraitScrollCanvas)
    end)
end
