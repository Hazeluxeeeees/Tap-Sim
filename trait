local UnitModelsRoot=nil; local BucketModelIndex={Unit={},Shiny={},Evo={}}
local function NormalizeUnitKey(n) local key=tostring(n or ""):lower(); return key:gsub(":shiny",""):gsub(":evo",""):gsub("%s+$",""):gsub("^%s+","") end
local function ResolveTemplateBucket(n) local s=tostring(n or ""):lower(); if s:find(":shiny",1,true) then return "Shiny" end; if s:find(":evo",1,true) then return "Evo" end; return "Unit" end
local function BuildBucketModelIndex()
    BucketModelIndex={Unit={},Shiny={},Evo={}}; UnitModelsRoot=nil
    pcall(function() UnitModelsRoot=RS:WaitForChild("Assets",8):WaitForChild("UnitModels",8) end)
    if not UnitModelsRoot then return end
    for _,bucket in ipairs({"Unit","Shiny","Evo"}) do
        local folder=UnitModelsRoot:FindFirstChild(bucket)
        if folder then for _,entry in ipairs(folder:GetDescendants()) do if entry:IsA("Model") then BucketModelIndex[bucket][entry.Name:lower()]=entry end end end
    end
end
local function BucketSearchOrder(preferred)
    if preferred=="Shiny" then return {"Shiny","Unit"} end
    if preferred=="Evo"   then return {"Evo","Unit"}   end
    return {"Unit","Shiny","Evo"}
end
local function FindUnitTemplate(unitName)
    if not UnitModelsRoot then BuildBucketModelIndex() end
    local key=NormalizeUnitKey(unitName); if key=="" then return nil end
    for _,bucket in ipairs(BucketSearchOrder(ResolveTemplateBucket(unitName))) do
        local idx=BucketModelIndex[bucket]
        if idx then
            local exact=idx[key]; if exact then return exact end
            for n,mdl in pairs(idx) do if n:find(key,1,true) or key:find(n,1,true) then return mdl end end
        end
    end
    return nil
end
local CAM_DIST=5.5
local function FillViewportWithUnit(vp,unitName)
    local ok=false
    pcall(function()
        for _,d in ipairs(vp:GetDescendants()) do if d:IsA("WorldModel") or d:IsA("Camera") then d:Destroy() end end
        local source=FindUnitTemplate(unitName); if not source then return end
        local world=Instance.new("WorldModel"); world.Parent=vp
        local clone=source:Clone(); clone.Parent=world
        if not clone.PrimaryPart then local pp0=clone:FindFirstChildWhichIsA("BasePart",true); if pp0 then clone.PrimaryPart=pp0 end end
        clone:PivotTo(CFrame.new(0,0,0))
        local cam=Instance.new("Camera"); cam.Parent=vp; vp.CurrentCamera=cam; cam.FieldOfView=60
        local head=clone:FindFirstChild("Head",true); local upperTorso=clone:FindFirstChild("UpperTorso",true) or clone:FindFirstChild("Torso",true)
        local pp=clone.PrimaryPart; if not pp or not pp:IsA("BasePart") then pp=clone:FindFirstChildWhichIsA("BasePart",true) end
        local aim=(head and head:IsA("BasePart") and head) or (upperTorso and upperTorso:IsA("BasePart") and upperTorso) or pp
        if not aim then return end
        cam.CFrame=CFrame.new(aim.Position+aim.CFrame.LookVector*CAM_DIST+Vector3.new(0,0.5,0),aim.Position); ok=true
    end)
    return ok
end

