local function BuildTraitOverview(filter)
    for _, v in pairs(trListFrame:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    filter = (filter or ""):lower()
    local sorted = {}
    for name, data in pairs(AllTraits) do
        if filter == "" or name:lower():find(filter, 1, true) then
            table.insert(sorted, { name = name, data = data })
        end
    end
    table.sort(sorted, function(a, b)
        local ra = RARITY_ORDER[(a.data and a.data.Rarity) or "Common"] or 99
        local rb = RARITY_ORDER[(b.data and b.data.Rarity) or "Common"] or 99
        if ra ~= rb then return ra < rb end
        return a.name:lower() < b.name:lower()
    end)
    for _, entry in ipairs(sorted) do
        local td  = entry.data
        local col = GetRarityColor(td and td.Rarity)
        local row = Instance.new("Frame", trListFrame)
        row.Size                  = UDim2.new(1, 0, 0, 0)
        row.AutomaticSize         = Enum.AutomaticSize.Y
        row.BorderSizePixel       = 0
        Corner(row, 7)
        row.BackgroundColor3 = D.Card
        Stroke(row, col, 1, 0.5)

        local acBar = Instance.new("Frame", row)
        acBar.Name = "AccentBar"
        acBar.Size = UDim2.new(0, 3, 0, 40)
        acBar.BackgroundColor3 = col
        acBar.BorderSizePixel = 0
        Corner(acBar, 2)

        local inner = Instance.new("Frame", row)
        inner.Size = UDim2.new(1, -6, 0, 0)
        inner.Position = UDim2.new(0, 3, 0, 0)
        inner.AutomaticSize = Enum.AutomaticSize.Y
        inner.BackgroundTransparency = 1
        Pad(inner, 5, 8, 5, 8)

        local innerLay = Instance.new("UIListLayout", inner)
        innerLay.FillDirection = Enum.FillDirection.Vertical
        innerLay.Padding = UDim.new(0, 4)
        innerLay.SortOrder = Enum.SortOrder.LayoutOrder

        local headRow = Instance.new("Frame", inner)
        headRow.Size = UDim2.new(1, 0, 0, 18)
        headRow.BackgroundTransparency = 1

        local nL = Instance.new("TextLabel", headRow)
        nL.Size = UDim2.new(0.65, 0, 1, 0)
        nL.BackgroundTransparency = 1
        nL.Text = entry.name
        nL.TextColor3 = col
