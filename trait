-- ── Hilfsfunktionen ───────────────────────────────────────────
local function GetUnitTraits(unitInstance)
    local main,sub=nil,nil
    pcall(function()
        local tf=unitInstance:FindFirstChild("Traits") or unitInstance:FindFirstChild("Trait")
        if tf then
            local pm=tf:FindFirstChild("PrimaryTrait") or tf:FindFirstChild("Primary")
            local ps=tf:FindFirstChild("SecondaryTrait") or tf:FindFirstChild("Secondary") or tf:FindFirstChild("SubTrait")
            if pm then main=tostring(pm.Value) end
            if ps then sub=tostring(ps.Value) end
        else
            local pm=unitInstance:FindFirstChild("PrimaryTrait") or unitInstance:FindFirstChild("Primary")
            local ps=unitInstance:FindFirstChild("SecondaryTrait") or unitInstance:FindFirstChild("Secondary")
            if pm then main=tostring(pm.Value) end
            if ps then sub=tostring(ps.Value) end
        end
    end)
    return main,sub
end

-- ╔══════════════════════════════════════════════════════════╗
--  FIX #2 – GetPotentialObject: robustere Pfad-Suche
--  Sucht in: Direct → Stats → Potentials → Data → Deep
-- ╚══════════════════════════════════════════════════════════╝
local function GetPotentialObject(unitInstance, statName)
    if not unitInstance then return nil end
    -- 1. Direkt am Unit
    local direct = unitInstance:FindFirstChild(statName)
    if direct then return direct end
    -- 2. Stats-Ordner
    local stats = unitInstance:FindFirstChild("Stats")
    if stats then
        local s = stats:FindFirstChild(statName)
        if s then return s end
    end
    -- 3. Potentials-Ordner
    local pot = unitInstance:FindFirstChild("Potentials")
    if pot then
        local p = pot:FindFirstChild(statName)
        if p then return p end
    end
    -- 4. Data-Ordner
    local data = unitInstance:FindFirstChild("Data")
    if data then
        local d = data:FindFirstChild(statName)
        if d then return d end
    end
    -- 5. Alle bekannten Containerordner iterieren
    for _, containerName in ipairs({"Attributes","Properties","Values","Config"}) do
        local container = unitInstance:FindFirstChild(containerName)
        if container then
            local c = container:FindFirstChild(statName)
            if c then return c end
        end
    end
    -- 6. Tiefen-Suche als letztes Mittel
    return unitInstance:FindFirstChild(statName, true)
end

local function GetStatRatings(unitInstance)
    local out = {}
    for _, statName in ipairs(STAT_POTENTIAL_NAMES) do
        local obj  = GetPotentialObject(unitInstance, statName)
        local raw  = obj and obj.Value or nil
        out[statName] = { raw=raw, rating=ToRankString(raw), obj=obj }
    end
    return out
end

-- FIX #5: ReadStatFromLabel liest aus valLbl (Format: "S+  (12)")
local function ReadStatFromLabel(statName)
    local rowData = TR.UI.Fr.StatRows and TR.UI.Fr.StatRows[statName]
    if not rowData or not rowData.valLbl then return nil end
    local text = rowData.valLbl.Text or ""
    local rating = text:match("^([^%s]+)")
    if rating and GRADE_INDEX[rating] then return rating end
    local rawStr = text:match("%((.-)%)")
    if rawStr then return ToRankString(rawStr) end
    return nil
end

local function GetUnitTagValue(unitName)
    local uName=unitName and tostring(unitName) or nil
    if not uName or uName=="" then return nil end
    local ok,tagValue=pcall(function()
        local playerData=RS:WaitForChild("Player_Data",10)
        local accountFolder=playerData:WaitForChild(LP.Name,10)
        local collection=accountFolder:WaitForChild("Collection",5)
        local unitFolder=collection:FindFirstChild(uName)
        if not unitFolder then
            for _,ch in ipairs(collection:GetChildren()) do
                if string.lower(ch.Name)==string.lower(uName) then unitFolder=ch; break end
            end
        end
        if not unitFolder then return nil end
        local tagObj=unitFolder:FindFirstChild("Tag") or unitFolder:FindFirstChild("Tags")
        if not tagObj then return nil end
        local vObj=tagObj:FindFirstChild("Value")
        if vObj then return vObj.Value end
        if tagObj.Value~=nil then return tagObj.Value end
        return nil
    end)
    if not ok then return nil end
    return tagValue
end

