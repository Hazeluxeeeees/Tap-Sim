-- ╔══════════════════════════════════════════════════════════╗
--  FIX #2 + #5 – CheckAllStatGoals (AND + >= + Label-Check)
--
--  Priorität der Stat-Quellen:
--    1. ReadStatFromLabel (GUI-Label, frischster Wert nach Roll)
--    2. GetStatRatings    (DataModel, Fallback)
--
--  Stop-Logik: allMet = true nur wenn ALLE aktiven Stats
--              StatValues[current] >= StatValues[target]
-- ╚══════════════════════════════════════════════════════════╝
local function CheckAllStatGoals()
    if not TR.SelectedUnit then return false, {} end
    local hasAnyTarget = false
    for _ in pairs(TR.StatTargetRatings) do hasAnyTarget = true; break end
    if not hasAnyTarget then return false, {} end

    -- Hole frische Ratings aus dem DataModel
    local ratings = GetStatRatings(TR.SelectedUnit)
    local allMet  = true
    local details = {}

    for statName, targetRating in pairs(TR.StatTargetRatings) do
        -- FIX #5: Bevorzuge GUI-Label-Wert (aktueller nach Roll)
        local labelRating   = ReadStatFromLabel(statName)
        local modelRating   = ratings[statName] and ratings[statName].rating or "C-"
        -- Nehme den BESSEREN der beiden Werte um False-Negatives zu vermeiden
        local lv = StatValues[labelRating or ""] or 0
        local mv = StatValues[modelRating]       or 1
        local currentRating = (lv >= mv) and (labelRating or modelRating) or modelRating

        -- FIX #2: >= Vergleich (nicht ==)
        local met = RankAtLeast(currentRating, targetRating)
        details[statName] = {
            current = currentRating,
            target  = targetRating,
            met     = met,
        }
        if not met then allMet = false end
    end
    return allMet, details
end

-- ── RefreshStatPanel ──────────────────────────────────────────
function RefreshStatPanel()
    if not TR.UI.Fr.StatRows then return end
    if not TR.SelectedUnit then
        TR.UI.Lbl.StatHeader.Text       = "Keine Einheit gewählt"
        TR.UI.Lbl.StatHeader.TextColor3 = D.TextLow
        for n, r in pairs(TR.UI.Fr.StatRows) do
            r.nameLbl.Text      = STAT_DISPLAY_NAMES[n] or n
            r.valLbl.Text       = "–"
            r.valLbl.TextColor3 = D.TextLow
            r.targetLbl.Text    = ""
        end
        return
    end
    TR.UI.Lbl.StatHeader.Text       = "Stats: " .. TR.SelectedUnit.Name
    TR.UI.Lbl.StatHeader.TextColor3 = D.Cyan
    local ratings = GetStatRatings(TR.SelectedUnit)
    local _, goalDetails = CheckAllStatGoals()

    for n, r in pairs(TR.UI.Fr.StatRows) do
        local d        = ratings[n]
        local rating   = d and d.rating or "C-"
        local raw      = d and d.raw    or "-"
        local gd       = goalDetails[n]
        local isTarget = gd and gd.met == true
        local hasTarget = TR.StatTargetRatings[n] ~= nil

        -- Farbe nach Rang
        local col = isTarget and D.GreenBright
                  or (RankAtLeast(rating, "S")  and D.Gold
                  or (RankAtLeast(rating, "A")  and D.Yellow
                  or D.TextMid))

        r.nameLbl.Text      = STAT_DISPLAY_NAMES[n] or n
        -- FIX #5: Format "RATING  (raw)" – ReadStatFromLabel extrahiert RATING
        r.valLbl.Text       = tostring(rating) .. "  (" .. tostring(raw) .. ")"
        r.valLbl.TextColor3 = col

        if hasTarget then
            local targetRating = TR.StatTargetRatings[n]
            if isTarget then
                r.targetLbl.Text       = "≥" .. targetRating .. " ✓"
                r.targetLbl.TextColor3 = D.GreenBright
            else
                r.targetLbl.Text       = "≥" .. targetRating
                r.targetLbl.TextColor3 = D.CyanDim
            end
        else
            r.targetLbl.Text = ""
        end

        Stroke(r.row, isTarget and D.GreenBright or D.Border, 1, isTarget and 0 or 0.45)
    end
end

