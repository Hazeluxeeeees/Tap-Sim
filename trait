    toggleBtn.TextSize         = 11
    toggleBtn.Font             = Enum.Font.GothamMedium
    toggleBtn.AutoButtonColor  = false
    toggleBtn.BorderSizePixel  = 0
    Corner(toggleBtn, 6)

    local dropBody = Instance.new("Frame", wrap)
    dropBody.Size                  = UDim2.new(1, 0, 0, 0)
    dropBody.AutomaticSize         = Enum.AutomaticSize.Y
    dropBody.BackgroundTransparency = 1
    dropBody.Visible               = false
    VList(dropBody, 4)

    local searchOuter, searchBox = MkInput(dropBody, title .. " suchen...", 26)
    searchOuter.Size = UDim2.new(1, 0, 0, 26)

    local listInner = Instance.new("Frame", dropBody)
    listInner.Size                  = UDim2.new(1, 0, 0, 0)
    listInner.AutomaticSize         = Enum.AutomaticSize.Y
    listInner.BackgroundTransparency = 1
    VList(listInner, 3)

    local function RebuildList(filter)
        for _, ch in pairs(listInner:GetChildren()) do if ch:IsA("Frame") then ch:Destroy() end end
        filter = (filter or ""):lower()
        local sorted = {}
        for k in pairs(AllTraits) do
            if filter == "" or k:lower():find(filter, 1, true) then table.insert(sorted, k) end
        end
        table.sort(sorted)
        for _, k in ipairs(sorted) do
            local r = Instance.new("Frame", listInner)
            r.Size                  = UDim2.new(1, 0, 0, 24)
            r.BackgroundColor3      = D.CardHover
            r.BackgroundTransparency = targetSet[k] and 0.12 or 0.55
            r.BorderSizePixel       = 0
            Corner(r, 6)
            Stroke(r, targetSet[k] and accent or D.Border, 1, targetSet[k] and 0 or 0.5)

            local cb = Instance.new("TextLabel", r)
            cb.Size                  = UDim2.new(0, 16, 0, 16)
            cb.Position              = UDim2.new(0, 4, 0.5, -8)
            cb.BackgroundColor3      = targetSet[k] and accent or D.Border
            cb.BackgroundTransparency = targetSet[k] and 0.05 or 0.5
            cb.Text                  = targetSet[k] and "✓" or ""
            cb.TextColor3            = Color3.new(1, 1, 1)
            cb.TextSize              = 10
            cb.Font                  = Enum.Font.GothamBold
            cb.TextXAlignment        = Enum.TextXAlignment.Center
            cb.TextYAlignment        = Enum.TextYAlignment.Center
            cb.BorderSizePixel       = 0
            Corner(cb, 3)

            local tl = Instance.new("TextLabel", r)
            tl.Position              = UDim2.new(0, 26, 0, 0)
            tl.Size                  = UDim2.new(1, -30, 1, 0)
            tl.BackgroundTransparency = 1
            tl.Text                  = k
            tl.TextColor3            = targetSet[k] and D.TextHi or D.TextMid
            tl.TextSize              = 12
            tl.Font                  = Enum.Font.GothamMedium
            tl.TextXAlignment        = Enum.TextXAlignment.Left
            tl.TextTruncate          = Enum.TextTruncate.AtEnd

            local clk = Instance.new("TextButton", r)
            clk.Size                  = UDim2.new(1, 0, 1, 0)
            clk.BackgroundTransparency = 1
            clk.Text                  = ""
            clk.BorderSizePixel       = 0
            local capK = k
            clk.MouseButton1Click:Connect(function()
                if targetSet[capK] then targetSet[capK] = nil else targetSet[capK] = true end
                RebuildList(searchBox.Text)
            end)
        end
        if #sorted == 0 then MkLbl(listInner, "Keine Traits.", 11, D.TextLow).Size = UDim2.new(1, 0, 0, 24) end
    end

    toggleBtn.MouseButton1Click:Connect(function()
        dropBody.Visible = not dropBody.Visible
        toggleBtn.Text   = dropBody.Visible and "▴ Einklappen" or "▾ Ausklappen"
        if dropBody.Visible then task.spawn(function() pcall(function() RebuildList("") end) end) end
    end)
    searchBox:GetPropertyChangedSignal("Text"):Connect(function() pcall(function() RebuildList(searchBox.Text) end) end)
    return dropBody
end

