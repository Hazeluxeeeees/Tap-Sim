local function CheckGoalReached()
    if not TR.SelectedUnit then return false end
    local main, sub = GetUnitTraits(TR.SelectedUnit)
    if main and TR.TargetTraits[main] then
        SetStatus("🎉 Ziel-Trait '" .. main .. "' ERREICHT! Gestoppt.", D.GreenBright); return true
    end
    if sub and TR.TargetTraits[sub] then
        SetStatus("🎉 Ziel-Trait '" .. sub .. "' ERREICHT! Gestoppt.", D.GreenBright); return true
    end
    return false
end

