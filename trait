        local headRow=Instance.new("Frame",inner); headRow.Size=UDim2.new(1,0,0,18); headRow.BackgroundTransparency=1
        local nL=Instance.new("TextLabel",headRow); nL.Size=UDim2.new(0.65,0,1,0); nL.BackgroundTransparency=1; nL.Text=entry.name; nL.TextColor3=col; nL.TextSize=14; nL.Font=Enum.Font.GothamBold; nL.TextXAlignment=Enum.TextXAlignment.Left
        local rL=Instance.new("TextLabel",headRow); rL.Size=UDim2.new(0.35,0,1,0); rL.Position=UDim2.new(0.65,0,0,0); rL.BackgroundTransparency=1; rL.Text=(td and td.Rarity) or ""; rL.TextColor3=col; rL.TextSize=12; rL.Font=Enum.Font.GothamMedium; rL.TextXAlignment=Enum.TextXAlignment.Right
        local function syncBarHeight() local h=inner.AbsoluteSize.Y; if h>0 then acBar.Size=UDim2.new(0,3,0,h) end end
        inner:GetPropertyChangedSignal("AbsoluteSize"):Connect(syncBarHeight); innerLay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(syncBarHeight); task.defer(syncBarHeight)
        if td and td.Description then local dL=Instance.new("TextLabel",inner); dL.Size=UDim2.new(1,0,0,0); dL.AutomaticSize=Enum.AutomaticSize.Y; dL.BackgroundTransparency=1; dL.Text=td.Description; dL.TextColor3=D.TextLow; dL.TextSize=12; dL.Font=Enum.Font.GothamMedium; dL.TextXAlignment=Enum.TextXAlignment.Left; dL.TextWrapped=true end
        if td and td.Stats then
            local statParts={}; for stat,val in pairs(td.Stats) do local sign=val>=0 and "+" or ""; table.insert(statParts,sign..val.."% "..stat) end
            if #statParts>0 then local sL=Instance.new("TextLabel",inner); sL.Size=UDim2.new(1,0,0,0); sL.AutomaticSize=Enum.AutomaticSize.Y; sL.BackgroundTransparency=1; sL.Text=table.concat(statParts,", "); sL.TextColor3=col; sL.TextSize=12; sL.Font=Enum.Font.GothamBold; sL.TextXAlignment=Enum.TextXAlignment.Left; sL.TextWrapped=true end
        end
