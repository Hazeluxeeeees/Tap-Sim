-- Auto-Reroll Loop
local function AutoRerollLoop()
    TR.Rolling = true
    TR.RollCount = 0
    local delay = math.max(0.1, tonumber(delayBox.Text) or 0.5)
    startRerollBtn.Text="⏳ Rollt..."; startRerollBtn.TextColor3=D.Yellow; Stroke(startRerollBtn,D.Yellow,2,0)
    SetStatus("🎲 Auto-Reroll läuft...", D.Gold)
    local rollStart = os.time()
    while TR.Rolling do
        -- Main reroll
        local mainOk = DoSingleReroll("Main")
        if not mainOk then SetStatus("❌ Main-Reroll fehlgeschlagen!",D.Red); TR.Rolling=false; break end
        task.wait(delay * 0.5)
        pcall(UpdateLiveTraitDisplay)
        if CheckGoalReached() then TR.Rolling=false; break end
        -- Sub reroll (nur wenn Sub-Ziele gesetzt)
        if next(TR.TargetSub) then
            local subOk = DoSingleReroll("Sub")
            if not subOk then SetStatus("❌ Sub-Reroll fehlgeschlagen!",D.Red); TR.Rolling=false; break end
            task.wait(delay * 0.5)
            pcall(UpdateLiveTraitDisplay)
            if CheckGoalReached() then TR.Rolling=false; break end
        end
        task.wait(delay)
        -- Rate anzeigen
        local elapsed = os.time() - rollStart
        if elapsed > 0 then
            local rps = string.format("%.1f r/min", TR.RollCount / math.max(1,elapsed) * 60)
            pcall(function() TR.UI.Lbl.RollRate.Text = rps end)
        end
    end
    TR.Rolling = false
    startRerollBtn.Text="🎲  Auto-Reroll STARTEN"; startRerollBtn.TextColor3=D.Gold; Stroke(startRerollBtn,D.Gold,2,0)
    pcall(UpdateLiveTraitDisplay)
end

