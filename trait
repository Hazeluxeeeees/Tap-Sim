local function ScanUnits()
    TR.Units={}
    local collection=GetCollection()
    if not collection then SetStatus("⚠ Collection nicht gefunden!",D.Orange); return false end
    local sourceList={}
    for _,unit in pairs(collection:GetChildren()) do
        if (unit:IsA("Folder") or unit:IsA("Model") or unit:IsA("Configuration"))
            and (LooksLikeUnitInstance(unit) or unit:FindFirstChild("Tag")) then
            table.insert(sourceList,{instance=unit,name=unit.Name})
        end
    end
    SetStatus("✅ "..#sourceList.." Einheiten gefunden",D.Green)
    local nameCount,nameSeen={},{}
    for _,entry in ipairs(sourceList) do nameCount[entry.name]=(nameCount[entry.name] or 0)+1 end
    for _,entry in ipairs(sourceList) do
        local n=entry.name; nameSeen[n]=(nameSeen[n] or 0)+1
        local displayName=n
        if nameCount[n]>1 then displayName=n.." #"..nameSeen[n] end
        table.insert(TR.Units,{instance=entry.instance,name=n,index=nameSeen[n],displayName=displayName})
    end
    table.sort(TR.Units,function(a,b) return a.displayName:lower()<b.displayName:lower() end)
    return #TR.Units>0
end

