        nL.TextXAlignment = Enum.TextXAlignment.Left

        local rL = Instance.new("TextLabel", headRow)
        rL.Size = UDim2.new(0.35, 0, 1, 0)
        rL.Position = UDim2.new(0.65, 0, 0, 0)
        rL.BackgroundTransparency = 1
        rL.Text = (td and td.Rarity) or ""
        rL.TextColor3 = col
        rL.TextSize = 12
        rL.Font = Enum.Font.GothamMedium
        rL.TextXAlignment = Enum.TextXAlignment.Right

        local function syncBarHeight()
            local h = inner.AbsoluteSize.Y
            if h > 0 then acBar.Size = UDim2.new(0, 3, 0, h) end
        end
        inner:GetPropertyChangedSignal("AbsoluteSize"):Connect(syncBarHeight)
        innerLay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(syncBarHeight)
