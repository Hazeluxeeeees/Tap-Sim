        local nL=Instance.new("TextLabel",row); nL.Position=UDim2.new(0,4,0.72,0); nL.Size=UDim2.new(1,-8,0,16); nL.BackgroundTransparency=1; nL.Text=u.displayName; nL.TextColor3=isSelected and D.Cyan or D.TextHi; nL.TextSize=13; nL.Font=Enum.Font.GothamBold; nL.TextXAlignment=Enum.TextXAlignment.Left; nL.TextTruncate=Enum.TextTruncate.AtEnd
