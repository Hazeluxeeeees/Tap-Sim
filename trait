        local elapsed = os.time() - rollStart
        if elapsed > 0 then
            pcall(function()
                TR.UI.Lbl.RollRate.Text = string.format("%.1f r/min", TR.RollCount / math.max(1, elapsed) * 60)
            end)
        end
    end
    TR.Rolling = false
    startRerollBtn.Text       = "▶  Start Reroll"
    startRerollBtn.TextColor3 = D.GreenBright
    Stroke(startRerollBtn, D.Green, 1.5, 0.3)
