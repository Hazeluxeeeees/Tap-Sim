    local rollStart = os.time()
    while TR.Rolling do
        pcall(UpdateLiveTraitDisplay)
        if CheckGoalReached() then TR.Rolling = false; break end
        local ok = DoSingleReroll()
        if not ok then SetStatus("❌ Reroll fehlgeschlagen!", D.Red); TR.Rolling = false; break end
        task.wait(0.1)
        pcall(UpdateLiveTraitDisplay)
