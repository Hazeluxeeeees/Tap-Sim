local function BuildLogo(parent,sz,lx,ly)
    sz=sz or 32
    local root=Instance.new("Frame",parent)
    root.Size=UDim2.new(0,sz,0,sz);root.AnchorPoint=Vector2.new(0,0)
    root.Position=UDim2.new(0,lx or 0,0,ly or 0)
    root.BackgroundTransparency=1;root.BorderSizePixel=0
    local ring=Instance.new("Frame",root);ring.Size=UDim2.new(1,0,1,0)
    ring.BackgroundTransparency=1;ring.BorderSizePixel=0;Corner(ring,99);Stroke(ring,D.Cyan,1.5,0.35)
    local bg=Instance.new("Frame",root);bg.Size=UDim2.new(0.84,0,0.84,0)
    bg.Position=UDim2.new(0.08,0,0.08,0);bg.BackgroundColor3=Color3.fromRGB(0,15,38)
    bg.BackgroundTransparency=0.08;bg.BorderSizePixel=0;Corner(bg,99)
    local bgG=Instance.new("UIGradient",bg)
    bgG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(0,38,85)),ColorSequenceKeypoint.new(1,Color3.fromRGB(0,8,28))});bgG.Rotation=135
    local tk=math.max(2,math.floor(sz*0.18));local bh=math.floor(sz*0.75)
    local by=math.floor((sz-bh)/2);local bxl=math.floor(sz*0.18);local bxr=sz-bxl-tk
    local function gs() return ColorSequence.new({ColorSequenceKeypoint.new(0,D.Cyan),ColorSequenceKeypoint.new(0.5,D.Green),ColorSequenceKeypoint.new(1,D.Cyan)}) end
    local bl=Instance.new("Frame",root);bl.Size=UDim2.new(0,tk,0,bh);bl.Position=UDim2.new(0,bxl,0,by);bl.BackgroundColor3=D.Cyan;bl.BorderSizePixel=0;Corner(bl,2);Instance.new("UIGradient",bl).Color=gs()
    local br=Instance.new("Frame",root);br.Size=UDim2.new(0,tk,0,bh);br.Position=UDim2.new(0,bxr,0,by);br.BackgroundColor3=D.Cyan;br.BorderSizePixel=0;Corner(br,2);Instance.new("UIGradient",br).Color=gs()
    local ch=math.max(2,math.floor(sz*0.14));local cw=bxr-bxl-tk;local cy=by+math.floor((bh-ch)/2)
    local bc=Instance.new("Frame",root);bc.Size=UDim2.new(0,cw,0,ch);bc.Position=UDim2.new(0,bxl+tk,0,cy);bc.BackgroundColor3=D.Cyan;bc.BorderSizePixel=0;Corner(bc,2)
    Instance.new("UIGradient",bc).Color=ColorSequence.new({ColorSequenceKeypoint.new(0,D.Green),ColorSequenceKeypoint.new(1,D.Cyan)})
    local ds=ch+2;local dot=Instance.new("Frame",root)
    dot.Size=UDim2.new(0,ds,0,ds);dot.Position=UDim2.new(0,bxl+tk+math.floor(cw/2)-math.floor(ds/2),0,cy-1)
    dot.BackgroundColor3=Color3.new(1,1,1);dot.BackgroundTransparency=0.15;dot.BorderSizePixel=0;Corner(dot,99)
    task.spawn(function()
        while root.Parent and Haze.State.Running do
            Tw(dot,{BackgroundTransparency=0.7},TM);task.wait(0.85)
            Tw(dot,{BackgroundTransparency=0.1},TM);task.wait(0.85)
        end
    end)
    return root
end

