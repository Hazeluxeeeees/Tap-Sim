local function SaveConfig()
    Haze.Config.SavedGoals = {}
    for _,g in ipairs(Haze.State.Goals) do
        table.insert(Haze.Config.SavedGoals,{item=g.item,amount=g.amount})
    end
    if writefile then
        pcall(function()
            writefile(SAVE_FILE,Svc.Http:JSONEncode(Haze.Config))
        end)
    end
end

local function LoadConfig()
    if not (isfile and isfile(SAVE_FILE)) then return end
    local ok,data = pcall(function()
        return Svc.Http:JSONDecode(readfile(SAVE_FILE))
    end)
    if not ok or not data then return end
    local C = Haze.Config
    if data.WebhookURL~=nil then C.WebhookURL=data.WebhookURL end
    if data.UISize    ~=nil then C.UISize    =data.UISize     end
    if data.ToggleKey ~=nil then C.ToggleKey =data.ToggleKey  end
    if data.AutoRetry ~=nil then C.AutoRetry =data.AutoRetry  end
    if data.SavedGoals and type(data.SavedGoals)=="table" then
        for _,g in ipairs(data.SavedGoals) do
            if g.item and tonumber(g.amount) then
                table.insert(Haze.State.Goals,{
                    item=g.item, amount=tonumber(g.amount), reached=false
                })
            end
        end
    end
end

