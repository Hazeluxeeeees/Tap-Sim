    for _,wid in ipairs(avail) do CreateWorldBtn(wid) end
    Haze.UI.Lbl.WorldStatus.Text="✅ "..#avail.." Welten verfügbar"
    Haze.UI.Lbl.WorldStatus.TextColor3=D.Green
