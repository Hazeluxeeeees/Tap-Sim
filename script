RebuildWorldList=function()
    local S=Haze.State
    for _,v in pairs(Haze.UI.Fr.WorldBtns:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _,v in pairs(Haze.UI.Fr.ChapRow:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    Haze.UI.Fr.ChapBtns={};S.SelectedWorldId=nil;S.SelectedChapId=nil

    if S.SelectedMode=="Calamity" then
        local cd=S.WorldData["Calamity"]
