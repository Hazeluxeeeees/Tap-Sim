-- === FUNKTIONEN ===
local function SaveConfig(name)
    local target = name or selectedConfig
    writefile(folderName .. "/" .. target .. ".json", HttpService:JSONEncode(Config))
    if Config.AutoLoad then writefile(lastConfigFile, target) end
end

local function LoadConfig(name)
    local path = folderName .. "/" .. name .. ".json"
    if isfile(path) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if success then 
            Config = data 
            selectedConfig = name
            return true 
        end
    end
    return false
end

local function SendWebhook(rewardTable)
    if Config.WebhookURL == "" or not Config.WebhookURL:find("discord.com") then return end
    
    local fields = {}
    local roundLoot = ""
    for _, item in pairs(rewardTable) do
        if typeof(item) == "Instance" then
            local n = item.Name
            local v = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
            local amt = v and tonumber(v.Value) or 0
            roundLoot = roundLoot .. string.format("🎁 **%s**: %d\n", n, amt)
        end
    end

    table.insert(fields, {["name"] = "─── Runde #"..roundCount.." ───", ["value"] = roundLoot ~= "" and roundLoot or "Nichts", ["inline"] = false})
    
    local totalLoot = ""
    for name, total in pairs(SessionTotals) do
        totalLoot = totalLoot .. string.format("📊 **%s**: %d\n", name, total)
    end
    table.insert(fields, {["name"] = "─── Session Gesamt ───", ["value"] = totalLoot ~= "" and totalLoot or "Nichts", ["inline"] = false})

    pcall(function()
        (request or http_request)({
            Url = Config.WebhookURL:gsub("discord.com", "webhook.lewisakura.moe"),
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = "🏆 Hazeluxe Bericht: " .. Player.Name,
                    color = 0x00FFAA,
                    fields = fields,
                    footer = {text = " V6.8 • " .. os.date("%X")}
                }}
            })
        })
    end)
end

