-- === DRAG FUNKTION ===
local function MakeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    handle.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- === WEBHOOK LOGIK ===
local function SendWebhook(rewardTable)
    if not Config.WebhookURL or Config.WebhookURL == "" or not Config.WebhookURL:find("discord.com") then return end
    
    local fields = {}
    table.insert(fields, {["name"] = "👤 Spieler", ["value"] = "```" .. Player.Name .. "```", ["inline"] = true})
    table.insert(fields, {["name"] = "🎮 Modus", ["value"] = "```" .. Config.UISize .. "```", ["inline"] = true})

    local roundLoot = ""
    for _, item in pairs(rewardTable) do
        if typeof(item) == "Instance" then
            local v = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
            roundLoot = roundLoot .. string.format("🎁 **%s**: %d\n", item.Name, v and tonumber(v.Value) or 1)
        end
    end
    table.insert(fields, {["name"] = "─── Runde #"..roundCount.." ───", ["value"] = roundLoot ~= "" and roundLoot or "Kein Loot", ["inline"] = false})
    
    local totalLoot = ""
    for name, total in pairs(SessionTotals) do
        totalLoot = totalLoot .. string.format("📊 **%s**: %d\n", name, total)
    end
    table.insert(fields, {["name"] = "─── Session Gesamt ───", ["value"] = totalLoot ~= "" and totalLoot or "Nichts", ["inline"] = false})

    task.spawn(function()
        pcall(function()
            (request or http_request or syn.request)({
                Url = Config.WebhookURL:gsub("discord.com", "webhook.lewisakura.moe"),
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    embeds = {{
                        title = "🏆 Hazeluxe Bericht: " .. Player.Name,
                        color = 65535,
                        fields = fields,
                        footer = {text = "V15 • Anti AFK • " .. os.date("%X")}
                    }}
                })
            })
        end)
    end)
end

