function RebuildWorldButtons()
    if not worldBtnFrame then return end
    for _,v in pairs(worldBtnFrame:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end

    -- FIX: WaitForChild mit pcall für sicheres Laden
    local chapterFolder=nil
    pcall(function()
        chapterFolder = Player:WaitForChild("PlayerGui",5)
            :WaitForChild("PlayRoom",5)
            :WaitForChild("Main",5)
            :WaitForChild("GameStage",5)
            :WaitForChild("Main",5)
            :WaitForChild("Base",5)
            :WaitForChild("Chapter",5)
    end)

    if not chapterFolder then
        -- Fallback: hardcoded
        worldStatusLbl.Text="⚠  Fallback (PlayRoom nicht geladen)"; worldStatusLbl.TextColor3=D.Orange
        local fallback={["OnePiece"]="Voocha Village",["Namek"]="Green Planet",["Naruto"]="Leaf Village",["TokyoGhoul"]="Ghoul City",["SAO"]="Virtual Sword",["JJK"]="Tokyo City"}
        for rawN,dispN in pairs(fallback) do
            local modeEntry=nil; for _,m in ipairs(MODES) do if m.id==selectedMode then modeEntry=m; break end end
            local suffix=modeEntry and modeEntry.suffix or "_Chapter1"
            CreateWorldButton(dispN..(selectedMode~="Story" and " ["..selectedMode.."]" or ""), rawN..suffix)
        end
        return
    end

    local children=chapterFolder:GetChildren()
    if #children==0 then worldStatusLbl.Text="⚠  Keine Welten gefunden"; worldStatusLbl.TextColor3=D.Orange; return end

    -- Finde den korrekten Modus-Suffix
    local modeEntry=nil
    for _,m in ipairs(MODES) do if m.id==selectedMode then modeEntry=m; break end end
    local suffix=modeEntry and modeEntry.suffix or "_Chapter1"

    local loaded=0
    for _,child in ipairs(children) do
        local rawName=child.Name   -- z.B. "OnePiece", "JJK"
        local displayName=(WORLD_DISPLAY[rawName] or rawName)
        local modeLabel=selectedMode~="Story" and " ["..selectedMode.."]" or ""
        local chapterId=rawName..suffix   -- z.B. "OnePiece_Chapter1" oder "JJK_Ranger1"
        CreateWorldButton(displayName..modeLabel, chapterId)
        loaded=loaded+1
    end
    worldStatusLbl.Text=string.format("✅  %d Welten  |  Modus: %s", loaded, selectedMode); worldStatusLbl.TextColor3=D.Green
end

