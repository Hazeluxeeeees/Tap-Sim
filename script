task.spawn(function()
    local f = GetChapterFolder()
    if f then
        ScanChapterFolder(f)
        pcall(function()
            H.UI.Lbl.ScanStatus.Text = "✅ " .. #S.WorldIds .. " Welten"
            H.UI.Lbl.ScanStatus.TextColor3 = D.Green
        end)
        S.ChildConn = f.ChildAdded:Connect(function()
            task.wait(0.5); ScanChapterFolder(f)
            pcall(function()
                H.UI.Lbl.ScanStatus.Text = "✅ " .. #S.WorldIds .. " Welten"
                H.UI.Lbl.ScanStatus.TextColor3 = D.Green
            end)
            pcall(RebuildWorldList)
        end)
    else
        ApplyFallback()
        pcall(function()
            H.UI.Lbl.ScanStatus.Text = "⚠ Fallback-Daten"
            H.UI.Lbl.ScanStatus.TextColor3 = D.Orange
        end)
    end
    pcall(RebuildWorldList)
end)

