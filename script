-- ── MODULE 3 & 4: SHOPS & CRAFTING (Auto-Buy & Logic) ────────
local ShopItems = {} 
pcall(function() ShopItems = require(Svc.RS.Shared.Info.ShopItems) end)

local function GetItemAmt(name)
    local amt = 0
    pcall(function()
        local item = Svc.RS.Player_Data[LP.Name].Items:FindFirstChild(name)
        amt = item.Value or item.Amount.Value
    end)
    return amt
end

local function RebuildCraftList()
    if not _G.HazeShared.CraftPage then return end
    _G.HazeShared.CraftPage:ClearAllChildren()
    
    -- Header-Fix: Kein doppelter Name mehr
    local recipes = require(Svc.RS.Shared.Info.CraftingRecipes)
    
    for name, data in pairs(recipes) do
        local card = Instance.new("Frame", _G.HazeShared.CraftPage)
        card.Size = UDim2.new(1, -10, 0, 80)
        card.BackgroundColor3 = D.Card
        
        -- Viewport Asset Integration
        local imgFrame = Instance.new("Frame", card)
        imgFrame.Size = UDim2.new(0, 60, 0, 60)
        imgFrame.Position = UDim2.new(0, 10, 0.5, -30)
        SetupViewport(imgFrame, name)
        
        -- Besitz/Nötig Anzeige & Auto-Buy Check
        local allMet = true
        local statusText = ""
        
        for mat, req in pairs(data.Requirement or {}) do
            local has = GetItemAmt(mat)
            statusText = statusText .. string.format("%d/%d %s, ", has, req, mat)
            if has < req then 
                -- Wenn kaufbar, wird es grün/gelb markiert für Auto-Buy
                if not ShopItems[mat] then allMet = false end
            end
        end
        
        local info = MkLbl(card, name .. "\n" .. statusText, 14)
        info.Position = UDim2.new(0, 80, 0, 10)
        
        if allMet then
            card.BackgroundColor3 = D.Green -- Grün wenn alles bereit (inkl. kaufbarer Items)
        end
    end
end

-- ── ADVANCED AUTO-FARM ENGINE (Queue & Auto-Buy) ──────────────
local function ProcessQueue()
    local currentTask = _G.HazeShared.Queue[1]
    if not currentTask then return end
    
    -- 1. Prüfe ob Item kaufbar ist (Shop-Integration)
    if ShopItems[currentTask.item] then
        _G.HazeShared.Status = "Kaufe " .. currentTask.item
        -- Remote Call für Shop-Kauf
        Svc.RS.Remote.Server.Shop.BuyItem:FireServer(currentTask.item, currentTask.amount)
        table.remove(_G.HazeShared.Queue, 1)
        return
    end
    
    -- 2. Wenn nicht kaufbar -> Normaler Farm-Vorgang
    _G.HazeShared.Status = "Farme " .. currentTask.item
    -- Autofarm Logik...
end

-- Start
task.spawn(function()
    BuildMain()
    UpdateQuests()
    while task.wait(5) do
        if _G.AutoFarmRunning then ProcessQueue() end
    end
end)

