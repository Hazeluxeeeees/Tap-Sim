-- ── Asset-System (Viewport-Fix) ──────────────────────────────
local ITEM_MODELS = Svc.RS:WaitForChild("Assets"):WaitForChild("ItemModels"):WaitForChild("Models")

local function SetupViewport(parent, itemName)
    local vp = Instance.new("ViewportFrame", parent)
    vp.Size = UDim2.new(1, 0, 1, 0)
    vp.BackgroundTransparency = 1
    
    local model = ITEM_MODELS:FindFirstChild(itemName)
    if not model then return vp end
    
    local clone = model:Clone()
    local worldModel = Instance.new("WorldModel", vp)
    clone.Parent = worldModel
    
    local cam = Instance.new("Camera", vp)
    vp.CurrentCamera = cam
    
    -- Zentrierung des Modells (Berechnung der Bounding Box)
    local cf, size = clone:GetBoundingBox()
    local dist = size.Magnitude * 0.8
    cam.CFrame = CFrame.new(cf.Position + Vector3.new(0, size.Y*0.2, dist), cf.Position)
    
    return vp
end

