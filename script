local function SelectTab(name)
    for n, p in pairs(H.Tabs)  do p.Visible = (n == name) end
    for n, b in pairs(H.TBtns) do
        if n == name then
            b.BackgroundColor3 = D.TabActive; b.TextColor3 = D.Cyan
