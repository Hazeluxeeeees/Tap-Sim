local function BuildLogo(parent, sz, lx, ly)
    sz = sz or 32
    local root = Instance.new("Frame", parent)
    root.Size = UDim2.new(0, sz, 0, sz); root.AnchorPoint = Vector2.new(0, 0)
    root.Position = UDim2.new(0, lx or 0, 0, ly or 0)
    root.BackgroundTransparency = 1; root.BorderSizePixel = 0
    local ring = Instance.new("Frame", root); ring.Size = UDim2.new(1, 0, 1, 0)
    ring.BackgroundTransparency = 1; ring.BorderSizePixel = 0; Corner(ring, 99); Stroke(ring, D.Cyan, 1.5, 0.35)
    local bg = Instance.new("Frame", root); bg.Size = UDim2.new(0.84, 0, 0.84, 0)
    bg.Position = UDim2.new(0.08, 0, 0.08, 0); bg.BackgroundColor3 = Color3.fromRGB(0, 15, 38)
    bg.BackgroundTransparency = 0.08; bg.BorderSizePixel = 0; Corner(bg, 99)
    local bgG = Instance.new("UIGradient", bg)
    bgG.Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 38, 85)), ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 8, 28)) })
    bgG.Rotation = 135
    local tk = math.max(2, math.floor(sz*0.18)); local bh = math.floor(sz*0.75)
    local by = math.floor((sz-bh)/2); local bxl = math.floor(sz*0.18); local bxr = sz-bxl-tk
    local function gs() return ColorSequence.new({ ColorSequenceKeypoint.new(0, D.Cyan), ColorSequenceKeypoint.new(0.5, D.Green), ColorSequenceKeypoint.new(1, D.Cyan) }) end
    local bl = Instance.new("Frame", root); bl.Size = UDim2.new(0, tk, 0, bh); bl.Position = UDim2.new(0, bxl, 0, by); bl.BackgroundColor3 = D.Cyan; bl.BorderSizePixel = 0; Corner(bl, 2); Instance.new("UIGradient", bl).Color = gs()
