local function RefreshDrop()
    for _, v in pairs(DropList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, file in pairs(listfiles(folderName)) do
        local name = file:gsub(folderName.."/", ""):gsub(".json", "")
        local B = Instance.new("TextButton", DropList)
        B.Size = UDim2.new(1, 0, 0, 30)
        B.Text = name
        B.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        B.TextColor3 = Color3.new(1,1,1)
        B.MouseButton1Click:Connect(function()
            selectedConfig = name
            DropMain.Text = "Wähle: " .. name
            DropList.Visible = false
        end)
    end
end

