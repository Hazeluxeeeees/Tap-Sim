        end
        local sq={}; local qsf=catFolder:FindFirstChild("Quests")
        if qsf then for _,ch in ipairs(qsf:GetChildren()) do if not ch:IsA("UIGridLayout") and not ch:IsA("UIListLayout") then table.insert(sq,ch) end end
        else
