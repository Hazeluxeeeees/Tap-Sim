-- === EVENTS ===
Remote.OnClientEvent:Connect(function(cat, data)
    if cat == "Rewards - Items" then 
        roundCount = roundCount + 1
        for _, item in pairs(data) do
            if typeof(item) == "Instance" then
                local v = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
                SessionTotals[item.Name] = (SessionTotals[item.Name] or 0) + (v and tonumber(v.Value) or 1)
            end
        end
        UpdateSessionUI()
        SendWebhook(data)
    end
end)

