local function RebuildQuestsUI()
    for _, v in pairs(questContainer:GetChildren()) do
        if v:IsA("Frame") or v:IsA("TextLabel") then v:Destroy() end
    end

    -- ★ Exakter Root-Pfad: RS.Player_Data.[Name].PlayerQuest
    local playerDataRoot = nil
    pcall(function()
        playerDataRoot = Svc.RS:WaitForChild("Player_Data", 3)
            :WaitForChild(Svc.Player.Name, 3)
    end)

    if not playerDataRoot then
        local errLbl = MkLbl(questContainer, "⚠ Player_Data.[" .. Svc.Player.Name .. "] nicht gefunden!", 11, D.Orange)
        errLbl.Size = UDim2.new(1, 0, 0, 28); return
    end

    local playerQuestRoot = nil
    pcall(function()
        playerQuestRoot = playerDataRoot:WaitForChild("PlayerQuest", 3)
    end)

    if not playerQuestRoot then
        local errLbl = MkLbl(questContainer, "⚠ PlayerQuest-Ordner nicht gefunden!", 11, D.Orange)
        errLbl.Size = UDim2.new(1, 0, 0, 28); return
    end

    -- ────────────────────────────────────────────────────────
    --  Easy / Normal / Hard
    --  ★ Ordner-Namen: easy_quest, normal_quest, hard_quest
    --  ★ Kategorie-claimed: [folder].claimed.Value
    --  ★ Sub-Quests im Unterordner .Quests ODER direkt als
    --    easy_quest_1..4 im Kategorieordner
    --  ★ Gesamt-Fortschritt: [folder].progress.Value / [folder].questneed.Value
    -- ────────────────────────────────────────────────────────
    local CATEGORY_DEFS = {
        { folderName = "easy_quest",   label = "EASY QUESTS",   icon = "🟢", color = D.Green  },
        { folderName = "normal_quest", label = "NORMAL QUESTS", icon = "🟡", color = D.Yellow },
        { folderName = "hard_quest",   label = "HARD QUESTS",   icon = "🔴", color = D.Red    },
    }

    for _, catDef in ipairs(CATEGORY_DEFS) do
        local color = catDef.color
        local catFolder = nil
        pcall(function() catFolder = playerQuestRoot:FindFirstChild(catDef.folderName) end)

        -- Card für diese Kategorie
        local catCard = Card(questContainer); Pad(catCard, 10, 12, 10, 12); VList(catCard, 6)
        Stroke(catCard, color, 1.5, 0.3)

        -- Header
        local hLbl = Instance.new("TextLabel", catCard)
        hLbl.Size = UDim2.new(1, 0, 0, 22); hLbl.BackgroundTransparency = 1
        hLbl.Text = catDef.icon .. "  " .. catDef.label
        hLbl.TextColor3 = color; hLbl.TextSize = 12; hLbl.Font = Enum.Font.GothamBold
        hLbl.TextXAlignment = Enum.TextXAlignment.Left

        if not catFolder then
            MkLbl(catCard, "Ordner '" .. catDef.folderName .. "' nicht gefunden.", 10, D.TextLow).Size = UDim2.new(1, 0, 0, 18)
            continue
        end

        -- ★ Kategorie komplett claimed?
        local catClaimed = false
        pcall(function()
            local cl = catFolder:FindFirstChild("claimed")
            if cl and cl.Value == true then catClaimed = true end
        end)

        -- ★ Gesamt-Fortschritt der Kategorie
        local catProgress, catNeed = 0, 1
        pcall(function()
            local pg = catFolder:FindFirstChild("progress")
            local nd = catFolder:FindFirstChild("questneed")
            if pg then catProgress = tonumber(pg.Value) or 0 end
            if nd then catNeed     = tonumber(nd.Value) or 1 end
        end)

        -- Fortschrittsbalken der Kategorie (immer anzeigen)
        local catPct = math.min(1, catProgress / math.max(1, catNeed))
        local catProgRow = Instance.new("Frame", catCard)
        catProgRow.Size = UDim2.new(1, 0, 0, 18); catProgRow.BackgroundTransparency = 1; HList(catProgRow, 6)
        local catProgTxt = Instance.new("TextLabel", catProgRow)
        catProgTxt.Size = UDim2.new(0.55, 0, 1, 0); catProgTxt.BackgroundTransparency = 1
        catProgTxt.Text = string.format("Gesamt: %d / %d", catProgress, catNeed)
        catProgTxt.TextColor3 = catClaimed and D.GreenBright or D.TextMid
        catProgTxt.TextSize = 10; catProgTxt.Font = Enum.Font.GothamSemibold
        catProgTxt.TextXAlignment = Enum.TextXAlignment.Left
        local catBarBg = Instance.new("Frame", catProgRow)
        catBarBg.Size = UDim2.new(0.45, 0, 0, 6); catBarBg.BackgroundColor3 = Color3.fromRGB(20,28,50)
        catBarBg.BorderSizePixel = 0; Corner(catBarBg, 3)
        local catBarFill = Instance.new("Frame", catBarBg)
        catBarFill.Size = UDim2.new(catPct, 0, 1, 0)
        catBarFill.BackgroundColor3 = catClaimed and D.GreenBright or color
        catBarFill.BorderSizePixel = 0; Corner(catBarFill, 3)

        if catClaimed then
            local doneFr = Instance.new("Frame", catCard)
            doneFr.Size = UDim2.new(1, 0, 0, 30); doneFr.BackgroundColor3 = D.GreenDark
            doneFr.BorderSizePixel = 0; Corner(doneFr, 7); Stroke(doneFr, D.GreenBright, 1.5, 0.2)
            local dLbl = Instance.new("TextLabel", doneFr)
            dLbl.Size = UDim2.new(1, 0, 1, 0); dLbl.BackgroundTransparency = 1
            dLbl.Text = "✅ ALLE BELOHNUNGEN ABGEHOLT!"; dLbl.TextColor3 = D.GreenBright
            dLbl.TextSize = 12; dLbl.Font = Enum.Font.GothamBold
            dLbl.TextXAlignment = Enum.TextXAlignment.Center
            continue
        end

        -- ★ Sub-Quests: suche erst im Unterordner "Quests", dann direkt [name]_1..4
        local subQuests = {}
        local questsSubfolder = catFolder:FindFirstChild("Quests")
        if questsSubfolder then
            -- Unterordner .Quests vorhanden → alle Kinder scannen
            for _, ch in ipairs(questsSubfolder:GetChildren()) do
                if not ch:IsA("UIGridLayout") and not ch:IsA("UIListLayout") then
                    table.insert(subQuests, ch)
                end
            end
        else
            -- Direkt im Kategorieordner: z.B. easy_quest_1 .. easy_quest_4
            for i = 1, 4 do
                local qf = catFolder:FindFirstChild(catDef.folderName .. "_" .. i)
                if qf then table.insert(subQuests, qf) end
            end
            -- Fallback: alle Folder-Kinder außer claimed/progress/questneed
            if #subQuests == 0 then
                local SKIP = { claimed=true, progress=true, questneed=true, Quests=true }
                for _, ch in ipairs(catFolder:GetChildren()) do
                    if not SKIP[ch.Name] then
                        table.insert(subQuests, ch)
                    end
                end
            end
        end

        if #subQuests == 0 then
            MkLbl(catCard, "Keine Sub-Quests gefunden.", 10, D.TextLow).Size = UDim2.new(1, 0, 0, 18)
        else
            -- Sub-Quests sortiert nach Name
            table.sort(subQuests, function(a, b) return a.Name < b.Name end)
            for _, sqFolder in ipairs(subQuests) do
                local sqClaimed = false
                pcall(function()
                    local cl = sqFolder:FindFirstChild("claimed")
                    if cl and cl.Value == true then sqClaimed = true end
                end)
                local des = GetQuestDes(sqFolder)
                local prog, need = GetQuestProgress(sqFolder)
                BuildQuestRow(catCard, sqFolder.Name, des, prog, need, sqClaimed, color)
            end
        end
    end

    -- ────────────────────────────────────────────────────────
    --  Weekly Quests
    --  ★ Pfad: RS.Player_Data.[Name].WeeklyQuest
    --  ★ claimed == true → Quest komplett ausblenden
    -- ────────────────────────────────────────────────────────
    do
        local weeklyRoot = nil
        pcall(function()
            weeklyRoot = playerDataRoot:FindFirstChild("WeeklyQuest")
        end)

        local wCard = Card(questContainer); Pad(wCard, 10, 12, 10, 12); VList(wCard, 6)
        Stroke(wCard, D.Purple, 1.5, 0.3)

        local wHdr = Instance.new("TextLabel", wCard)
        wHdr.Size = UDim2.new(1, 0, 0, 22); wHdr.BackgroundTransparency = 1
        wHdr.Text = "🟣  WEEKLY QUESTS"; wHdr.TextColor3 = D.Purple
        wHdr.TextSize = 12; wHdr.Font = Enum.Font.GothamBold
        wHdr.TextXAlignment = Enum.TextXAlignment.Left

        if not weeklyRoot then
            MkLbl(wCard, "WeeklyQuest nicht gefunden unter Player_Data." .. Svc.Player.Name, 10, D.TextLow).Size = UDim2.new(1, 0, 0, 18)
        else
            local wFound = false
            local SKIP_W = { claimed=true, progress=true, questneed=true }
            for _, qFolder in ipairs(weeklyRoot:GetChildren()) do
                if SKIP_W[qFolder.Name] then continue end
                -- ★ claimed == true → Quest komplett nicht anzeigen
                local isClaimed = false
                pcall(function()
                    local cl = qFolder:FindFirstChild("claimed")
                    if cl and cl.Value == true then isClaimed = true end
                end)
                if isClaimed then continue end
                -- Titel = Ordnername, des = Attribut, Balken aus progress/questneed
                local des = GetQuestDes(qFolder)
                local prog, need = GetQuestProgress(qFolder)
                BuildQuestRow(wCard, qFolder.Name, des, prog, need, false, D.Purple)
                wFound = true
            end
            if not wFound then
                local allDoneFr = Instance.new("Frame", wCard)
                allDoneFr.Size = UDim2.new(1, 0, 0, 28); allDoneFr.BackgroundColor3 = D.GreenDark
                allDoneFr.BorderSizePixel = 0; Corner(allDoneFr, 7); Stroke(allDoneFr, D.GreenBright, 1.5, 0.2)
                local dL = Instance.new("TextLabel", allDoneFr); dL.Size = UDim2.new(1,0,1,0); dL.BackgroundTransparency=1
                dL.Text = "✅ Alle Weekly Quests erledigt!"; dL.TextColor3 = D.GreenBright
                dL.TextSize = 11; dL.Font = Enum.Font.GothamBold; dL.TextXAlignment = Enum.TextXAlignment.Center
            end
        end
    end

    -- ────────────────────────────────────────────────────────
    --  Daily Quests
    --  ★ Pfad: RS.Player_Data.[Name].DailyQuest
    --  ★ claimed == true → Quest komplett ausblenden
    -- ────────────────────────────────────────────────────────
    do
        local dailyRoot = nil
        pcall(function()
            dailyRoot = playerDataRoot:FindFirstChild("DailyQuest")
        end)

        local dCard = Card(questContainer); Pad(dCard, 10, 12, 10, 12); VList(dCard, 6)
        Stroke(dCard, D.Teal, 1.5, 0.3)

        local dHdr = Instance.new("TextLabel", dCard)
        dHdr.Size = UDim2.new(1, 0, 0, 22); dHdr.BackgroundTransparency = 1
        dHdr.Text = "🔵  DAILY QUESTS"; dHdr.TextColor3 = D.Teal
        dHdr.TextSize = 12; dHdr.Font = Enum.Font.GothamBold
        dHdr.TextXAlignment = Enum.TextXAlignment.Left

        if not dailyRoot then
            MkLbl(dCard, "DailyQuest nicht gefunden unter Player_Data." .. Svc.Player.Name, 10, D.TextLow).Size = UDim2.new(1, 0, 0, 18)
        else
            local dFound = false
            local SKIP_D = { claimed=true, progress=true, questneed=true }
            for _, qFolder in ipairs(dailyRoot:GetChildren()) do
                if SKIP_D[qFolder.Name] then continue end
                -- ★ claimed == true → Quest komplett nicht anzeigen
                local isClaimed = false
                pcall(function()
                    local cl = qFolder:FindFirstChild("claimed")
                    if cl and cl.Value == true then isClaimed = true end
                end)
                if isClaimed then continue end
                local des = GetQuestDes(qFolder)
                local prog, need = GetQuestProgress(qFolder)
                BuildQuestRow(dCard, qFolder.Name, des, prog, need, false, D.Teal)
                dFound = true
            end
            if not dFound then
                local allDoneFr = Instance.new("Frame", dCard)
                allDoneFr.Size = UDim2.new(1, 0, 0, 28); allDoneFr.BackgroundColor3 = D.GreenDark
                allDoneFr.BorderSizePixel = 0; Corner(allDoneFr, 7); Stroke(allDoneFr, D.GreenBright, 1.5, 0.2)
                local dL = Instance.new("TextLabel", allDoneFr); dL.Size = UDim2.new(1,0,1,0); dL.BackgroundTransparency=1
                dL.Text = "✅ Alle Daily Quests erledigt!"; dL.TextColor3 = D.GreenBright
                dL.TextSize = 11; dL.Font = Enum.Font.GothamBold; dL.TextXAlignment = Enum.TextXAlignment.Center
            end
        end
    end
end

