local function FmtDur(s)
    local h=math.floor(s/3600);local m=math.floor((s%3600)/60);local sec=s%60
    if h>0 then return string.format("%dh %02dm %02ds",h,m,sec)
    else return string.format("%dm %02ds",m,sec) end
end

