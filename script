local function RefreshPlayerStats()
    -- ★ XP aus HUD: Pfad PlayerGui.HUD.ExpBar.Numbers.ContentText
    pcall(function()
        local hudText = nil
        pcall(function()
            hudText = Svc.Player.PlayerGui.HUD.ExpBar.Numbers.ContentText
        end)
        if hudText and hudText ~= "" then
            H.UI.Lbl.XPText.Text = hudText
            H.UI.Lbl.XPText.TextColor3 = D.Cyan
            -- Parse z.B. "Level 106 [3,650/10,600XP]"
            local curXP, maxXP = hudText:match("(%d[%d,]+)/(%d[%d,]+)XP")
            if not curXP then curXP, maxXP = hudText:match("%[(%d[%d,]+)/(%d[%d,]+)") end
            if not curXP then curXP, maxXP = hudText:match("(%d[%d,]+)/(%d[%d,]+)") end
            if curXP and maxXP then
                local c = tonumber(curXP:gsub(",","")) or 0
                local m = tonumber(maxXP:gsub(",","")) or 1
                local pct = math.min(1, c / math.max(1, m))
                Tw(H.UI.Fr.XPBarFill, { Size = UDim2.new(pct, 0, 1, 0) }, TM)
            end
        else
            H.UI.Lbl.XPText.Text = "HUD XP nicht verfügbar"
            H.UI.Lbl.XPText.TextColor3 = D.TextLow
        end
    end)

    -- ★ Level aus RS.Player_Data.[Name].Data
    pcall(function()
        local dataFolder = Svc.RS:WaitForChild("Player_Data", 3)
            :WaitForChild(Svc.Player.Name, 3)
            :WaitForChild("Data", 3)
        local lvlChild    = dataFolder:FindFirstChild("Level")
        local expChild    = dataFolder:FindFirstChild("Exp")
        local maxExpChild = dataFolder:FindFirstChild("MaxExp")
        local lvl    = lvlChild    and lvlChild.Value    or nil
        local exp    = expChild    and expChild.Value    or nil
        local maxExp = maxExpChild and maxExpChild.Value or nil
        if lvl then
            local lvlTxt = "Level " .. tostring(lvl)
            if exp and maxExp then
                lvlTxt = lvlTxt .. "  (" .. FmtNum(exp) .. " / " .. FmtNum(maxExp) .. " XP)"
                local pct = math.min(1, (tonumber(exp) or 0) / math.max(1, tonumber(maxExp) or 1))
                Tw(H.UI.Fr.XPBarFill, { Size = UDim2.new(pct, 0, 1, 0) }, TM)
            end
            H.UI.Lbl.PlayerLevel.Text = lvlTxt
        else
            H.UI.Lbl.PlayerLevel.Text = "–"
        end
    end)

    -- ★ Upgrade Stats – exakte Pfade laut Spec
    --   Aktueller Wert : RS.Player_Data.[Name].Stats.[key].Value
    --   Level-Text     : PlayerGui.PlayerStats.Main.[key].Frame.Level.ContentText
    --   Kosten-Text    : PlayerGui.PlayerStats.Main.[key].Frame.Cost.Numbers.ContentText
    for _, statDef in ipairs(UPGRADE_STATS) do
        pcall(function()
            local lbls = H.UI.Lbl.UpgradeStats[statDef.key]
            if not lbls then return end

            -- Aktueller Stat-Wert aus RS
            local statVal = nil
            pcall(function()
                statVal = Svc.RS:WaitForChild("Player_Data", 3)
                    :WaitForChild(Svc.Player.Name, 3)
                    :WaitForChild("Stats", 3)
                    :WaitForChild(statDef.key, 3).Value
            end)

            -- Level-Text aus PlayerGui (.ContentText)
            local lvlTxt = nil
            pcall(function()
                lvlTxt = Svc.Player.PlayerGui.PlayerStats.Main[statDef.key].Frame.Level.ContentText
            end)

            -- Kosten-Text aus PlayerGui (.ContentText)
            local costTxt = nil
            pcall(function()
                costTxt = Svc.Player.PlayerGui.PlayerStats.Main[statDef.key].Frame.Cost.Numbers.ContentText
            end)

            -- Level-Label aufbauen
            if lvlTxt and lvlTxt ~= "" then
                if lvlTxt:find("MAX") or lvlTxt:find("max") then
                    lbls.level.Text = "✅ MAX"
                    lbls.level.TextColor3 = D.GreenBright
                else
                    -- Stat-Wert anhängen wenn verfügbar
                    local valStr = statVal ~= nil and ("  [" .. FmtNum(statVal) .. "]") or ""
                    lbls.level.Text = "Lv. " .. lvlTxt .. valStr
                    lbls.level.TextColor3 = D.TextMid
                end
            elseif statVal ~= nil then
                lbls.level.Text = "Wert: " .. FmtNum(statVal)
                lbls.level.TextColor3 = D.TextMid
            else
                lbls.level.Text = "Lv. –"
                lbls.level.TextColor3 = D.TextLow
            end

            -- Kosten-Label
            if costTxt and costTxt ~= "" then
                lbls.cost.Text = "💰 " .. costTxt
                lbls.cost.TextColor3 = D.Gold
            else
                lbls.cost.Text = "–"
                lbls.cost.TextColor3 = D.TextLow
            end

            -- ★ Gold bis Max Berechnung
            if lbls.gold then
                local curLvl = nil
                if lvlTxt then
                    -- Versuche Zahl aus Level-Text zu parsen (z.B. "5", "Level 5", "5/50")
                    curLvl = tonumber(lvlTxt:match("(%d+)")) or nil
                end
                local isMax = lvlTxt and (lvlTxt:find("MAX") or lvlTxt:find("max"))
                if isMax then
                    lbls.gold.Text = "🪙 Gold bis Max: bereits MAX"
                    lbls.gold.TextColor3 = D.GreenBright
                elseif curLvl then
                    local goldNeeded = 0
                    if statDef.key == "YenGenarate" then
                        -- Max LVL 50, konstant 500 Gold pro Upgrade
                        local remaining = math.max(0, 50 - curLvl)
                        goldNeeded = remaining * 500
                    elseif statDef.key == "YenMax" then
                        -- Max LVL 100, erstes Upgrade kostet 250, jedes weitere +250
                        -- Upgrade von LVL n auf n+1 kostet: n * 250
                        -- Gesamt von curLvl bis 100: Summe(n * 250, n = curLvl..99)
                        for n = curLvl, 99 do
                            goldNeeded = goldNeeded + (n * 250)
                        end
                    elseif statDef.key == "BaseHealth" then
                        -- Max LVL 100, erstes Upgrade kostet 200, jedes weitere +200
                        -- Upgrade von LVL n auf n+1 kostet: n * 200
                        for n = curLvl, 99 do
                            goldNeeded = goldNeeded + (n * 200)
                        end
                    end
                    lbls.gold.Text = "🪙 Gold bis Max: " .. FmtNum(goldNeeded)
                    lbls.gold.TextColor3 = goldNeeded == 0 and D.GreenBright or D.TextLow
                else
                    lbls.gold.Text = "🪙 Gold bis Max: –"
                    lbls.gold.TextColor3 = D.TextLow
                end
            end
        end)
    end
end

