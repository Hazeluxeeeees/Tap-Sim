local function UpdateSession()
    for _, v in pairs(SessionPage:GetChildren()) do if not v:IsA("UIListLayout") then v:Destroy() end end
    local L = Instance.new("TextLabel", SessionPage); L.Size = UDim2.new(1,0,0,30); L.Text = "Runden: "..roundCount; L.TextColor3 = Color3.new(1,0.8,0); L.BackgroundTransparency = 1
    for name, amt in pairs(SessionTotals) do
        local F = Instance.new("Frame", SessionPage); F.Size = UDim2.new(1,-10,0,35); F.BackgroundColor3 = Color3.fromRGB(35,50,40); Instance.new("UICorner", F)
        local T = Instance.new("TextLabel", F); T.Size = UDim2.new(1,-10,1,0); T.Position = UDim2.new(0,10,0,0); T.Text = name..": "..amt; T.TextColor3 = Color3.new(0,1,0.6); T.BackgroundTransparency = 1; T.TextXAlignment = Enum.TextXAlignment.Left
    end
end

-- Reward Listener
Remote.OnClientEvent:Connect(function(cat, data)
    if cat == "Rewards - Items" then 
        roundCount = roundCount + 1
        for _, item in pairs(data) do
            if typeof(item) == "Instance" then
                local n = item.Name
                local v = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
                local amt = v and tonumber(v.Value) or 0
                SessionTotals[n] = (SessionTotals[n] or 0) + amt
            end
        end
        UpdateSession()
        SendWebhook(data)
    end
end)

