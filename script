-- ============================================================
--  WEBHOOK
-- ============================================================
local function SendWebhook(rewardTable, goalItem, goalAmt)
    if not S.WhEnabled then return end
    if not H.Config.WebhookURL or H.Config.WebhookURL == ""
    or not H.Config.WebhookURL:find("discord.com") then return end
    local rReal = {}; local rTotal = 0
    for _, item in pairs(rewardTable or {}) do
        if typeof(item) == "Instance" then
            local v = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
            local a = v and tonumber(v.Value) or 1
            if not K.INFO[item.Name] then
                rTotal = rTotal + a
                table.insert(rReal, { name = item.Name, amt = a, rare = K.RARE[item.Name] == true })
            end
        end
    end
    local sItems, sTotal = {}, 0
    for name, t in pairs(S.SessTotals) do sTotal = sTotal + t; table.insert(sItems, { name = name, total = t }) end
    table.sort(sItems, function(a, b) return a.total > b.total end)
    local rTxt = #rReal == 0 and "> *Kein Loot*" or ""
    for _, i in ipairs(rReal) do rTxt = rTxt .. string.format("%s**%s** `×%d`\n", i.rare and "💎 " or "› ", i.name, i.amt) end
    local sTxt = ""
    for i, it in ipairs(sItems) do
        if i > 8 then sTxt = sTxt .. string.format("\n*+%d weitere*", #sItems-8); break end
        local fill = math.min(8, math.ceil(it.total / math.max(1, sTotal/40)))
        sTxt = sTxt .. string.format("`%s%s`  **%s** %d\n", ("█"):rep(fill), ("░"):rep(8-fill), it.name, it.total)
    end
    if sTxt == "" then sTxt = "> *–*" end
    local dur = FmtDur(os.time() - S.SessStart)
    local ava = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. tostring(Svc.Player.UserId) .. "&width=150&height=150&format=png"
    local isGoal = goalItem ~= nil
    local embed = {
        color  = isGoal and 0x00FF7A or 0x00C8FF,
        author = { name = "⚡  HazeHUB V19", icon_url = "https://www.roblox.com/favicon.ico" },
        title  = (isGoal and "🎯  ZIEL ERREICHT!  " or "🏆  ") .. string.format("%s · Runde #%d", Svc.Player.Name, S.RoundCount),
        url    = "https://www.roblox.com/users/" .. tostring(Svc.Player.UserId) .. "/profile",
        thumbnail = { url = ava },
        fields = {
            { name = "👤 Spieler", value = "```" .. Svc.Player.Name .. "```", inline = true },
            { name = "🔢 Runde",   value = "```#" .. S.RoundCount .. "```",   inline = true },
            { name = "⏱ Session", value = "`" .. dur .. "`",                  inline = true },
            { name = "🎁 Loot",   value = rTxt,                               inline = false },
            { name = "📊 Gesamt", value = sTxt,                               inline = false },
        },
        footer    = { text = "HazeHUB V19 · " .. dur, icon_url = "https://www.roblox.com/favicon.ico" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }
    if isGoal then
        table.insert(embed.fields, 2, {
            name  = "🎯 Ziel erreicht",
            value = string.format("**%s**: `%d / %d` ✅", goalItem, goalAmt, goalAmt),
            inline = false,
        })
    end
    task.spawn(function() pcall(function()
        local fn = request or http_request or (syn and syn.request)
        if not fn then return end
        fn({ Url = H.Config.WebhookURL:gsub("discord%.com", "webhook.lewisakura.moe"),
             Method = "POST", Headers = { ["Content-Type"] = "application/json" },
             Body = Svc.Http:JSONEncode({ embeds = { embed } }) })
    end) end)
end

