local function Pad(p,pt,pr,pb,pl)
    local u=Instance.new("UIPadding",p)
    u.PaddingTop=UDim.new(0,pt or 6); u.PaddingRight=UDim.new(0,pr or 6)
    u.PaddingBottom=UDim.new(0,pb or 6); u.PaddingLeft=UDim.new(0,pl or 6)
