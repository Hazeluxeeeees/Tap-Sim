        local prog = questFolder:FindFirstChild("progress")
        local need = questFolder:FindFirstChild("questneed")
        if prog then progress  = tonumber(prog.Value)  or 0 end
        if need then questneed = tonumber(need.Value) or 1 end
    end)
    return progress, questneed
end

-- Hilfsfunktion: Quest-Row bauen
local function BuildQuestRow(parent, title, des, progress, questneed, isClaimed, accentColor)
    local pct = math.min(1, progress / math.max(1, questneed))
    local rowH = (des and des ~= "") and 60 or 44
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, 0, 0, rowH); row.BorderSizePixel = 0; Corner(row, 8)
    if isClaimed then
        row.BackgroundColor3 = Color3.fromRGB(0, 35, 18); Stroke(row, D.GreenBright, 1, 0.3)
    else
        row.BackgroundColor3 = D.CardHover; Stroke(row, accentColor or D.Cyan, 1, 0.55)
    end

    local acBar = Instance.new("Frame", row)
    acBar.Size = UDim2.new(0, 3, 0.7, 0); acBar.Position = UDim2.new(0, 0, 0.15, 0)
    acBar.BackgroundColor3 = isClaimed and D.GreenBright or (accentColor or D.Cyan)
    acBar.BorderSizePixel = 0; Corner(acBar, 2)

    local titleLbl = Instance.new("TextLabel", row)
    titleLbl.Position = UDim2.new(0, 10, 0, 4); titleLbl.Size = UDim2.new(1, -14, 0, 16)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = (isClaimed and "✅ " or "") .. title
    titleLbl.TextColor3 = isClaimed and D.GreenBright or D.TextHi
    titleLbl.TextSize = 11; titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left; titleLbl.TextTruncate = Enum.TextTruncate.AtEnd

    if des and des ~= "" then
        local desLbl = Instance.new("TextLabel", row)
        desLbl.Position = UDim2.new(0, 10, 0, 20); desLbl.Size = UDim2.new(1, -14, 0, 14)
        desLbl.BackgroundTransparency = 1; desLbl.Text = des
        desLbl.TextColor3 = D.TextLow; desLbl.TextSize = 9; desLbl.Font = Enum.Font.Gotham
        desLbl.TextXAlignment = Enum.TextXAlignment.Left; desLbl.TextTruncate = Enum.TextTruncate.AtEnd
    end

    local progressY = (des and des ~= "") and -6 or -5
    local pgBg = Instance.new("Frame", row)
    pgBg.Size = UDim2.new(1, -14, 0, 4); pgBg.Position = UDim2.new(0, 10, 1, progressY)
    pgBg.BackgroundColor3 = Color3.fromRGB(20, 28, 50); pgBg.BorderSizePixel = 0; Corner(pgBg, 2)
    local pgF = Instance.new("Frame", pgBg)
    pgF.Size = UDim2.new(pct, 0, 1, 0); pgF.BackgroundColor3 = isClaimed and D.GreenBright or (accentColor or D.Cyan)
    pgF.BorderSizePixel = 0; Corner(pgF, 2)

    local pctLbl = Instance.new("TextLabel", row)
    pctLbl.Position = UDim2.new(1, -50, 0, 4); pctLbl.Size = UDim2.new(0, 44, 0, 16)
    pctLbl.BackgroundTransparency = 1
    pctLbl.Text = string.format("%d/%d", progress, questneed)
    pctLbl.TextColor3 = isClaimed and D.GreenBright or D.TextLow
    pctLbl.TextSize = 9; pctLbl.Font = Enum.Font.GothamSemibold
    pctLbl.TextXAlignment = Enum.TextXAlignment.Right

    return row
end

