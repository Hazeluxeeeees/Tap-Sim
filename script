            local df=Instance.new("Frame",catCard); df.Size=UDim2.new(1,0,0,30); df.BackgroundColor3=D.GreenDark; df.BorderSizePixel=0; Corner(df,7); Stroke(df,D.GreenBright,1.5,0.2)
