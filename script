local function SelectTab(name)
    for n,p in pairs(Haze.Tabs) do p.Visible=(n==name) end
    for n,b in pairs(Haze.TBtns) do
        if n==name then
            b.BackgroundColor3=D.TabActive;b.TextColor3=D.Cyan
            local s=b:FindFirstChildOfClass("UIStroke");if s then s.Transparency=0 end
        else
            b.BackgroundColor3=D.TabInactive;b.TextColor3=D.TextMid
            local s=b:FindFirstChildOfClass("UIStroke");if s then s.Transparency=1 end
        end
    end
    Haze.State.ActiveTab=name
end

local function MakeTab(name,icon)
    local B=Instance.new("TextButton",Haze.UI.Fr.TabHolder)
    B.Size=UDim2.new(1,0,0,30);B.BackgroundColor3=D.TabInactive
    B.Text=icon.."  "..name;B.TextColor3=D.TextMid;B.TextSize=10
    B.Font=Enum.Font.GothamSemibold;B.AutoButtonColor=false;B.BorderSizePixel=0
    Corner(B,7);Stroke(B,D.Cyan,1,1)
    B.MouseEnter:Connect(function()
        if Haze.State.ActiveTab~=name then Tw(B,{BackgroundColor3=D.CardHover}) end
    end)
    B.MouseLeave:Connect(function()
        if Haze.State.ActiveTab~=name then Tw(B,{BackgroundColor3=D.TabInactive}) end
    end)
    local P=Instance.new("ScrollingFrame",Haze.UI.Fr.Content)
    P.Name=name;P.Size=UDim2.new(1,0,1,0);P.Visible=false
    P.BackgroundTransparency=1;P.ScrollBarThickness=3
    P.ScrollBarImageColor3=D.CyanDim;P.AutomaticCanvasSize=Enum.AutomaticSize.Y
    P.BorderSizePixel=0;VList(P,8);Pad(P,10,10,10,10)
    Haze.Tabs[name]=P;Haze.TBtns[name]=B
    B.MouseButton1Click:Connect(function() SelectTab(name) end)
    return P
end

