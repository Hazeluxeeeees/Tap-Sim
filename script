-- ============================================================
--  GAME EVENTS
-- ============================================================
if R.Remote then
    R.Remote.OnClientEvent:Connect(function(cat, data)
        if cat == "GameEnded_TextAnimation" and data == "Won" then
            if H.Config.AutoRetry then FireVoteRetry() end; return
        end
        if cat == "Rewards - Items" then
            S.RoundCount = S.RoundCount + 1
            for _, item in pairs(data) do
                if typeof(item) == "Instance" then
                    local v = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
                    local amt = v and tonumber(v.Value) or 1
                    if K.INFO[item.Name] then S.InfoTotals[item.Name] = (S.InfoTotals[item.Name] or 0) + amt
                    else S.SessTotals[item.Name] = (S.SessTotals[item.Name] or 0) + amt end
                end
            end
            UpdateSessionUI(); CheckAllGoals(); SendWebhook(data, nil, nil)
        end
    end)
end

