-- ============================================================
local function CheckAllGoals()
    local S=Haze.State
    for _,g in ipairs(S.Goals) do
        if not g.reached and not S.GoalsNotified[g.item] then
            local cur=math.max(S.SessionTotals[g.item] or 0, GetInvAmt(g.item))
            if cur>=g.amount then
                g.reached=true;S.GoalsNotified[g.item]=true
                task.spawn(function() SendWebhook({},g.item,cur) end)
                SaveConfig()
            end
        end
    end
    if UpdateGoalsUI then pcall(UpdateGoalsUI) end
end

