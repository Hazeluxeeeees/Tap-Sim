local function CheckGoal()
    if goalReached then return end
    if Config.GoalItem=="" or Config.GoalAmount<=0 then return end
    local cur=SessionTotals[Config.GoalItem] or InfoTotals[Config.GoalItem] or 0
    if cur>=Config.GoalAmount then goalReached=true; Config.AutoRetry=false; SaveConfig(); UpdateAutoRetryUI(); SendWebhook({},true); UpdateSessionUI() end
end

