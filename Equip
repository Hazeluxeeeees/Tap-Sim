local rebuildSetList  -- forward-declare

rebuildSetList = function(filter)
    filter = (filter or ""):lower():match("^%s*(.-)%s*$")  -- trimmen + lowercase
    local useFilter = filter ~= ""

    -- Alte Einträge löschen
    for _, v in pairs(setListScroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    -- Einheiten mit Sets sammeln, alphabetisch nach DisplayName
    local unitKeys = {}
    for tag, sets in pairs(EquipSets) do
        if type(sets) == "table" and next(sets) ~= nil then
            -- DisplayName aus gespeichertem Eintrag oder live ermitteln
            local displayName = "?"
            for _, sd in pairs(sets) do
                if sd.DisplayName and sd.DisplayName ~= "" then
                    displayName = sd.DisplayName; break
                end
            end
            if displayName == "?" then
                -- Fallback: aus Collection
                local folder = getUnitByTag(tag)
                if folder then displayName = getDisplayName(folder.Name)
                else displayName = "Tag:" .. tag end
            end
            -- ★ Stage-Filter: Einheit nur anzeigen wenn mindestens ein Set passt
            local stageMatch = false
            if _activeStage == "" then
                stageMatch = true  -- "Alle anzeigen"
            else
                for _, sd in pairs(sets) do
                    if sd.Stage == _activeStage then stageMatch = true; break end
                end
            end
            -- ★ Stage-Filter: Einheit nur aufnehmen wenn DisplayName den Suchbegriff enthält
            if not useFilter or displayName:lower():find(filter, 1, true) then
                if stageMatch then
                    local setCount = 0; for _ in pairs(sets) do setCount = setCount + 1 end
                    table.insert(unitKeys, { tag=tag, displayName=displayName, setCount=setCount })
                end
            end
        end
    end

    local hasAny = #unitKeys > 0
    setsEmptyLbl.Visible = not hasAny
    if not hasAny then return end

    table.sort(unitKeys, function(a,b) return a.displayName < b.displayName end)

    for _, unitInfo in ipairs(unitKeys) do
        local tag         = unitInfo.tag
        local displayName = unitInfo.displayName
        local sets        = EquipSets[tag]
        local isExpanded  = _expanded[tag] == true

        -- ── Einheits-Header ─────────────────────────────────
        local headerFrame = Instance.new("Frame", setListScroll)
        headerFrame.Size = UDim2.new(1,0,0,38)
        headerFrame.BackgroundColor3 = Color3.fromRGB(28,28,32)
        headerFrame.BackgroundTransparency = 0.1
        headerFrame.BorderSizePixel = 0
        Corner(headerFrame, 7)
        Stroke(headerFrame, D.Cyan, 1, isExpanded and 0.2 or 0.55)

        -- Farbstreifen links (Cyan wenn expanded)
        local stripe = Instance.new("Frame", headerFrame)
        stripe.Size=UDim2.new(0,4,1,0); stripe.BackgroundColor3= isExpanded and D.Cyan or D.AccentDim
        stripe.BackgroundTransparency=0.3; stripe.BorderSizePixel=0; Corner(stripe,3)

        -- Pfeil-Indikator
        local arrowLbl = Instance.new("TextLabel", headerFrame)
        arrowLbl.Position=UDim2.new(0,10,0.5,-8); arrowLbl.Size=UDim2.new(0,16,0,16)
        arrowLbl.BackgroundTransparency=1; arrowLbl.Text= isExpanded and "▼" or "▶"
        arrowLbl.TextColor3= isExpanded and D.Cyan or D.TextMid
        arrowLbl.TextSize=11; arrowLbl.Font=Enum.Font.GothamBold
        arrowLbl.TextXAlignment=Enum.TextXAlignment.Center
        arrowLbl.TextScaled=false; arrowLbl.RichText=true; arrowLbl.TextStrokeTransparency=1

        -- Einheits-Name
        local unitNameLbl = Instance.new("TextLabel", headerFrame)
        unitNameLbl.Position=UDim2.new(0,30,0,4); unitNameLbl.Size=UDim2.new(1,-90,0,18)
        unitNameLbl.BackgroundTransparency=1; unitNameLbl.Text=displayName
        unitNameLbl.TextColor3= isExpanded and D.Cyan or D.TextHi
        unitNameLbl.TextSize=13; unitNameLbl.Font=Enum.Font.GothamBold
        unitNameLbl.TextXAlignment=Enum.TextXAlignment.Left; unitNameLbl.TextTruncate=Enum.TextTruncate.AtEnd
        unitNameLbl.TextScaled=false; unitNameLbl.RichText=true; unitNameLbl.TextStrokeTransparency=1

        -- Set-Anzahl Badge
        local countBadge = Instance.new("TextLabel", headerFrame)
        countBadge.Size=UDim2.new(0,40,0,20); countBadge.Position=UDim2.new(1,-46,0.5,-10)
        countBadge.BackgroundColor3=isExpanded and D.Cyan or D.CardHover
        countBadge.BackgroundTransparency=isExpanded and 0.2 or 0.4
        countBadge.Text=tostring(unitInfo.setCount) .. " Sets"
        countBadge.TextColor3=isExpanded and D.BG or D.TextMid
        countBadge.TextSize=9; countBadge.Font=Enum.Font.GothamBold
        countBadge.TextXAlignment=Enum.TextXAlignment.Center; countBadge.BorderSizePixel=0
        countBadge.TextScaled=false; countBadge.TextStrokeTransparency=1
        Corner(countBadge,5)

        -- Sub-Label (Tag)
        local tagSubLbl = Instance.new("TextLabel", headerFrame)
        tagSubLbl.Position=UDim2.new(0,30,0,23); tagSubLbl.Size=UDim2.new(1,-90,0,12)
        tagSubLbl.BackgroundTransparency=1; tagSubLbl.Text="[#" .. tag .. "]"
