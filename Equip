-- ── rebuildSetList ─────────────────────────────────────────
-- Baut die gesamte Set-Liste neu auf. Zeigt ALLE Einheiten mit
-- mindestens einem Set, gruppiert und einklappbar.
local rebuildSetList  -- forward-declare

rebuildSetList = function()
    -- Alte Einträge löschen
    for _, v in pairs(setListScroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    -- Einheiten mit Sets sammeln, alphabetisch nach DisplayName
    local unitKeys = {}
    for tag, sets in pairs(EquipSets) do
        if type(sets) == "table" and next(sets) ~= nil then
            -- DisplayName aus gespeichertem Eintrag oder live ermitteln
            local displayName = "?"
            for _, sd in pairs(sets) do
                if sd.DisplayName and sd.DisplayName ~= "" then
                    displayName = sd.DisplayName; break
                end
            end
            if displayName == "?" then
                -- Fallback: aus Collection
                local folder = getUnitByTag(tag)
                if folder then displayName = getDisplayName(folder.Name)
                else displayName = "Tag:" .. tag end
            end
            local setCount = 0; for _ in pairs(sets) do setCount = setCount + 1 end
            table.insert(unitKeys, { tag=tag, displayName=displayName, setCount=setCount })
        end
    end

    local hasAny = #unitKeys > 0
    setsEmptyLbl.Visible = not hasAny
    if not hasAny then return end

    table.sort(unitKeys, function(a,b) return a.displayName < b.displayName end)

    for _, unitInfo in ipairs(unitKeys) do
        local tag         = unitInfo.tag
        local displayName = unitInfo.displayName
        local sets        = EquipSets[tag]
        local isExpanded  = _expanded[tag] == true

        -- ── Einheits-Header ─────────────────────────────────
        local headerFrame = Instance.new("Frame", setListScroll)
        headerFrame.Size = UDim2.new(1,0,0,38)
        headerFrame.BackgroundColor3 = Color3.fromRGB(28,28,32)
        headerFrame.BackgroundTransparency = 0.1
        headerFrame.BorderSizePixel = 0
        Corner(headerFrame, 7)
        Stroke(headerFrame, D.Cyan, 1, isExpanded and 0.2 or 0.55)

        -- Farbstreifen links (Cyan wenn expanded)
        local stripe = Instance.new("Frame", headerFrame)
        stripe.Size=UDim2.new(0,4,1,0); stripe.BackgroundColor3= isExpanded and D.Cyan or D.AccentDim
        stripe.BackgroundTransparency=0.3; stripe.BorderSizePixel=0; Corner(stripe,3)

        -- Pfeil-Indikator
        local arrowLbl = Instance.new("TextLabel", headerFrame)
        arrowLbl.Position=UDim2.new(0,10,0.5,-8); arrowLbl.Size=UDim2.new(0,16,0,16)
        arrowLbl.BackgroundTransparency=1; arrowLbl.Text= isExpanded and "▼" or "▶"
        arrowLbl.TextColor3= isExpanded and D.Cyan or D.TextMid
        arrowLbl.TextSize=11; arrowLbl.Font=Enum.Font.GothamBold
        arrowLbl.TextXAlignment=Enum.TextXAlignment.Center
        arrowLbl.TextScaled=false; arrowLbl.RichText=true; arrowLbl.TextStrokeTransparency=1

        -- Einheits-Name
        local unitNameLbl = Instance.new("TextLabel", headerFrame)
        unitNameLbl.Position=UDim2.new(0,30,0,4); unitNameLbl.Size=UDim2.new(1,-90,0,18)
        unitNameLbl.BackgroundTransparency=1; unitNameLbl.Text=displayName
        unitNameLbl.TextColor3= isExpanded and D.Cyan or D.TextHi
        unitNameLbl.TextSize=13; unitNameLbl.Font=Enum.Font.GothamBold
        unitNameLbl.TextXAlignment=Enum.TextXAlignment.Left; unitNameLbl.TextTruncate=Enum.TextTruncate.AtEnd
        unitNameLbl.TextScaled=false; unitNameLbl.RichText=true; unitNameLbl.TextStrokeTransparency=1

        -- Set-Anzahl Badge
        local countBadge = Instance.new("TextLabel", headerFrame)
        countBadge.Size=UDim2.new(0,40,0,20); countBadge.Position=UDim2.new(1,-46,0.5,-10)
        countBadge.BackgroundColor3=isExpanded and D.Cyan or D.CardHover
        countBadge.BackgroundTransparency=isExpanded and 0.2 or 0.4
        countBadge.Text=tostring(unitInfo.setCount) .. " Sets"
        countBadge.TextColor3=isExpanded and D.BG or D.TextMid
        countBadge.TextSize=9; countBadge.Font=Enum.Font.GothamBold
        countBadge.TextXAlignment=Enum.TextXAlignment.Center; countBadge.BorderSizePixel=0
        countBadge.TextScaled=false; countBadge.TextStrokeTransparency=1
        Corner(countBadge,5)

        -- Sub-Label (Tag)
        local tagSubLbl = Instance.new("TextLabel", headerFrame)
        tagSubLbl.Position=UDim2.new(0,30,0,23); tagSubLbl.Size=UDim2.new(1,-90,0,12)
        tagSubLbl.BackgroundTransparency=1; tagSubLbl.Text="[#" .. tag .. "]"
        tagSubLbl.TextColor3=D.TextLow; tagSubLbl.TextSize=9; tagSubLbl.Font=Enum.Font.GothamMedium
        tagSubLbl.TextXAlignment=Enum.TextXAlignment.Left; tagSubLbl.TextTruncate=Enum.TextTruncate.AtEnd
        tagSubLbl.TextScaled=false; tagSubLbl.RichText=true; tagSubLbl.TextStrokeTransparency=1

        -- Klick-Fläche auf Header → Expand/Collapse
        local headerBtn = Instance.new("TextButton", headerFrame)
        headerBtn.Size=UDim2.new(1,0,1,0); headerBtn.BackgroundTransparency=1
        headerBtn.Text=""; headerBtn.BorderSizePixel=0

        headerBtn.MouseEnter:Connect(function()
            Tw(headerFrame,{BackgroundColor3=Color3.fromRGB(36,36,42),BackgroundTransparency=0.05})
        end)
        headerBtn.MouseLeave:Connect(function()
            Tw(headerFrame,{BackgroundColor3=Color3.fromRGB(28,28,32),BackgroundTransparency=0.1})
        end)

        local capTag = tag
        headerBtn.MouseButton1Click:Connect(function()
            _expanded[capTag] = not (_expanded[capTag] == true)
            rebuildSetList()
        end)

        -- ── Set-Einträge (nur wenn expanded) ────────────────
        if isExpanded then
            -- Sets alphabetisch
            local setNames = {}
            for sName in pairs(sets) do table.insert(setNames, sName) end
            table.sort(setNames)

            for _, setName in ipairs(setNames) do
                local setData = sets[setName]

                -- Eingerückter Container
                local setRow = Instance.new("Frame", setListScroll)
                setRow.Size=UDim2.new(1,0,0,36)
                setRow.BackgroundColor3=D.CardHover; setRow.BackgroundTransparency=0.45
                setRow.BorderSizePixel=0; Corner(setRow,6)
                Stroke(setRow,D.Border,1,0.5)

                -- Einrückung via Padding links
                Pad(setRow,0,4,0,24)

                -- Linker Indikator-Strich (zeigt Zugehörigkeit)
                local indentLine = Instance.new("Frame", setRow)
                indentLine.Size=UDim2.new(0,2,0.6,0); indentLine.Position=UDim2.new(0,10,0.2,0)
                indentLine.BackgroundColor3=D.Cyan; indentLine.BackgroundTransparency=0.5
                indentLine.BorderSizePixel=0; Corner(indentLine,2)

                -- Set-Name
                local setNameLbl = Instance.new("TextLabel", setRow)
                setNameLbl.Position=UDim2.new(0,20,0,4); setNameLbl.Size=UDim2.new(1,-96,0,16)
                setNameLbl.BackgroundTransparency=1; setNameLbl.Text="🗡  " .. setName
                setNameLbl.TextColor3=D.TextHi; setNameLbl.TextSize=12; setNameLbl.Font=Enum.Font.GothamBold
                setNameLbl.TextXAlignment=Enum.TextXAlignment.Left; setNameLbl.TextTruncate=Enum.TextTruncate.AtEnd
                setNameLbl.TextScaled=false; setNameLbl.RichText=true; setNameLbl.TextStrokeTransparency=1

                -- Gear-Anzahl sub
                local gearCountLbl = Instance.new("TextLabel", setRow)
                gearCountLbl.Position=UDim2.new(0,20,0,22); gearCountLbl.Size=UDim2.new(1,-96,0,11)
                gearCountLbl.BackgroundTransparency=1
                gearCountLbl.Text=countGear(setData) .. "/5 Slots"
                gearCountLbl.TextColor3=D.TextLow; gearCountLbl.TextSize=9; gearCountLbl.Font=Enum.Font.GothamMedium
                gearCountLbl.TextXAlignment=Enum.TextXAlignment.Left
                gearCountLbl.TextScaled=false; gearCountLbl.RichText=true; gearCountLbl.TextStrokeTransparency=1

                -- Löschen-Button
                local delBtn = Instance.new("TextButton", setRow)
                delBtn.Size=UDim2.new(0,26,0,26); delBtn.Position=UDim2.new(1,-30,0.5,-13)
                delBtn.BackgroundColor3=Color3.fromRGB(50,12,12); delBtn.Text="✕"
                delBtn.TextColor3=D.Red; delBtn.TextSize=11; delBtn.Font=Enum.Font.GothamBold
                delBtn.AutoButtonColor=false; delBtn.BorderSizePixel=0
                Corner(delBtn,5); Stroke(delBtn,D.Red,1,0.4)
                delBtn.MouseEnter:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(80,20,20)}) end)
                delBtn.MouseLeave:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(50,12,12)}) end)

                -- Load-Button
                local loadBtn = Instance.new("TextButton", setRow)
                loadBtn.Size=UDim2.new(0,30,0,26); loadBtn.Position=UDim2.new(1,-62,0.5,-13)
                loadBtn.BackgroundColor3=Color3.fromRGB(10,36,18); loadBtn.BackgroundTransparency=0.15
                loadBtn.Text="▶"; loadBtn.TextColor3=D.Green; loadBtn.TextSize=13
                loadBtn.Font=Enum.Font.GothamBold; loadBtn.AutoButtonColor=false; loadBtn.BorderSizePixel=0
                Corner(loadBtn,5); Stroke(loadBtn,D.Green,1,0.3)
                loadBtn.MouseEnter:Connect(function() Tw(loadBtn,{BackgroundColor3=Color3.fromRGB(16,52,28)}) end)
                loadBtn.MouseLeave:Connect(function() Tw(loadBtn,{BackgroundColor3=Color3.fromRGB(10,36,18)}) end)

                -- Hover auf gesamte Row
                local rowBtn = Instance.new("TextButton", setRow)
                rowBtn.Size=UDim2.new(1,-66,1,0); rowBtn.BackgroundTransparency=1
                rowBtn.Text=""; rowBtn.BorderSizePixel=0
                rowBtn.MouseEnter:Connect(function()
                    Tw(setRow,{BackgroundColor3=D.TabActive,BackgroundTransparency=0.3})
                end)
                rowBtn.MouseLeave:Connect(function()
                    Tw(setRow,{BackgroundColor3=D.CardHover,BackgroundTransparency=0.45})
                end)

                -- Captures
                local capSetTag  = capTag
                local capSetName = setName
                local capSetData = setData

                loadBtn.MouseButton1Click:Connect(function()
                    loadBtn.Active=false
                    loadFeedback.Text="⏳ Lade '"..capSetName.."'..."; loadFeedback.TextColor3=D.Yellow
                    setStatus("⏳ Lade '"..capSetName.."'...", D.Yellow)
                    task.spawn(function()
                        applyEquipSet(capSetTag, capSetData, function(txt, col)
                            pcall(function()
                                loadFeedback.Text=txt; loadFeedback.TextColor3=col or D.TextMid
                                setStatus(txt, col)
                            end)
                        end)
                        task.wait(0.5)
                        if _selectedTag == capSetTag then pcall(refreshGearView) end
                        loadBtn.Active=true
                        task.delay(6, function() pcall(function() loadFeedback.Text="" end) end)
                    end)
                end)

                delBtn.MouseButton1Click:Connect(function()
                    if EquipSets[capSetTag] then
                        EquipSets[capSetTag][capSetName] = nil
                        if next(EquipSets[capSetTag]) == nil then
                            EquipSets[capSetTag] = nil
                            _expanded[capSetTag] = nil
                        end
                        saveFile()
                        rebuildSetList()
                        setStatus("🗑 Set '"..capSetName.."' gelöscht.", D.TextMid)
                    end
                end)
            end
        end
    end
end

_G._RebuildEquipSetList = rebuildSetList

