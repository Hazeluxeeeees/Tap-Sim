--  PERSISTENZ  —  writefile / readfile via Executor
--
--  Datei:     HazeHUB/Equipment_{UserId}.json
--  Struktur:  { [unitTag] = { [setName] = { Gear..., UnitName, DisplayName } } }
-- ════════════════════════════════════════════════════════════
local FOLDER     = "HazeHUB"
local EQUIP_FILE = FOLDER .. "/Equipment_" .. tostring(Player.UserId) .. ".json"

if makefolder then pcall(function() makefolder(FOLDER) end) end

-- In-Memory-Tabelle — wird beim Start aus Datei gefüllt
-- EquipSets[unitTag][setName] = { HeadGear=..., BodyGear=..., ..., UnitName=..., DisplayName=... }
local EquipSets = {}

local function saveFile()
    if not writefile then
        warn("[HazeHub/Equip] writefile nicht verfügbar (Executor-Feature fehlt)")
        return
    end
    local ok, err = pcall(function()
        writefile(EQUIP_FILE, Http:JSONEncode(EquipSets))
    end)
    if not ok then warn("[HazeHub/Equip] Speichern fehlgeschlagen: " .. tostring(err)) end
end

local function loadFile()
    if not (isfile and isfile(EQUIP_FILE)) then return end
    local ok, data = pcall(function()
        return Http:JSONDecode(readfile(EQUIP_FILE))
    end)
    if ok and type(data) == "table" then
        EquipSets = data
        local n = 0; for _ in pairs(EquipSets) do n = n + 1 end
        print(string.format("[HazeHub/Equip] Geladen: %d Einheiten  (UserId: %s | Datei: %s)",
            n, tostring(Player.UserId), EQUIP_FILE))
    else
        warn("[HazeHub/Equip] Datei konnte nicht gelesen werden: " .. EQUIP_FILE)
    end
end

