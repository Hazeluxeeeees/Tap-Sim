local _remoteCache = {}
local function getRemote(...)
    local key = table.concat({...}, "/")
    if _remoteCache[key] then return _remoteCache[key] end
    local node = RS
    for _, seg in ipairs({...}) do
        local ok, child = pcall(function() return node:WaitForChild(seg, 8) end)
        if not ok or not child then
            warn("[HazeHub/Equip] Remote nicht gefunden: " .. key); return nil
        end
        node = child
    end
    _remoteCache[key] = node; return node
end

local function fireUnequipGear(unitFolder, slotDef)
    if not unitFolder or not slotDef then return end
    if slotDef.remoteType == "Soul" then
        local r = getRemote("Remote","Server","Units","Soul"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Unequip", [2]={ ["UnitFolder"]=unitFolder, ["SoulName"]="Soul" } }))
        end)
    else
        local r = getRemote("Remote","Server","Units","Gears"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Unequip", [2]={ ["UnitFolder"]=unitFolder, ["GearName"]=slotDef.unequipKey } }))
        end)
    end
end

local function fireEquipGear(unitFolder, slotDef, itemName)
    if not itemName or itemName == "" or not unitFolder then return end
    if slotDef.remoteType == "Soul" then
        local r = getRemote("Remote","Server","Units","Soul"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Equip", [2]={ ["UnitFolder"]=unitFolder, ["SoulName"]=itemName } }))
        end)
    else
        local r = getRemote("Remote","Server","Units","Gears"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Equip", [2]={ ["UnitFolder"]=unitFolder, ["GearName"]=itemName } }))
        end)
    end
end

-- ════════════════════════════════════════════════════════════
--  EQUIP-SET ANWENDEN  (Unequip alle → Equip aus Set)
-- ════════════════════════════════════════════════════════════
local function applyEquipSet(unitTag, setData, onStatus)
    onStatus = onStatus or function() end
    local unitFolder = getUnitByTag(unitTag)
    if not unitFolder then
        onStatus("❌ Einheit nicht in Collection (Tag: " .. tostring(unitTag) .. ")", D.Red); return
    end
    -- Schritt 1: alle Slots leeren
    onStatus("⚡ Entferne altes Gear...", D.Yellow)
    for _, s in ipairs(GEAR_SLOTS) do
        if readGearValue(unitFolder, s.key) then
            fireUnequipGear(unitFolder, s); task.wait(0.05)
        end
    end
    task.wait(0.25)
    -- Schritt 2: Set ausrüsten
    onStatus("🎯 Rüste Set aus...", D.Yellow)
    local equipped = 0
    for _, s in ipairs(GEAR_SLOTS) do
        local itemName = setData[s.key]
        if itemName and itemName ~= "" then
            local fresh = getUnitByTag(unitTag)
            if fresh then fireEquipGear(fresh, s, itemName); equipped = equipped + 1; task.wait(0.08) end
        end
    end
    onStatus(string.format("✅ Set geladen! (%d/%d Slots)", equipped, #GEAR_SLOTS), D.GreenBright)
    print(string.format("[HazeHub/Equip] Set angewandt: %d Slots  Einheit:%s", equipped, unitFolder.Name))
end

-- ════════════════════════════════════════════════════════════
--  ITEMS-INDEX  (RS.Shared.Info.Items)
--  Lazy-geladen, einmalig gecacht.
--  Struktur (dekompiliert): ItemsIndex[ItemName] = {
--    GearType = "HeadGear"|"BodyGear"|"LegsGear"|"ArmsGear",
--    Rarity   = "Common"|"Rare"|...,
--    Stats    = { Damage=n, Range=n, Speed=n, ... }
--  }
-- ════════════════════════════════════════════════════════════
local _itemsIndex       = nil
local _itemsIndexLoaded = false

local function loadItemsIndex()
    if _itemsIndexLoaded then return end
    _itemsIndexLoaded = true
    pcall(function()
        local shared = RS:WaitForChild("Shared",5)
        local info   = shared:WaitForChild("Info",5)
        local mod    = info:WaitForChild("Items",5)
        _itemsIndex  = require(mod)
    end)
    if _itemsIndex then
        print("[HazeHub/Equip] Items-Index geladen.")
    else
        warn("[HazeHub/Equip] Items-Index nicht verfügbar – Fallback auf Inventar-Namen.")
    end
end

-- Gibt alle Stats-Keys eines Items zurück (aus Index oder leer)
local function getItemStats(itemName)
    if not _itemsIndex then return {} end
    -- Direkte Suche
    local entry = _itemsIndex[itemName]
    if not entry then
        -- Case-insensitiv
        local low = itemName:lower()
        for k, v in pairs(_itemsIndex) do
            if tostring(k):lower() == low then entry = v; break end
        end
    end
    if not entry then return {} end
    -- Stats können in entry.Stats oder direkt in entry stehen
    if type(entry.Stats) == "table" then return entry.Stats end
    -- Fallback: alle numerischen Keys als Stats behandeln
    local stats = {}
    for k, v in pairs(entry) do
        if type(v) == "number" then stats[k] = v end
    end
    return stats
end

-- Gibt den GearType eines Items zurück (HeadGear, BodyGear, ...)
-- Fallback: nil (Item hat keinen Gear-Typ)
local function getItemGearType(itemName)
    if not _itemsIndex then return nil end
    local entry = _itemsIndex[itemName]
    if not entry then
        local low = itemName:lower()
        for k, v in pairs(_itemsIndex) do
            if tostring(k):lower() == low then entry = v; break end
        end
    end
    if not entry then return nil end
    return entry.GearType or entry.Type or entry.Slot or nil
end

-- ════════════════════════════════════════════════════════════
--  INVENTAR-SCANNER
--  Liest RS.Player_Data[Player.Name].Items
--  Gibt zurück: { [itemName] = amount }  (nur Items mit amount > 0)
-- ════════════════════════════════════════════════════════════
local function scanInventory()
    local inv = {}
    pcall(function()
        local itemFolder = RS
            :WaitForChild("Player_Data",5)
            :WaitForChild(Player.Name,5)
            :WaitForChild("Items",5)
        for _, item in pairs(itemFolder:GetChildren()) do
            local amt = 0
            local vc  = item:FindFirstChild("Amount") or item:FindFirstChild("Value")
            if vc then
                amt = tonumber(vc.Value) or 0
            elseif item:IsA("IntValue") or item:IsA("NumberValue") then
                amt = tonumber(item.Value) or 0
            end
            if amt > 0 then inv[item.Name] = amt end
        end
    end)
    return inv
end

-- ════════════════════════════════════════════════════════════
--  OPTIMIERUNGS-ATTRIBUTE
--  { id, label, keys[], higherIsBetter }
--  keys[]: alle Stat-Schlüssel die für dieses Attribut zählen
-- ════════════════════════════════════════════════════════════
local OPT_ATTRS = {
    { id="Damage",   label="⚔ Damage",   keys={"Damage","AttackDamage","BaseDamage","DMG"},      better=true  },
    { id="Range",    label="🎯 Range",    keys={"Range","AttackRange","AtkRange"},                better=true  },
    { id="Speed",    label="💨 Speed",    keys={"Speed","MoveSpeed","MovementSpeed","WalkSpeed"}, better=true  },
    { id="Cooldown", label="⏱ Cooldown", keys={"AttackCooldown","Cooldown","AtkCooldown"},        better=false }, -- niedriger = besser
    { id="HP",       label="❤ HP",       keys={"HP","Health","MaxHP","MaxHealth"},                better=true  },
    { id="Defense",  label="🛡 Defense",  keys={"Defense","Armor","DEF","PhysicalDefense"},       better=true  },
    { id="Soul",     label="🌟 Soul Pow", keys={"SoulPower","SoulDamage","SoulBonus"},             better=true  },
}
local _selectedAttr = OPT_ATTRS[1]  -- Standard: Damage

-- Berechnet den Score eines Items für ein Attribut
-- Gibt nil zurück wenn das Item keine relevanten Stats hat
local function scoreItem(itemName, attrDef)
    local stats = getItemStats(itemName)
    if not next(stats) then return nil end
    local total = 0
    local found = false
    for _, key in ipairs(attrDef.keys) do
        local val = stats[key]
        if not val then
            -- Case-insensitiv suchen
            local lk = key:lower()
            for sk, sv in pairs(stats) do
                if tostring(sk):lower() == lk then val=sv; break end
            end
        end
        if type(val) == "number" then
            total = total + math.abs(val)
            found = true
        end
    end
    if not found then return nil end
    -- Für "niedriger=besser" Attribute (Cooldown): Kehrwert damit sort gleich bleibt
    return attrDef.better and total or (1/(total+0.001))
end

-- ════════════════════════════════════════════════════════════
--  KERN-OPTIMIZER
--  Für jeden GEAR_SLOT: bestes Item aus Inventar finden.
--  Gibt zurück: { [gearSlotKey] = { itemName, score, gearType } }
-- ════════════════════════════════════════════════════════════
local function runOptimize(attrDef)
    loadItemsIndex()
    local inv = scanInventory()
    if not next(inv) then
        return nil, "Inventar leer oder nicht erreichbar."
    end

    -- Slot-Key → Liste von { itemName, score }
    local candidates = {}
    for _, slot in ipairs(GEAR_SLOTS) do
        candidates[slot.key] = {}
    end

    -- Fallback-Slot-Zuordnung (wenn GearType nicht aus Index ermittelbar)
    -- Annahme aus Spielstruktur: Item-Namen oft mit Slot-Begriff
    local slotHints = {
        HeadGear = {"helm","hat","hood","crown","head","mask","cap","tiara"},
        BodyGear = {"coat","armor","robe","shirt","chest","body","jacket","cloak","vest"},
        LegsGear = {"boots","shoes","pants","legs","greaves","sandals","leggings"},
        ArmsGear = {"gloves","gauntlet","arm","bracelet","wrist","sleeve","sword","weapon","blade","gun","staff","bow"},
        Soul     = {"soul","spirit","essence","orb"},
    }

    local function guessSlot(name)
        local low = name:lower()
        for slotKey, hints in pairs(slotHints) do
            for _, h in ipairs(hints) do
                if low:find(h, 1, true) then return slotKey end
            end
        end
        return nil
    end

    for itemName, _ in pairs(inv) do
        local score = scoreItem(itemName, attrDef)
        if score then
            -- Slot bestimmen: Index zuerst, dann Heuristik
            local gearType = getItemGearType(itemName)
            if not gearType then gearType = guessSlot(itemName) end
            if gearType and candidates[gearType] then
                table.insert(candidates[gearType], { name=itemName, score=score })
            end
        end
    end

    -- Bestes Item pro Slot ermitteln
    local best = {}
    for slotKey, list in pairs(candidates) do
        if #list > 0 then
            table.sort(list, function(a,b) return a.score > b.score end)
            best[slotKey] = list[1]
        end
    end

    return best, nil
end

