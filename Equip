-- ════════════════════════════════════════════════════════════
--  BASE64  (Lua-eigene Implementierung, kein externes Modul)
--  Wird für Export/Import-Codes genutzt.
-- ════════════════════════════════════════════════════════════
local B64_CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

local function b64Encode(data)
    local result, padding = {}, ""
    local bytes = {data:byte(1, #data)}
    for i = 1, #bytes, 3 do
        local b1, b2, b3 = bytes[i], bytes[i+1] or 0, bytes[i+2] or 0
        local n = b1 * 65536 + b2 * 256 + b3
        result[#result+1] = B64_CHARS:sub(math.floor(n/262144)%64+1, math.floor(n/262144)%64+1)
        result[#result+1] = B64_CHARS:sub(math.floor(n/4096)%64+1,   math.floor(n/4096)%64+1)
        result[#result+1] = bytes[i+1] and B64_CHARS:sub(math.floor(n/64)%64+1, math.floor(n/64)%64+1) or "="
        result[#result+1] = bytes[i+2] and B64_CHARS:sub(n%64+1, n%64+1) or "="
    end
    return table.concat(result)
end

local function b64Decode(s)
    s = s:gsub("[^A-Za-z0-9+/=]", "")
    local result = {}
    local lookup = {}
    for i = 1, #B64_CHARS do lookup[B64_CHARS:sub(i,i)] = i-1 end
    for i = 1, #s, 4 do
        local c1 = lookup[s:sub(i,i)]   or 0
        local c2 = lookup[s:sub(i+1,i+1)] or 0
        local c3 = lookup[s:sub(i+2,i+2)]
        local c4 = lookup[s:sub(i+3,i+3)]
        local n  = c1 * 262144 + c2 * 4096
        result[#result+1] = string.char(math.floor(n/65536) % 256)
        if c3 then
            n = n + (c3 or 0) * 64
            result[#result+1] = string.char(math.floor(n/256) % 256)
        end
        if c4 then
            n = n + (c4 or 0)
            result[#result+1] = string.char(n % 256)
        end
    end
    return table.concat(result)
end

-- Exportiert ein einzelnes Set als kopierbaren Code-String
-- Format: Base64( JSONEncode({ unitTag, setName, setData }) )
local function exportSetCode(unitTag, setName, setData)
    local payload = {
        v       = 1,             -- Version für künftige Kompatibilität
        unitTag = unitTag,
        setName = setName,
        setData = setData,
    }
    local ok, json = pcall(function() return Http:JSONEncode(payload) end)
    if not ok then return nil, "JSON-Fehler: " .. tostring(json) end
    return b64Encode(json)
end

-- Importiert einen Code-String. Gibt { unitTag, setName, setData } oder nil, err zurück.
local function importSetCode(code)
    code = (code or ""):match("^%s*(.-)%s*$")
    if code == "" then return nil, "Leerer Code." end
    local jsonStr = b64Decode(code)
    if jsonStr == "" then return nil, "Ungültiger Code (Base64-Fehler)." end
    local ok, payload = pcall(function() return Http:JSONDecode(jsonStr) end)
    if not ok or type(payload) ~= "table" then
        return nil, "Ungültiges Format (JSON-Fehler)."
    end
    -- Validierung: Pflichtfelder prüfen
    if type(payload.unitTag) ~= "string" or payload.unitTag == "" then
        return nil, "Kein unitTag im Code."
    end
    if type(payload.setName) ~= "string" or payload.setName == "" then
        return nil, "Kein setName im Code."
    end
    if type(payload.setData) ~= "table" then
        return nil, "Keine setData im Code."
    end
    return payload, nil
end
