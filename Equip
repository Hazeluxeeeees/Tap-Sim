--  SAVE BUTTON LOGIK
-- ════════════════════════════════════════════════════════════
saveSetBtn.MouseButton1Click:Connect(function()
    if not _selectedTag then
        saveFeedback.Text="⚠ Erst eine Einheit wählen!"; saveFeedback.TextColor3=D.Orange; return
    end
    local setName = (setNameBox.Text or ""):match("^%s*(.-)%s*$")
    if setName=="" then
        saveFeedback.Text="⚠ Set-Name eingeben!"; saveFeedback.TextColor3=D.Orange; return
    end

    local folder = getUnitByTag(_selectedTag)
    if not folder then
        saveFeedback.Text="⚠ Einheit nicht in Collection!"; saveFeedback.TextColor3=D.Red; return
    end

    local gear = readAllGear(folder)

    local gearCount = countGear(gear)
    if gearCount == 0 then
        saveFeedback.Text="⚠ Kein Gear gefunden – nichts zum Speichern."; saveFeedback.TextColor3=D.Orange; return
    end

    -- Meta-Daten anhängen
    gear.UnitName    = folder.Name
    gear.DisplayName = _selectedName
    gear.Stage       = (_saveStage ~= "") and _saveStage or nil  -- ★ Stage-Tag

    -- In EquipSets einschreiben: [unitTag][setName]
    if not EquipSets[_selectedTag] then EquipSets[_selectedTag] = {} end
    EquipSets[_selectedTag][setName] = gear

    -- Auf Disk schreiben (account-gebunden via UserId)
    saveFile()

    -- UI: Gruppe sofort aufklappen damit der neue Eintrag sichtbar ist
    _expanded[_selectedTag] = true

    saveFeedback.Text=string.format("✅ '%s' gespeichert! (%d Slots)", setName, gearCount)
    saveFeedback.TextColor3=D.GreenBright
    setNameBox.Text=""

    rebuildSetList()

    task.delay(5, function() pcall(function() saveFeedback.Text="" end) end)
end)

