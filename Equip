        Corner(delBtn,6); Stroke(delBtn,D.Red,1,0.4)
        delBtn.MouseEnter:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(80,20,20)}) end)
        delBtn.MouseLeave:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(50,12,12)}) end)

        -- Load-Button (gesamte Zeile klickbar)
        local loadBtn = Instance.new("TextButton", row)
        loadBtn.Size = UDim2.new(1,-38,1,0); loadBtn.BackgroundTransparency = 1
        loadBtn.Text = ""; loadBtn.BorderSizePixel = 0
        loadBtn.MouseEnter:Connect(function()
            Tw(row,{BackgroundColor3=D.TabActive,BackgroundTransparency=0.2})
        end)
        loadBtn.MouseLeave:Connect(function()
            Tw(row,{BackgroundColor3=D.CardHover,BackgroundTransparency=0.3})
        end)

        -- Capture für Closures
        local capName    = setName
        local capSetData = setData
        local capTag     = _selectedTag

