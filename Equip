            end

            -- Unequip bestehende Slots
            for _, s in ipairs(GEAR_SLOTS) do
                if _lastOptResult[s.key] then  -- nur Slots die wir überschreiben
                    if readGearValue(unitFolder, s.key) then
                        fireUnequipGear(unitFolder, s); task.wait(0.05)
                    end
                end
            end
            task.wait(0.2)

            -- Equip neue Items
            local equipped = 0
            for _, s in ipairs(GEAR_SLOTS) do
                local info = _lastOptResult[s.key]
                if info then
                    local fresh = getUnitByTag(_selectedTag)
                    if fresh then
                        fireEquipGear(fresh, s, info.name)
                        equipped = equipped + 1
                        task.wait(0.08)
                    end
                end
            end

            optResultLbl.Text = string.format(
                "✅ %d Slots ausgerüstet! (Attribut: %s)", equipped, _selectedAttr.label)
            optResultLbl.TextColor3 = D.GreenBright

            -- Live-Gear aktualisieren
            task.wait(0.3)
            pcall(refreshGearView)

            optEquipBtn.Active=true
        end)
    end)
end  -- Ende Auto-Optimize Block

