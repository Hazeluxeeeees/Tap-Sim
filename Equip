                local inv = scanInventory()
                local allItems = {}
                for name, _ in pairs(inv) do table.insert(allItems, name) end
                table.sort(allItems)

                -- Zeige die ersten 5 als Fallback
                for i, s in ipairs(GEAR_SLOTS) do
                    local item = allItems[i]
                    if item then
                        optSlotLabels[s.key].Text = item .. " (kein Score)"
                        optSlotLabels[s.key].TextColor3 = D.TextMid
                    end
