    10, D.TextLow)
importInfoLbl.Size=UDim2.new(1,0,0,0); importInfoLbl.AutomaticSize=Enum.AutomaticSize.Y
importInfoLbl.TextWrapped=true

local importRow = Instance.new("Frame", importCard)
importRow.Size=UDim2.new(1,0,0,32); importRow.BackgroundTransparency=1; HList(importRow,6)

local importOuter, importBox = MkInput(importRow, "Export-Code hier einfügen...")
importOuter.Size = UDim2.new(0.72,0,0,32)

local importBtn = Instance.new("TextButton", importRow)
importBtn.Size=UDim2.new(0.25,0,0,32); importBtn.BackgroundColor3=D.Cyan
importBtn.BackgroundTransparency=0.15; importBtn.Text="📥 Import"
importBtn.TextColor3=Color3.new(1,1,1); importBtn.TextSize=11; importBtn.Font=Enum.Font.GothamBold
importBtn.AutoButtonColor=false; importBtn.BorderSizePixel=0
Corner(importBtn,7); Stroke(importBtn,D.Cyan,1,0.2)
importBtn.MouseEnter:Connect(function() Tw(importBtn,{BackgroundTransparency=0.05}) end)
importBtn.MouseLeave:Connect(function() Tw(importBtn,{BackgroundTransparency=0.15}) end)

local importFeedback = MkLbl(importCard,"",10,D.TextLow); importFeedback.Size=UDim2.new(1,0,0,16)

importBtn.MouseButton1Click:Connect(function()
    local code = (importBox.Text or ""):match("^%s*(.-)%s*$")
    if code == "" then
        importFeedback.Text="⚠ Bitte einen Code eingeben."; importFeedback.TextColor3=D.Orange; return
    end

    local payload, err = importSetCode(code)
    if not payload then
        importFeedback.Text="❌ " .. tostring(err); importFeedback.TextColor3=D.Red; return
    end

    local unitTag  = payload.unitTag
    local setName  = payload.setName
    local setData  = payload.setData

    -- Duplikat-Behandlung: Namen mit Suffix versehen wenn schon vorhanden
    if EquipSets[unitTag] and EquipSets[unitTag][setName] then
        local i = 2
        while EquipSets[unitTag][setName .. " (" .. i .. ")"] do i = i + 1 end
        setName = setName .. " (" .. i .. ")"
    end

    -- Einschreiben
    if not EquipSets[unitTag] then EquipSets[unitTag] = {} end
    EquipSets[unitTag][setName] = setData

    saveFile()
    _expanded[unitTag] = true  -- Gruppe aufklappen

    importBox.Text = ""
    importFeedback.Text=string.format("✅ Set '%s' importiert!", setName)
    importFeedback.TextColor3=D.GreenBright
    rebuildSetList()
    setStatus("✅ Importiert: '" .. setName .. "'", D.GreenBright)

    task.delay(5, function() pcall(function() importFeedback.Text="" end) end)
end)

