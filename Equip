        tagSubLbl.TextXAlignment=Enum.TextXAlignment.Left; tagSubLbl.TextTruncate=Enum.TextTruncate.AtEnd
        tagSubLbl.TextScaled=false; tagSubLbl.RichText=true; tagSubLbl.TextStrokeTransparency=1

        -- Klick-Fläche auf Header → Expand/Collapse
        local headerBtn = Instance.new("TextButton", headerFrame)
        headerBtn.Size=UDim2.new(1,0,1,0); headerBtn.BackgroundTransparency=1
        headerBtn.Text=""; headerBtn.BorderSizePixel=0

        headerBtn.MouseEnter:Connect(function()
            Tw(headerFrame,{BackgroundColor3=Color3.fromRGB(36,36,42),BackgroundTransparency=0.05})
        end)
        headerBtn.MouseLeave:Connect(function()
            Tw(headerFrame,{BackgroundColor3=Color3.fromRGB(28,28,32),BackgroundTransparency=0.1})
        end)

        local capTag = tag
        headerBtn.MouseButton1Click:Connect(function()
            _expanded[capTag] = not (_expanded[capTag] == true)
            rebuildSetList()
        end)

        -- ── Set-Einträge (nur wenn expanded) ────────────────
        if isExpanded then
            -- Sets alphabetisch, Stage-Filter auf Set-Ebene
            local setNames = {}
            for sName, sd in pairs(sets) do
                if _activeStage == "" or sd.Stage == _activeStage then
