                gearCountLbl.TextScaled=false; gearCountLbl.RichText=true; gearCountLbl.TextStrokeTransparency=1

                -- ★ Copy-Button (Export)
                local copyBtn = Instance.new("TextButton", setRow)
                copyBtn.Size=UDim2.new(0,26,0,26); copyBtn.Position=UDim2.new(1,-96,0.5,-13)
                copyBtn.BackgroundColor3=Color3.fromRGB(18,28,48); copyBtn.BackgroundTransparency=0.15
                copyBtn.Text="📋"; copyBtn.TextColor3=D.CyanDim; copyBtn.TextSize=12
                copyBtn.Font=Enum.Font.GothamBold; copyBtn.AutoButtonColor=false; copyBtn.BorderSizePixel=0
                Corner(copyBtn,5); Stroke(copyBtn,D.CyanDim,1,0.35)
                copyBtn.MouseEnter:Connect(function() Tw(copyBtn,{BackgroundColor3=Color3.fromRGB(22,40,70)}) end)
                copyBtn.MouseLeave:Connect(function() Tw(copyBtn,{BackgroundColor3=Color3.fromRGB(18,28,48)}) end)

                -- Löschen-Button
                local delBtn = Instance.new("TextButton", setRow)
                delBtn.Size=UDim2.new(0,26,0,26); delBtn.Position=UDim2.new(1,-30,0.5,-13)
                delBtn.BackgroundColor3=Color3.fromRGB(50,12,12); delBtn.Text="✕"
                delBtn.TextColor3=D.Red; delBtn.TextSize=11; delBtn.Font=Enum.Font.GothamBold
                delBtn.AutoButtonColor=false; delBtn.BorderSizePixel=0
                Corner(delBtn,5); Stroke(delBtn,D.Red,1,0.4)
                delBtn.MouseEnter:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(80,20,20)}) end)
                delBtn.MouseLeave:Connect(function() Tw(delBtn,{BackgroundColor3=Color3.fromRGB(50,12,12)}) end)

                -- Load-Button
                local loadBtn = Instance.new("TextButton", setRow)
                loadBtn.Size=UDim2.new(0,30,0,26); loadBtn.Position=UDim2.new(1,-62,0.5,-13)
                loadBtn.BackgroundColor3=Color3.fromRGB(10,36,18); loadBtn.BackgroundTransparency=0.15
                loadBtn.Text="▶"; loadBtn.TextColor3=D.Green; loadBtn.TextSize=13
                loadBtn.Font=Enum.Font.GothamBold; loadBtn.AutoButtonColor=false; loadBtn.BorderSizePixel=0
                Corner(loadBtn,5); Stroke(loadBtn,D.Green,1,0.3)
                loadBtn.MouseEnter:Connect(function() Tw(loadBtn,{BackgroundColor3=Color3.fromRGB(16,52,28)}) end)
                loadBtn.MouseLeave:Connect(function() Tw(loadBtn,{BackgroundColor3=Color3.fromRGB(10,36,18)}) end)

                -- Hover auf gesamte Row
                local rowBtn = Instance.new("TextButton", setRow)
                rowBtn.Size=UDim2.new(1,-100,1,0); rowBtn.BackgroundTransparency=1
                rowBtn.Text=""; rowBtn.BorderSizePixel=0
                rowBtn.MouseEnter:Connect(function()
                    Tw(setRow,{BackgroundColor3=D.TabActive,BackgroundTransparency=0.3})
                end)
                rowBtn.MouseLeave:Connect(function()
                    Tw(setRow,{BackgroundColor3=D.CardHover,BackgroundTransparency=0.45})
                end)

                -- Captures
                local capSetTag  = capTag
                local capSetName = setName
                local capSetData = setData

                -- ★ Copy-Button Logik
                copyBtn.MouseButton1Click:Connect(function()
                    local code, err = exportSetCode(capSetTag, capSetName, capSetData)
                    if code then
                        if setclipboard then
                            setclipboard(code)
                            copyBtn.Text="✅"; copyBtn.TextColor3=D.GreenBright
                            task.delay(1.5, function() pcall(function()
                                copyBtn.Text="📋"; copyBtn.TextColor3=D.CyanDim
                            end) end)
                        else
                            loadFeedback.Text="⚠ setclipboard nicht verfügbar."
                            loadFeedback.TextColor3=D.Orange
                        end
                    else
                        loadFeedback.Text="❌ Export Fehler: " .. tostring(err)
                        loadFeedback.TextColor3=D.Red
                    end
                end)

                loadBtn.MouseButton1Click:Connect(function()
                    loadBtn.Active=false
                    loadFeedback.Text="⏳ Lade '"..capSetName.."'..."; loadFeedback.TextColor3=D.Yellow
                    setStatus("⏳ Lade '"..capSetName.."'...", D.Yellow)
                    task.spawn(function()
                        applyEquipSet(capSetTag, capSetData, function(txt, col)
                            pcall(function()
                                loadFeedback.Text=txt; loadFeedback.TextColor3=col or D.TextMid
                                setStatus(txt, col)
                            end)
                        end)
                        task.wait(0.5)
                        if _selectedTag == capSetTag then pcall(refreshGearView) end
                        loadBtn.Active=true
                        task.delay(6, function() pcall(function() loadFeedback.Text="" end) end)
                    end)
                end)

                delBtn.MouseButton1Click:Connect(function()
                    if EquipSets[capSetTag] then
                        EquipSets[capSetTag][capSetName] = nil
                        if next(EquipSets[capSetTag]) == nil then
                            EquipSets[capSetTag] = nil
                            _expanded[capSetTag] = nil
                        end
                        saveFile()
                        rebuildSetList()
                        setStatus("🗑 Set '"..capSetName.."' gelöscht.", D.TextMid)
                    end
                end)
            end
        end
    end
end

