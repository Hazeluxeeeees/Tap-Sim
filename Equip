local function onUnitSelected(unitEntry)
    _selectedTag  = unitEntry.tag
    _selectedName = unitEntry.displayName

    gearCard.Visible  = true
    saveCard.Visible  = true

    saveUnitLbl.Text = "Einheit: " .. unitEntry.displayName .. "  [#" .. unitEntry.tag .. "]"
    saveUnitLbl.TextColor3 = D.Cyan

    setStatus(string.format("Ausgewählt: %s  [#%s]", unitEntry.displayName, unitEntry.tag), D.Cyan)
    pcall(refreshGearView)
end

local function buildUnitList(filter)
    filter = (filter or ""):lower():match("^%s*(.-)%s*$")
    local useFilter = filter ~= ""

    for _, v in pairs(unitListFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    local units = getAllUnits()

    -- ★ Filtern: nur Einheiten anzeigen deren DisplayName den Begriff enthält
    local filtered = {}
    for _, u in ipairs(units) do
        if not useFilter or u.displayName:lower():find(filter, 1, true) then
            table.insert(filtered, u)
        end
    end

    unitEmptyLbl.Visible = (#filtered == 0)

    for _, unitEntry in ipairs(filtered) do
        local isSel  = (_selectedTag ~= nil and unitEntry.tag == _selectedTag)
        local hasTag = unitEntry.tag ~= ""

        local row = Instance.new("Frame", unitListFrame)
        row.Size=UDim2.new(1,0,0,36)
        row.BackgroundColor3= isSel and D.TabActive or D.CardHover
        row.BackgroundTransparency= isSel and 0.2 or 0.5
        row.BorderSizePixel=0; Corner(row,6)
        Stroke(row, isSel and D.Cyan or D.Border, isSel and 1.5 or 1, isSel and 0 or 0.5)

        local stripe = Instance.new("Frame", row)
        stripe.Size=UDim2.new(0,4,1,0)
        stripe.BackgroundColor3= hasTag and D.Green or D.Orange
        stripe.BackgroundTransparency=0.3; stripe.BorderSizePixel=0; Corner(stripe,3)

        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Position=UDim2.new(0,10,0,3); nameLbl.Size=UDim2.new(1,-14,0,16)
        nameLbl.BackgroundTransparency=1; nameLbl.Text=unitEntry.displayName
        nameLbl.TextColor3= isSel and D.Cyan or D.TextHi
        nameLbl.TextSize=12; nameLbl.Font=Enum.Font.GothamBold
        nameLbl.TextXAlignment=Enum.TextXAlignment.Left; nameLbl.TextTruncate=Enum.TextTruncate.AtEnd
        nameLbl.TextScaled=false; nameLbl.RichText=true; nameLbl.TextStrokeTransparency=1

        local tagLbl = Instance.new("TextLabel", row)
        tagLbl.Position=UDim2.new(0,10,0,20); tagLbl.Size=UDim2.new(1,-14,0,13)
        tagLbl.BackgroundTransparency=1
        tagLbl.Text= hasTag and ("[#"..unitEntry.tag.."]") or "[⚠ kein Tag]"
        tagLbl.TextColor3= hasTag and D.TextMid or D.Orange
        tagLbl.TextSize=10; tagLbl.Font=Enum.Font.GothamMedium
        tagLbl.TextXAlignment=Enum.TextXAlignment.Left; tagLbl.TextTruncate=Enum.TextTruncate.AtEnd
        tagLbl.TextScaled=false; tagLbl.RichText=true; tagLbl.TextStrokeTransparency=1

        local btn = Instance.new("TextButton", row)
        btn.Size=UDim2.new(1,0,1,0); btn.BackgroundTransparency=1; btn.Text=""; btn.BorderSizePixel=0

        local capEntry = unitEntry
        btn.MouseEnter:Connect(function()
            if not (_selectedTag and capEntry.tag==_selectedTag) then
                Tw(row,{BackgroundColor3=D.TabActive,BackgroundTransparency=0.35})
            end
        end)
        btn.MouseLeave:Connect(function()
            if not (_selectedTag and capEntry.tag==_selectedTag) then
                Tw(row,{BackgroundColor3=D.CardHover,BackgroundTransparency=0.5})
            end
        end)
        btn.MouseButton1Click:Connect(function()
            onUnitSelected(capEntry)
            buildUnitList()
        end)
    end
end

