local GEAR_SLOTS = {
    { key = "HeadGear", remoteType = "Gears", unequipKey = "HeadGear", label = "Head" },
    { key = "BodyGear",  remoteType = "Gears", unequipKey = "BodyGear",  label = "Body" },
    { key = "LegsGear",  remoteType = "Gears", unequipKey = "LegsGear",  label = "Legs" },
    { key = "ArmsGear",  remoteType = "Gears", unequipKey = "ArmsGear",  label = "Arms" },
