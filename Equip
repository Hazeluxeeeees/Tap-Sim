-- ════════════════════════════════════════════════════════════
--  HELPERS
-- ════════════════════════════════════════════════════════════
local function getDisplayName(folderName)
    if _G.HazeShared and type(_G.HazeShared.getDisplayName) == "function" then
        return _G.HazeShared.getDisplayName(folderName)
    end
    return folderName or "?"
end

local function getCollection()
    return RS.Player_Data[Player.Name].Collection
end

local function getUnitByTag(targetTag)
    if not targetTag or targetTag == "" then return nil end
    for _, folder in pairs(getCollection():GetChildren()) do
        if folder:FindFirstChild("Tag") and folder.Tag.Value == targetTag then
            return folder
        end
    end
    return nil
end

local function readGearValue(unitFolder, gearKey)
    local obj = unitFolder:FindFirstChild(gearKey)
    if not obj then return nil end
    local v = tostring(obj.Value)
    return (v ~= "" and v ~= "nil" and v ~= "0") and v or nil
end

local function readAllGear(unitFolder)
    local gear = {}
    for _, s in ipairs(GEAR_SLOTS) do
        gear[s.key] = readGearValue(unitFolder, s.key)
    end
    return gear
end

local function getAllUnits()
    local result = {}
    local ok, col = pcall(getCollection)
    if not ok or not col then return result end
    for _, folder in pairs(col:GetChildren()) do
        if folder:IsA("Folder") then
            local tagObj = folder:FindFirstChild("Tag")
            local tag    = tagObj and tostring(tagObj.Value) or ""
            table.insert(result, {
                name        = folder.Name,
                displayName = getDisplayName(folder.Name),
                tag         = tag,
                instance    = folder,
            })
        end
    end
    table.sort(result, function(a, b) return a.displayName < b.displayName end)
    return result
end

local function countGear(setData)
    local n = 0
    for _, s in ipairs(GEAR_SLOTS) do
        if setData[s.key] and setData[s.key] ~= "" then n = n + 1 end
    end
    return n
end

-- ════════════════════════════════════════════════════════════
--  REMOTE-HELPER  (identisch zu teams.lua)
-- ════════════════════════════════════════════════════════════
local _remoteCache = {}
local function getRemote(...)
    local key = table.concat({...}, "/")
    if _remoteCache[key] then return _remoteCache[key] end
    local node = RS
    for _, seg in ipairs({...}) do
        local ok, child = pcall(function() return node:WaitForChild(seg, 8) end)
        if not ok or not child then
            warn("[HazeHub/Equip] Remote nicht gefunden: " .. key); return nil
        end
        node = child
    end
    _remoteCache[key] = node; return node
end

local function fireUnequipGear(unitFolder, slotDef)
    if not unitFolder or not slotDef then return end
    if slotDef.remoteType == "Soul" then
        local r = getRemote("Remote","Server","Units","Soul"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Unequip", [2]={ ["UnitFolder"]=unitFolder, ["SoulName"]="Soul" } }))
        end)
    else
        local r = getRemote("Remote","Server","Units","Gears"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Unequip", [2]={ ["UnitFolder"]=unitFolder, ["GearName"]=slotDef.unequipKey } }))
        end)
    end
end

local function fireEquipGear(unitFolder, slotDef, itemName)
    if not itemName or itemName == "" or not unitFolder then return end
    if slotDef.remoteType == "Soul" then
        local r = getRemote("Remote","Server","Units","Soul"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Equip", [2]={ ["UnitFolder"]=unitFolder, ["SoulName"]=itemName } }))
        end)
    else
        local r = getRemote("Remote","Server","Units","Gears"); if not r then return end
        pcall(function()
            r:FireServer(table.unpack({ [1]="Equip", [2]={ ["UnitFolder"]=unitFolder, ["GearName"]=itemName } }))
        end)
    end
end

-- ════════════════════════════════════════════════════════════
--  EQUIP-SET ANWENDEN  (Unequip alle → Equip aus Set)
-- ════════════════════════════════════════════════════════════
local function applyEquipSet(unitTag, setData, onStatus)
    onStatus = onStatus or function() end
    local unitFolder = getUnitByTag(unitTag)
    if not unitFolder then
        onStatus("❌ Einheit nicht in Collection (Tag: " .. tostring(unitTag) .. ")", D.Red); return
    end
    -- Schritt 1: alle Slots leeren
    onStatus("⚡ Entferne altes Gear...", D.Yellow)
    for _, s in ipairs(GEAR_SLOTS) do
        if readGearValue(unitFolder, s.key) then
            fireUnequipGear(unitFolder, s); task.wait(0.05)
        end
    end
    task.wait(0.25)
    -- Schritt 2: Set ausrüsten
    onStatus("🎯 Rüste Set aus...", D.Yellow)
    local equipped = 0
    for _, s in ipairs(GEAR_SLOTS) do
        local itemName = setData[s.key]
        if itemName and itemName ~= "" then
            local fresh = getUnitByTag(unitTag)
            if fresh then fireEquipGear(fresh, s, itemName); equipped = equipped + 1; task.wait(0.08) end
        end
    end
    onStatus(string.format("✅ Set geladen! (%d/%d Slots)", equipped, #GEAR_SLOTS), D.GreenBright)
    print(string.format("[HazeHub/Equip] Set angewandt: %d Slots  Einheit:%s", equipped, unitFolder.Name))
end

