            local best, err = runOptimize(_selectedAttr)

            if not best then
                optResultLbl.Text="❌ " .. tostring(err); optResultLbl.TextColor3=D.Red
                optRunBtn.Text="⚡  Optimieren"; optRunBtn.TextColor3=D.BG; optRunBtn.Active=true
                return
            end

            local foundCount = 0
            for k, _ in pairs(best) do foundCount = foundCount + 1 end

            if foundCount == 0 then
                -- Items-Index nicht geladen → Namen-Heuristik griff auch nicht
                -- Zeige Inventar-Namen direkt an (ohne Stats-Filterung)
                optResultLbl.Text="⚠ Keine Gear-Items mit '" .. _selectedAttr.label ..
