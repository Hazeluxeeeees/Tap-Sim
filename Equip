        stripe.Size = UDim2.new(0,4,1,0)
        stripe.BackgroundColor3 = hasTag and D.Green or D.Orange
        stripe.BackgroundTransparency = 0.3; stripe.BorderSizePixel = 0; Corner(stripe,3)

        -- Name + [#Tag]
        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Position = UDim2.new(0,10,0,3); nameLbl.Size = UDim2.new(1,-14,0,16)
        nameLbl.BackgroundTransparency = 1
