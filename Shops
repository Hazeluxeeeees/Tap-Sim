local function BuildShopHeader(parent, shopName, currencyKey, acc)
    acc = acc or D.Cyan
    local r,g,b = math.floor(acc.R*255), math.floor(acc.G*255), math.floor(acc.B*255)

    local hc = Instance.new("Frame", parent)
    hc.Size = UDim2.new(1,0,0,40); hc.BorderSizePixel=0; Corner(hc,8)
    hc.BackgroundColor3 = Color3.fromRGB(
        math.clamp(math.floor(r*0.12),0,255),
        math.clamp(math.floor(g*0.12),0,255),
        math.clamp(math.floor(b*0.12),0,255))
    Stroke(hc, acc, 2, 0.1)

    local grad = Instance.new("UIGradient", hc)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(
            math.clamp(math.floor(r*0.25),0,255),
            math.clamp(math.floor(g*0.25),0,255),
            math.clamp(math.floor(b*0.25),0,255))),
        ColorSequenceKeypoint.new(1, D.BG),
    })
    grad.Rotation = 90

    local snL = Instance.new("TextLabel", hc)
    snL.Position = UDim2.new(0,10,0,4); snL.Size = UDim2.new(0.58,-10,0,16)
    snL.BackgroundTransparency=1; snL.Text = shopName
    snL.TextColor3=acc; snL.TextSize=13; snL.Font=Enum.Font.GothamBold
    snL.TextXAlignment=Enum.TextXAlignment.Left

    local curL = Instance.new("TextLabel", hc)
    curL.Position = UDim2.new(0,10,0,22); curL.Size = UDim2.new(0.58,-10,0,13)
    curL.BackgroundTransparency=1; curL.Text = "U Have: " .. currencyKey
    curL.TextColor3=D.TextLow; curL.TextSize=9; curL.Font=Enum.Font.Gotham
    curL.TextXAlignment=Enum.TextXAlignment.Left

    local balL = Instance.new("TextLabel", hc)
    balL.Position = UDim2.new(0.58,0,0,0); balL.Size = UDim2.new(0.41,-4,1,0)
    balL.BackgroundTransparency=1; balL.Text = "–"
    balL.TextColor3=acc; balL.TextSize=17; balL.Font=Enum.Font.GothamBold
    balL.TextXAlignment=Enum.TextXAlignment.Right

    task.spawn(function()
        while hc.Parent do
            pcall(function()
                local v = ReadData(currencyKey)
                if v ~= nil then
                    balL.Text = FmtNum(v)
                    balL.TextColor3 = acc
                    curL.Text = "U Have: " .. currencyKey
                else
                    balL.Text = "–"
                    curL.Text = currencyKey .. " (Pfad fehlt)"
                    balL.TextColor3 = D.TextLow
                end
            end)
            task.wait(3)
        end
    end)
    return hc
end

