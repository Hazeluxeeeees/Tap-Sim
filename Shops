            pcall(function() rfEsp.Text="🔄 Esper neu laden"; rfEsp.TextColor3=D.CyanDim end)
        end)
    end)

    -- JJK (Cursed Scrolls)
    Instance.new("Frame",raidCard).Size = UDim2.new(1,0,0,1)
    BuildShopHeader(raidCard,"📜  JJK (Raid)","Cursed Scrolls",D.Lavender)
    local _,rebJJK2 = BuildItemList(raidCard,
        function() return GetRaidSubfolder("JJK") end,
        { remoteName="JJK_RaidShop",
          extraArgs=function(n,q) return {"JJK",n,q} end },
        D.Lavender)
    local rfJJK2 = NeonBtn(raidCard,"🔄 JJK (Raid) neu laden",D.CyanDim,24)
    rfJJK2.MouseButton1Click:Connect(function()
        rfJJK2.Text="⏳..."; rfJJK2.TextColor3=D.Yellow
        task.spawn(function() pcall(rebJJK2)
            pcall(function() rfJJK2.Text="🔄 JJK (Raid) neu laden"; rfJJK2.TextColor3=D.CyanDim end)
        end)
    end)
end

