--  ITEM-LISTEN BUILDER
-- ============================================================
local function BuildItemList(parent, folderGetter, shopDef, acc)
    acc = acc or D.Cyan

    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1,0,0,0); container.AutomaticSize = Enum.AutomaticSize.Y
    container.BackgroundTransparency=1; VList(container,5)

    local statusLbl = MkLbl(container, "⏳ Lade Shop-Items...", 10, D.TextLow)
    statusLbl.Size = UDim2.new(1,0,0,22)

    local function Rebuild()
        for _,v in pairs(container:GetChildren()) do
            if v:IsA("Frame") then v:Destroy() end
        end
        statusLbl.Text = "⏳ Lade Shop-Items..."
        statusLbl.TextColor3 = D.TextLow
        statusLbl.Visible = true

        local folder = folderGetter()
        if not folder then
            statusLbl.Text = "⚠ Shop-Ordner nicht gefunden."
            statusLbl.TextColor3 = D.Orange
            return
        end

        local items = {}
        for _, ch in ipairs(folder:GetChildren()) do
            if not (ch:IsA("UIGridLayout") or ch:IsA("UIListLayout")
                 or ch:IsA("UIPadding")    or ch:IsA("UICorner")) then
                table.insert(items, ch)
            end
        end
        if #items == 0 then
            statusLbl.Text = "Shop ist leer."; statusLbl.TextColor3 = D.TextLow; return
        end
        table.sort(items, function(a,b) return a.Name < b.Name end)
        statusLbl.Visible = false

            for _, item in ipairs(items) do
            local iName = item.Name
            local rawQty, rawCost = 0, 0
            local qtyStr, costStr = "–", "–"
            pcall(function()
                local qv = item:FindFirstChild("Quantity")
                         or item:FindFirstChild("Amount")
                         or item:FindFirstChild("Stock")
                if qv then rawQty = tonumber(qv.Value) or 0; qtyStr = FmtNum(rawQty) end
            end)
            pcall(function()
                local cv = item:FindFirstChild("CurrencyAmount")
                         or item:FindFirstChild("Cost")
                         or item:FindFirstChild("Price")
                if cv then rawCost = tonumber(cv.Value) or 0; costStr = FmtNum(rawCost) end
            end)

            local row = Instance.new("Frame", container)
            row.Size = UDim2.new(1,0,0,72); row.BackgroundColor3 = D.Card
            row.BackgroundTransparency = D.GlassPane or 0.18
            row.BorderSizePixel=0; Corner(row,8); Stroke(row,acc,1,0.6)

            local acBar = Instance.new("Frame",row)
            acBar.Size = UDim2.new(0,3,1,0); acBar.BackgroundColor3=acc
            acBar.BorderSizePixel=0; Corner(acBar,2)

            local nL = Instance.new("TextLabel",row)
            nL.Position = UDim2.new(0,10,0,4); nL.Size = UDim2.new(1,-14,0,18)
            nL.BackgroundTransparency=1; nL.Text = iName
            nL.TextColor3=D.TextHi; nL.TextSize=12; nL.Font=Enum.Font.GothamBold
            nL.TextXAlignment=Enum.TextXAlignment.Left; nL.TextTruncate=Enum.TextTruncate.AtEnd

            local iL = Instance.new("TextLabel",row)
            iL.Position = UDim2.new(0,10,0,24); iL.Size = UDim2.new(1,-14,0,13)
            iL.BackgroundTransparency=1
            iL.Text = string.format("Qty: %s  |  Preis: %s", qtyStr, costStr)
            iL.TextColor3=D.TextLow; iL.TextSize=9; iL.Font=Enum.Font.Gotham
            iL.TextXAlignment=Enum.TextXAlignment.Left

            local inOuter = Instance.new("Frame",row)
            inOuter.Position = UDim2.new(0,10,0,40); inOuter.Size = UDim2.new(0.36,-14,0,24)
            inOuter.BackgroundColor3=D.Input; inOuter.BackgroundTransparency=D.GlassPane or 0.18; inOuter.BorderSizePixel=0
            Corner(inOuter,8); Stroke(inOuter,acc,1,0.4)

            local inBox = Instance.new("TextBox",inOuter)
            inBox.Size = UDim2.new(1,0,1,0); inBox.BackgroundTransparency=1
            inBox.PlaceholderText="Menge"; inBox.PlaceholderColor3=D.TextLow
            inBox.Text=""; inBox.TextColor3=D.TextHi
            inBox.TextSize=10; inBox.Font=Enum.Font.Gotham
            inBox.ClearTextOnFocus=false
            Pad(inBox,0,5,0,5)

            local pvL = Instance.new("TextLabel",row)
            pvL.Position = UDim2.new(0.36,2,0,40); pvL.Size = UDim2.new(0.28,-4,0,24)
            pvL.BackgroundTransparency=1; pvL.Text=""
            pvL.TextColor3=D.Gold; pvL.TextSize=9; pvL.Font=Enum.Font.GothamBold
            pvL.TextXAlignment=Enum.TextXAlignment.Left; pvL.TextWrapped=true

            inBox:GetPropertyChangedSignal("Text"):Connect(function()
                local n = tonumber(inBox.Text)
                if n and n > 0 then
                    pvL.Text = rawCost > 0 and ("= " .. FmtNum(math.floor(n*rawCost))) or "= ?"
                    pvL.TextColor3 = rawCost > 0 and D.Gold or D.TextLow
                else
                    pvL.Text = ""
                end
            end)

            local buyBtn = Instance.new("TextButton",row)
            buyBtn.Position = UDim2.new(0.65,2,0,38); buyBtn.Size = UDim2.new(0.35,-8,0,26)
            buyBtn.BackgroundColor3 = D.CardHover
            buyBtn.BackgroundTransparency = D.GlassPane or 0.18
            buyBtn.Text = "🛒 Kaufen"; buyBtn.TextColor3=acc
            buyBtn.TextSize=10; buyBtn.Font=Enum.Font.GothamBold
            buyBtn.TextScaled=false; buyBtn.RichText=true; buyBtn.TextStrokeTransparency=1
            buyBtn.AutoButtonColor=false; buyBtn.BorderSizePixel=0
            Corner(buyBtn,8); Stroke(buyBtn,acc,1,0.25)

            buyBtn.MouseEnter:Connect(function()
                Tw(buyBtn,{BackgroundColor3=D.TabActive,BackgroundTransparency=D.GlassPane or 0.18})
            end)
            buyBtn.MouseLeave:Connect(function()
                Tw(buyBtn,{BackgroundColor3=D.CardHover,BackgroundTransparency=D.GlassPane or 0.18})
            end)

            local capName = iName
            buyBtn.MouseButton1Click:Connect(function()
                local qty = math.floor(tonumber(inBox.Text) or 0)
                if qty <= 0 then
                    buyBtn.Text = "⚠ Menge!"; buyBtn.TextColor3=D.Red
                    task.delay(1.5,function() pcall(function()
                        buyBtn.Text="🛒 Kaufen"; buyBtn.TextColor3=acc
                    end) end)
                    return
                end
                buyBtn.Text = "⏳..."; buyBtn.TextColor3=D.Yellow
                local args = shopDef.extraArgs
                    and shopDef.extraArgs(capName,qty)
                    or  {capName, qty}
                FireRemote(shopDef.remoteName, table.unpack(args))
                task.delay(1,function() pcall(function()
                    buyBtn.Text="✅ OK"; buyBtn.TextColor3=D.GreenBright
                    task.delay(1.5,function() pcall(function()
                        buyBtn.Text="🛒 Kaufen"; buyBtn.TextColor3=acc
                    end) end)
                end) end)
            end)
        end
    end

    task.spawn(function() pcall(Rebuild) end)
    return container, Rebuild
end

-- ============================================================
--  SHOP BUILDER HELPER
-- ============================================================
local function BuildShop(opts)
    local shopCard = Card(opts.parent)
    Pad(shopCard,10,12,10,12); VList(shopCard,7)
    Stroke(shopCard, opts.accent, 1.5, 0.25)

    BuildShopHeader(shopCard, opts.name, opts.currencyKey, opts.accent)
    BuildResetTimer(shopCard, opts.timerType)

    local _, rebuildFn = BuildItemList(shopCard, opts.folderGetter, opts.shopDef, opts.accent)

    local refBtn = NeonBtn(shopCard, "🔄 Shop neu laden", D.CyanDim, 26)
    refBtn.MouseButton1Click:Connect(function()
        refBtn.Text="⏳ Lädt..."; refBtn.TextColor3=D.Yellow
        task.spawn(function()
            pcall(rebuildFn)
            pcall(function() refBtn.Text="🔄 Shop neu laden"; refBtn.TextColor3=D.CyanDim end)
        end)
    end)
    return shopCard
end

