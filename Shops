-- ============================================================
--  RESET-TIMER WIDGET
--  timerType = "daily415" | "hourly15"
-- ============================================================
local function BuildResetTimer(parent, timerType)
    local timerCard = Instance.new("Frame", parent)
    timerCard.Size = UDim2.new(1, 0, 0, 32); timerCard.BackgroundColor3 = Color3.fromRGB(12, 18, 36)
    timerCard.BorderSizePixel = 0; Corner(timerCard, 6); Stroke(timerCard, D.CyanDim, 1, 0.5)

    local timerLbl = Instance.new("TextLabel", timerCard)
    timerLbl.Position = UDim2.new(0, 8, 0, 2); timerLbl.Size = UDim2.new(0.55, 0, 0, 14)
    timerLbl.BackgroundTransparency = 1
    timerLbl.Text = timerType == "hourly15" and "⏰ Reset: stündlich :15" or "⏰ Reset: täglich 04:15"
    timerLbl.TextColor3 = D.TextLow; timerLbl.TextSize = 9; timerLbl.Font = Enum.Font.Gotham
    timerLbl.TextXAlignment = Enum.TextXAlignment.Left

    local countLbl = Instance.new("TextLabel", timerCard)
    countLbl.Position = UDim2.new(0.55, 0, 0, 2); countLbl.Size = UDim2.new(0.44, 0, 0, 14)
    countLbl.BackgroundTransparency = 1; countLbl.Text = "–"
    countLbl.TextColor3 = D.Cyan; countLbl.TextSize = 10; countLbl.Font = Enum.Font.GothamBold
    countLbl.TextXAlignment = Enum.TextXAlignment.Right

    local barBg = Instance.new("Frame", timerCard)
    barBg.Position = UDim2.new(0, 8, 0, 18); barBg.Size = UDim2.new(1, -16, 0, 6)
    barBg.BackgroundColor3 = Color3.fromRGB(20, 28, 50); barBg.BorderSizePixel = 0; Corner(barBg, 3)

    local barFill = Instance.new("Frame", barBg)
    barFill.Size = UDim2.new(1, 0, 1, 0); barFill.BackgroundColor3 = D.CyanDim
    barFill.BorderSizePixel = 0; Corner(barFill, 3)

    -- Hintergrund-Loop
    task.spawn(function()
        while timerCard.Parent do
            local totalSecs, remainSecs
            if timerType == "hourly15" then
                totalSecs  = 3600
                remainSecs = SecsUntilNextHourlyAt15()
            else
                totalSecs  = 86400
                remainSecs = SecsUntilDailyTime(4, 15)
            end
            local pct = 1 - (remainSecs / totalSecs)
            pct = math.max(0, math.min(1, pct))
            pcall(function()
                countLbl.Text = FormatCountdown(remainSecs)
                Tw(barFill, { Size = UDim2.new(pct, 0, 1, 0),
                    BackgroundColor3 = pct > 0.85 and D.Red or (pct > 0.5 and D.Yellow or D.Cyan) }, TF)
            end)
            task.wait(1)
        end
    end)

    return timerCard
end

-- ============================================================
--  ITEM-ROW BUILDER
--  Liest Items aus einem RS-Ordner und baut je eine Kauf-Zeile
-- ============================================================
--  shopDef = {
--    remoteName  = string,
--    extraArgs   = function(itemName, qty) -> {...}  (optional)
--  }
--  folderGetter = function() -> Folder | nil
--  currencyKey  = string  (Name in Player_Data.Data)
-- ============================================================
local function BuildShopItemList(parent, folderGetter, shopDef, accentColor)
    local acc = accentColor or D.Cyan

    local itemsContainer = Instance.new("Frame", parent)
    itemsContainer.Size = UDim2.new(1, 0, 0, 0)
    itemsContainer.AutomaticSize = Enum.AutomaticSize.Y
    itemsContainer.BackgroundTransparency = 1
    VList(itemsContainer, 5)

    local emptyLbl = MkLbl(itemsContainer, "⏳ Shop-Daten werden geladen...", 10, D.TextLow)
    emptyLbl.Size = UDim2.new(1, 0, 0, 24)

    local function Rebuild()
        for _, v in pairs(itemsContainer:GetChildren()) do
            if v:IsA("Frame") then v:Destroy() end
        end
        emptyLbl.Visible = true

        local folder = folderGetter()
        if not folder then
            emptyLbl.Text = "⚠ Shop-Ordner nicht gefunden (Pfad prüfen)."
            emptyLbl.TextColor3 = D.Orange
            return
        end

        local items = {}
        for _, child in ipairs(folder:GetChildren()) do
            if not child:IsA("UIGridLayout") and not child:IsA("UIListLayout")
            and not child:IsA("UIPadding") then
                table.insert(items, child)
            end
        end
        table.sort(items, function(a,b) return a.Name < b.Name end)

        if #items == 0 then
            emptyLbl.Text = "Shop ist leer."; emptyLbl.TextColor3 = D.TextLow; return
        end
        emptyLbl.Visible = false

        for _, item in ipairs(items) do
            local iName = item.Name
            local qty, costAmt = "–", "–"
            pcall(function()
                local qv = item:FindFirstChild("Quantity") or item:FindFirstChild("Amount")
                if qv then qty = FmtNum(qv.Value) end
            end)
            pcall(function()
                local cv = item:FindFirstChild("CurrencyAmount") or item:FindFirstChild("Cost")
                         or item:FindFirstChild("Price")
                if cv then costAmt = FmtNum(cv.Value) end
            end)

            -- Row-Frame (Höhe 64 für TextBox + Vorschau)
            local row = Instance.new("Frame", itemsContainer)
            row.Size = UDim2.new(1, 0, 0, 64); row.BackgroundColor3 = D.Card
            row.BorderSizePixel = 0; Corner(row, 8); Stroke(row, acc, 1, 0.65)

            local acBar = Instance.new("Frame", row)
            acBar.Size = UDim2.new(0, 3, 1, 0); acBar.BackgroundColor3 = acc
            acBar.BorderSizePixel = 0; Corner(acBar, 2)

            -- Name
            local nameLbl = Instance.new("TextLabel", row)
            nameLbl.Position = UDim2.new(0, 10, 0, 4); nameLbl.Size = UDim2.new(0.6, -10, 0, 16)
            nameLbl.BackgroundTransparency = 1; nameLbl.Text = iName
            nameLbl.TextColor3 = D.TextHi; nameLbl.TextSize = 12; nameLbl.Font = Enum.Font.GothamBold
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left
            nameLbl.TextTruncate = Enum.TextTruncate.AtEnd

            -- Menge & Preis
            local infoLbl = Instance.new("TextLabel", row)
            infoLbl.Position = UDim2.new(0, 10, 0, 22); infoLbl.Size = UDim2.new(0.6, -10, 0, 13)
            infoLbl.BackgroundTransparency = 1
            infoLbl.Text = "Qty: " .. qty .. "  |  Preis: " .. costAmt
            infoLbl.TextColor3 = D.TextLow; infoLbl.TextSize = 9; infoLbl.Font = Enum.Font.Gotham
            infoLbl.TextXAlignment = Enum.TextXAlignment.Left

            -- Eingabe-Box (Kaufmenge)
            local inputOuter = Instance.new("Frame", row)
            inputOuter.Position = UDim2.new(0, 10, 0, 38); inputOuter.Size = UDim2.new(0.38, -14, 0, 20)
            inputOuter.BackgroundColor3 = D.Input; inputOuter.BorderSizePixel = 0
            Corner(inputOuter, 5); Stroke(inputOuter, acc, 1, 0.4)

            local inputBox = Instance.new("TextBox", inputOuter)
            inputBox.Size = UDim2.new(1, 0, 1, 0); inputBox.BackgroundTransparency = 1
            inputBox.PlaceholderText = "Menge..."; inputBox.PlaceholderColor3 = D.TextLow
            inputBox.Text = ""; inputBox.TextColor3 = D.TextHi
            inputBox.TextSize = 10; inputBox.Font = Enum.Font.Gotham
            inputBox.ClearTextOnFocus = false
            Pad(inputBox, 0, 6, 0, 6)

            -- Live-Kosten-Vorschau
            local previewLbl = Instance.new("TextLabel", row)
            previewLbl.Position = UDim2.new(0.38, 2, 0, 38); previewLbl.Size = UDim2.new(0.28, -4, 0, 20)
            previewLbl.BackgroundTransparency = 1; previewLbl.Text = ""
            previewLbl.TextColor3 = D.Gold; previewLbl.TextSize = 9; previewLbl.Font = Enum.Font.GothamBold
            previewLbl.TextXAlignment = Enum.TextXAlignment.Left; previewLbl.TextWrapped = true

            local rawCost = 0
            pcall(function()
                local cv = item:FindFirstChild("CurrencyAmount") or item:FindFirstChild("Cost")
                         or item:FindFirstChild("Price")
                if cv then rawCost = tonumber(cv.Value) or 0 end
            end)

            inputBox:GetPropertyChangedSignal("Text"):Connect(function()
                local n = tonumber(inputBox.Text)
                if n and n > 0 and rawCost > 0 then
                    previewLbl.Text = "= " .. FmtNum(n * rawCost)
                    previewLbl.TextColor3 = D.Gold
                elseif n and n > 0 then
                    previewLbl.Text = "= ?"
                    previewLbl.TextColor3 = D.TextLow
                else
                    previewLbl.Text = ""
                end
            end)

            -- Kauf-Button
            local buyBtn = Instance.new("TextButton", row)
            buyBtn.Position = UDim2.new(0.68, 2, 0, 36); buyBtn.Size = UDim2.new(0.32, -8, 0, 22)
            buyBtn.BackgroundColor3 = Color3.fromRGB(
                math.clamp(math.floor(acc.R*255*0.25), 0, 255),
                math.clamp(math.floor(acc.G*255*0.25), 0, 255),
                math.clamp(math.floor(acc.B*255*0.25), 0, 255))
            buyBtn.Text = "🛒 Kaufen"; buyBtn.TextColor3 = acc
            buyBtn.TextSize = 10; buyBtn.Font = Enum.Font.GothamBold
            buyBtn.AutoButtonColor = false; buyBtn.BorderSizePixel = 0
            Corner(buyBtn, 6); Stroke(buyBtn, acc, 1, 0.3)

            buyBtn.MouseEnter:Connect(function()
                Tw(buyBtn, { BackgroundColor3 = Color3.fromRGB(
                    math.clamp(math.floor(acc.R*255*0.4), 0, 255),
                    math.clamp(math.floor(acc.G*255*0.4), 0, 255),
                    math.clamp(math.floor(acc.B*255*0.4), 0, 255)) })
            end)
            buyBtn.MouseLeave:Connect(function()
                Tw(buyBtn, { BackgroundColor3 = Color3.fromRGB(
                    math.clamp(math.floor(acc.R*255*0.25), 0, 255),
                    math.clamp(math.floor(acc.G*255*0.25), 0, 255),
                    math.clamp(math.floor(acc.B*255*0.25), 0, 255)) })
            end)

            local capName = iName
            buyBtn.MouseButton1Click:Connect(function()
                local qty2 = tonumber(inputBox.Text)
                if not qty2 or qty2 <= 0 then
                    buyBtn.Text = "⚠ Menge!"; buyBtn.TextColor3 = D.Red
                    task.delay(1.5, function() pcall(function()
                        buyBtn.Text = "🛒 Kaufen"; buyBtn.TextColor3 = acc
                    end) end)
                    return
                end
                qty2 = math.floor(qty2)
                buyBtn.Text = "⏳..."; buyBtn.TextColor3 = D.Yellow

                -- Remote feuern – Extra-Args kommen aus shopDef.extraArgs
                local args
                if shopDef.extraArgs then
                    args = shopDef.extraArgs(capName, qty2)
                else
                    args = { capName, qty2 }
                end
                FireRemote(shopDef.remoteName, table.unpack(args))

                task.delay(1.2, function() pcall(function()
                    buyBtn.Text = "✅ OK"; buyBtn.TextColor3 = D.GreenBright
                    task.delay(1.5, function() pcall(function()
                        buyBtn.Text = "🛒 Kaufen"; buyBtn.TextColor3 = acc
                    end) end)
                end) end)
            end)
        end
    end

    -- Sofort laden
    task.spawn(function() pcall(Rebuild) end)

    -- Refresh-Button zurückgeben für externen Aufruf
    return itemsContainer, Rebuild
end

-- ============================================================
--  SHOP HEADER WIDGET
--  Zeigt Shop-Name + aktuelle Spieler-Währung
-- ============================================================
local function BuildShopHeader(parent, shopName, currencyKey, accentColor)
    local acc = accentColor or D.Cyan
    local hCard = Instance.new("Frame", parent)
    hCard.Size = UDim2.new(1, 0, 0, 38); hCard.BackgroundColor3 = Color3.fromRGB(
        math.clamp(math.floor(acc.R*255*0.12), 0, 255),
        math.clamp(math.floor(acc.G*255*0.12), 0, 255),
        math.clamp(math.floor(acc.B*255*0.12), 0, 255))
    hCard.BorderSizePixel = 0; Corner(hCard, 8); Stroke(hCard, acc, 2, 0.15)

    local gradient = Instance.new("UIGradient", hCard)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(
            math.clamp(math.floor(acc.R*255*0.22), 0, 255),
            math.clamp(math.floor(acc.G*255*0.22), 0, 255),
            math.clamp(math.floor(acc.B*255*0.22), 0, 255))),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 14, 28)),
    })
    gradient.Rotation = 90

    local titleLbl = Instance.new("TextLabel", hCard)
    titleLbl.Position = UDim2.new(0, 10, 0, 4); titleLbl.Size = UDim2.new(0.55, 0, 0.55, 0)
    titleLbl.BackgroundTransparency = 1; titleLbl.Text = shopName
    titleLbl.TextColor3 = acc; titleLbl.TextSize = 13; titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local currencyLbl = Instance.new("TextLabel", hCard)
    currencyLbl.Position = UDim2.new(0, 10, 0.5, 0); currencyLbl.Size = UDim2.new(0.55, 0, 0.5, 0)
    currencyLbl.BackgroundTransparency = 1; currencyLbl.Text = "U Have: ..."
    currencyLbl.TextColor3 = D.TextLow; currencyLbl.TextSize = 9; currencyLbl.Font = Enum.Font.Gotham
    currencyLbl.TextXAlignment = Enum.TextXAlignment.Left

    local balanceLbl = Instance.new("TextLabel", hCard)
    balanceLbl.Position = UDim2.new(0.55, 0, 0, 0); balanceLbl.Size = UDim2.new(0.44, 0, 1, 0)
    balanceLbl.BackgroundTransparency = 1; balanceLbl.Text = "–"
    balanceLbl.TextColor3 = acc; balanceLbl.TextSize = 16; balanceLbl.Font = Enum.Font.GothamBold
    balanceLbl.TextXAlignment = Enum.TextXAlignment.Right

    -- Laufend aktualisieren
    task.spawn(function()
        while hCard.Parent do
            pcall(function()
                local val = ReadPlayerData("Data", currencyKey)
                if val ~= nil then
                    balanceLbl.Text = FmtNum(val)
                    currencyLbl.Text = "U Have: " .. currencyKey
                    balanceLbl.TextColor3 = acc
                else
                    balanceLbl.Text = "–"
                    currencyLbl.Text = currencyKey .. " (nicht gefunden)"
                    balanceLbl.TextColor3 = D.TextLow
                end
            end)
            task.wait(3)
        end
    end)

    return hCard
end

