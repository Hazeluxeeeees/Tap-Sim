FmtNum = function(n)
    n = math.floor(tonumber(n) or 0)
    local s = tostring(n); local result = ""; local count = 0
    for i = #s, 1, -1 do
        count = count + 1; result = s:sub(i,i) .. result
        if count % 3 == 0 and i > 1 then result = "," .. result end
    end
    return result
end

-- Lese einen Wert aus RS.Player_Data.[LP.Name].[...Pfad]
local function ReadPlayerData(...)
    local val = nil
    pcall(function()
        local node = RS:WaitForChild("Player_Data", 3):WaitForChild(LP.Name, 3)
        for _, part in ipairs({...}) do
            node = node:WaitForChild(part, 2)
        end
        val = node.Value
    end)
    return val
end

-- Sekunden bis zum nächsten Ziel-Zeitpunkt (HH:MM täglich)
local function SecsUntilDailyTime(targetHour, targetMin)
    local now = os.time()
    local t   = os.date("*t", now)
    -- Ziel heute
    local todayTarget = os.time({ year=t.year, month=t.month, day=t.day,
                                   hour=targetHour, min=targetMin, sec=0 })
    if todayTarget <= now then
        todayTarget = todayTarget + 86400   -- morgen
    end
    return todayTarget - now
end

-- Sekunden bis zur nächsten :15 der aktuellen Stunde
local function SecsUntilNextHourlyAt15()
    local now = os.time()
    local t   = os.date("*t", now)
    local thisHour15 = os.time({ year=t.year, month=t.month, day=t.day,
                                  hour=t.hour, min=15, sec=0 })
    if thisHour15 <= now then
        thisHour15 = thisHour15 + 3600   -- nächste Stunde :15
    end
    return thisHour15 - now
end

local function FormatCountdown(secs)
    local h = math.floor(secs / 3600)
    local m = math.floor((secs % 3600) / 60)
    local s = secs % 60
    if h > 0 then return string.format("%dh %02dm %02ds", h, m, s)
    else           return string.format("%dm %02ds", m, s) end
end

-- ============================================================
--  REMOTE LOOKUP
-- ============================================================
local RemoteCache = {}
local function GetRemote(name)
    if RemoteCache[name] then return RemoteCache[name] end
    local r = nil
    pcall(function() r = RS:WaitForChild("Remote", 3):WaitForChild("Server", 3):WaitForChild(name, 3) end)
    if not r then pcall(function() r = RS:FindFirstChild(name, true) end) end
    if r then RemoteCache[name] = r end
    return r
end

local function FireRemote(remoteName, ...)
    local r = GetRemote(remoteName)
    if r then
        pcall(function() r:FireServer(...) end)
        print(string.format("[HazeHub-Shops] Fire %s(%s)", remoteName,
            table.concat(table.pack(...), ", ")))
    else
        warn("[HazeHub-Shops] Remote nicht gefunden: " .. remoteName)
    end
end

