do
    local raidCard = Card(ShopPage); Pad(raidCard,10,12,10,12); VList(raidCard,8)
    Stroke(raidCard, D.Purple, 1.5, 0.25)

    local hdr = Instance.new("TextLabel",raidCard)
    hdr.Size=UDim2.new(1,0,0,22); hdr.BackgroundTransparency=1
    hdr.Text="⚔️  Raid Shop"; hdr.TextColor3=D.Purple
    hdr.TextSize=13; hdr.Font=Enum.Font.GothamBold; hdr.TextXAlignment=Enum.TextXAlignment.Left

    BuildResetTimer(raidCard,"daily415")

    -- Helper: Raid-Ordner mit Retry
    local function GetRaidSubfolder(subName)
        local f = nil
        pcall(function()
            f = RS:WaitForChild("Player_Data",10)
                 :WaitForChild(LP.Name,5)
                 :WaitForChild("JJK_Raid_Shop",3)
                 :WaitForChild(subName,3)
        end)
        if not f then
            task.wait(2)
            pcall(function()
                f = RS:WaitForChild("Player_Data",5)
                     :WaitForChild(LP.Name,5)
                     :WaitForChild("JJK_Raid_Shop",3)
                     :WaitForChild(subName,3)
            end)
        end
        return f
    end

    -- Esper (Esper Token)
    Instance.new("Frame",raidCard).Size = UDim2.new(1,0,0,1)
    BuildShopHeader(raidCard,"🔮  Esper","Esper Token",D.Purple)
    local _,rebEsp = BuildItemList(raidCard,
        function() return GetRaidSubfolder("Esper") end,
        { remoteName="JJK_RaidShop",
          extraArgs=function(n,q) return {"Esper",n,q} end },
        D.Purple)
    local rfEsp = NeonBtn(raidCard,"🔄 Esper neu laden",D.CyanDim,24)
