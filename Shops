local function BuildResetTimer(parent, timerType)
    local tc = Instance.new("Frame", parent)
    tc.Size = UDim2.new(1,0,0,32); tc.BackgroundColor3 = D.Input
    tc.BackgroundTransparency = D.GlassPane or 0.18
    tc.BorderSizePixel = 0; Corner(tc,8); Stroke(tc,D.Border,1,0.45)

    local labelTxt = timerType == "hourly15"
        and "⏰ Reset: stündlich :15"
        or  "⏰ Reset: täglich 04:15"

    local tLbl = Instance.new("TextLabel", tc)
    tLbl.Position = UDim2.new(0,8,0,2); tLbl.Size = UDim2.new(0.5,0,0,14)
    tLbl.BackgroundTransparency = 1; tLbl.Text = labelTxt
    tLbl.TextColor3 = D.TextLow; tLbl.TextSize = 9; tLbl.Font = Enum.Font.GothamMedium
    tLbl.TextScaled = false; tLbl.RichText = true; tLbl.TextStrokeTransparency = 1
    tLbl.TextXAlignment = Enum.TextXAlignment.Left

    local cLbl = Instance.new("TextLabel", tc)
    cLbl.Position = UDim2.new(0.5,0,0,2); cLbl.Size = UDim2.new(0.49,0,0,14)
    cLbl.BackgroundTransparency = 1; cLbl.Text = "–"
    cLbl.TextColor3 = D.Accent or D.Cyan; cLbl.TextSize = 10; cLbl.Font = Enum.Font.GothamBold
    cLbl.TextScaled = false; cLbl.RichText = true; cLbl.TextStrokeTransparency = 1
    cLbl.TextXAlignment = Enum.TextXAlignment.Right

    local barBg = Instance.new("Frame",tc)
    barBg.Position = UDim2.new(0,8,0,18); barBg.Size = UDim2.new(1,-16,0,6)
    barBg.BackgroundColor3 = D.Input; barBg.BackgroundTransparency = D.GlassPane or 0.18; barBg.BorderSizePixel=0; Corner(barBg,4)

    local barFill = Instance.new("Frame",barBg)
    barFill.Size = UDim2.new(0,0,1,0); barFill.BackgroundColor3 = D.AccentDim or D.CyanDim
    barFill.BorderSizePixel=0; Corner(barFill,4)

    task.spawn(function()
        while tc.Parent do
            pcall(function()
                local remain, total = SecsUntilReset(timerType)
                local elapsed = total - remain
                local pct = math.max(0, math.min(1, elapsed / total))
                local col = pct > 0.9 and D.Red or (pct > 0.6 and D.Yellow or (D.AccentDim or D.CyanDim))
                cLbl.Text = FmtCountdown(remain)
                Tw(barFill, { Size = UDim2.new(pct,0,1,0), BackgroundColor3 = col }, TF)
            end)
            task.wait(1)
        end
    end)
    return tc
end

