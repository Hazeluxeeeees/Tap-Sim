local function FmtNum(n)
    n = math.floor(tonumber(n) or 0)
    local s = tostring(n); local r = ""; local c = 0
    for i = #s, 1, -1 do
        c = c + 1; r = s:sub(i,i) .. r
        if c % 3 == 0 and i > 1 then r = "," .. r end
    end
    return r
end

-- Lese .Value aus RS.Player_Data.[LP.Name].Data.[key]
local function ReadData(key)
    local v = nil
    pcall(function()
        v = RS:WaitForChild("Player_Data",3)
             :WaitForChild(LP.Name,3)
             :WaitForChild("Data",3)
             :WaitForChild(key,2).Value
    end)
    return v
end

-- ============================================================
--  RESET-TIMER BERECHNUNG
--  "daily415"  → nächster Reset um 04:15 Uhr lokal
--  "hourly15"  → nächste volle Stunde + 15 Minuten
-- ============================================================
local function SecsUntilReset(timerType)
    local now = os.time()
    local t   = os.date("*t", now)
    if timerType == "hourly15" then
        -- nächstes XX:15
        local thisMin15 = os.time({ year=t.year, month=t.month, day=t.day,
                                     hour=t.hour, min=15, sec=0 })
        if thisMin15 <= now then thisMin15 = thisMin15 + 3600 end
        return thisMin15 - now, 3600
    else
        -- täglich 04:15
        local target = os.time({ year=t.year, month=t.month, day=t.day,
                                  hour=4, min=15, sec=0 })
        if target <= now then target = target + 86400 end
        return target - now, 86400
    end
end

local function FmtCountdown(secs)
    secs = math.max(0, math.floor(secs))
    local h = math.floor(secs/3600)
    local m = math.floor((secs%3600)/60)
    local s = secs % 60
    if h > 0 then return string.format("%dh %02dm %02ds",h,m,s)
    else           return string.format("%dm %02ds",m,s) end
end

-- ============================================================
--  REMOTE LOOKUP
--  Sucht erst in RS.Remote.Server.[name], dann RS.[name] tief
-- ============================================================
local RemoteCache = {}
local function GetRemote(name)
    if RemoteCache[name] then return RemoteCache[name] end
    local r = nil
    -- Versuch 1: RS.Remote.Server.[name]
    pcall(function()
        r = RS:WaitForChild("Remote",3)
             :WaitForChild("Server",3)
             :WaitForChild(name,3)
    end)
    -- Versuch 2: irgendwo in RS (FindFirstChild tief)
    if not r then pcall(function() r = RS:FindFirstChild(name,true) end) end
    if r then RemoteCache[name] = r end
    return r
end

local function FireRemote(remoteName, ...)
    local r = GetRemote(remoteName)
    if r then
        local args = {...}
        pcall(function() r:FireServer(table.unpack(args)) end)
        print(string.format("[HazeHub-Shops] %s:FireServer(%s)",
            remoteName, table.concat(table.pack(...),", ")))
    else
        warn("[HazeHub-Shops] Remote nicht gefunden: " .. tostring(remoteName))
    end
end

