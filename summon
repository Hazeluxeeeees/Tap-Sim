-- Banner: display=UI-Text, remote=Remote-Parameter, id=interne Kennung
local BANNERS = {
    { display="STANDARD", remote="Standard", id="Standard" },
    { display="RATE-UP",  remote="Rateup",   id="Rateup"   },
    { display="SOL",      remote="Sol",      id="Sol"       },
}
local AMOUNTS  = {"1x","10x","50x"}
local RARITIES = {"Rare","Epic","Legendary","Mythic"}
