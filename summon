-- ── KORRIGIERTE PITY-DEFINITIONEN ────────────────────────────
-- Pfad: RS.Player_Data[LP.Name].BannerPity.<key>
local SOL_PITY = {
    { key="SolMythicPity", label="Mythic Pity",  max=1000,  col=D.Gold   },
    { key="SolRangerPity", label="Ranger Pity",  max=35000, col=D.Purple },
    { key="SolSecretPity", label="Secret Pity",  max=5000,  col=D.Red    },
