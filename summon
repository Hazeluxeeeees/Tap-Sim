            UpdateSumInfo()
        end)
        btn.MouseEnter:Connect(function()
            if selectedAmount ~= capAmt then
                Tw(btn, { BackgroundTransparency = 0.08 })
            end
        end)
        btn.MouseLeave:Connect(function()
            if selectedAmount ~= capAmt then
                Tw(btn, { BackgroundTransparency = D.GlassPane })
            end
        end)

        amtBtns[amt] = btn
    end
    RefreshAmtUI()

    -- ── Summon-Button ──────────────────────────────────────────
    local sumBtn = NeonBtn(sumCard, "✨  SUMMON", D.Purple, 38)
    sumBtn.MouseButton1Click:Connect(function()
        DoSummon(selectedAmount)
    end)

    -- ────────────────────────────────────────────────────────
    --  SEKTION E: AUTO-SUMMON LOOP
    -- ────────────────────────────────────────────────────────
    local autoCard = Card(Page)
    Pad(autoCard, 10, 12, 10, 12); VList(autoCard, 8)
    SecLbl(autoCard, "🔁  AUTO-SUMMON  (Loop)")

    -- Pause-Eingabe
    local pauseRow = Instance.new("Frame", autoCard)
    pauseRow.Size = UDim2.new(1, 0, 0, 30)
    pauseRow.BackgroundTransparency = 1
    HList(pauseRow, 6)

    local pauseLbl = MkLbl(pauseRow, "Pause zwischen Summons (s):", 10, D.TextLow)
    pauseLbl.Size = UDim2.new(0.7, 0, 1, 0)

    local pauseOuter, pauseBox = MkInput(pauseRow, "3", 30)
    pauseOuter.Size = UDim2.new(0.29, 0, 0, 30)
    pauseBox.Text   = "3"
    pauseBox:GetPropertyChangedSignal("Text"):Connect(function()
        autoSummonDelay = math.max(1, math.floor(tonumber(pauseBox.Text) or 3))
    end)

    -- Status-Zeile
    local autoTopRow = Instance.new("Frame", autoCard)
    autoTopRow.Size = UDim2.new(1, 0, 0, 22)
    autoTopRow.BackgroundTransparency = 1
    HList(autoTopRow, 8)

    local autoDot = Instance.new("Frame", autoTopRow)
    autoDot.Size   = UDim2.new(0, 10, 0, 10)
    autoDot.BackgroundColor3 = D.TextLow
    autoDot.BorderSizePixel  = 0
    Corner(autoDot, 99)

    local autoStatusLbl = Instance.new("TextLabel", autoTopRow)
    autoStatusLbl.Size = UDim2.new(1, -18, 1, 0)
    autoStatusLbl.BackgroundTransparency = 1
    autoStatusLbl.Text      = "Auto-Summon  —  Inaktiv"
    autoStatusLbl.TextColor3 = D.TextLow
    autoStatusLbl.TextSize   = 12
    autoStatusLbl.Font       = Enum.Font.GothamBold
    autoStatusLbl.TextXAlignment = Enum.TextXAlignment.Left
    autoStatusLbl.TextScaled = false
    autoStatusLbl.RichText   = true
    autoStatusLbl.TextStrokeTransparency = 1

    -- Toggle-Button
    local autoToggle = NeonBtn(autoCard, "▶  Auto-Summon AN", D.Purple, 34)

    local function UpdateAutoUI()
        if autoSummonOn then
            autoDot.BackgroundColor3  = D.Green
            autoStatusLbl.Text        = "Auto-Summon  —  Aktiv"
            autoStatusLbl.TextColor3  = D.Green
            autoToggle.Text           = "⏹  Auto-Summon AUS"
            autoToggle.TextColor3     = D.Red
            Stroke(autoToggle, D.Red, 1, 0.35)
        else
            autoDot.BackgroundColor3  = D.TextLow
            autoStatusLbl.Text        = "Auto-Summon  —  Inaktiv"
            autoStatusLbl.TextColor3  = D.TextLow
            autoToggle.Text           = "▶  Auto-Summon AN"
            autoToggle.TextColor3     = D.Purple
            Stroke(autoToggle, D.Purple, 1, 0.35)
        end
    end

    autoToggle.MouseButton1Click:Connect(function()
        autoSummonOn = not autoSummonOn
        UpdateAutoUI()
    end)

    -- Dot-Puls-Animation
    task.spawn(function()
        while Page and Page.Parent do
            if autoSummonOn then
                Tw(autoDot, { BackgroundTransparency = 0.65 }, TM)
                task.wait(0.9)
                Tw(autoDot, { BackgroundTransparency = 0 }, TM)
                task.wait(0.9)
            else
                task.wait(0.5)
            end
        end
    end)

    -- Auto-Summon Haupt-Loop
    task.spawn(function()
        while Page and Page.Parent do
            if autoSummonOn and not summonBusy then
                DoSummon(selectedAmount)
                task.wait(math.max(1, autoSummonDelay))
            else
                task.wait(0.5)
            end
        end
    end)

    -- ────────────────────────────────────────────────────────
    --  INIT: Pity beim Start laden + alle 10s refreshen
    -- ────────────────────────────────────────────────────────
    task.spawn(function()
        task.wait(2)        -- Warte bis RS vollständig initialisiert
        pcall(RefreshPity)
        while Page and Page.Parent do
            task.wait(10)
            pcall(RefreshPity)
        end
    end)

    -- Initiale Info-Labels
    UpdateSumInfo()

    print(string.format("[Summon] v3.0.0 geladen – Spieler: %s", LP.Name))
end) -- end task.defer
