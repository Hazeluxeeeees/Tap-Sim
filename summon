--  SCHRITT 1: Warte auf _G.HazeHUB  UND  _G.HazeShared
--  Beide Globals müssen existieren UND HazeShared muss die
--  Kern-UI-Funktionen (Card, Tw, D) bereits gesetzt haben.
--  KEIN SummonPage in dieser Bedingung (Race-Condition).
-- ================================================================
local _waitT = 0
repeat
    task.wait(0.25)
    _waitT = _waitT + 0.25
    if _waitT > 25 then
        warn("[Summon] HazeHUB / HazeShared nicht bereit nach 25s – Abbruch")
        _G._SummonLoaded = false
        return
    end
