local VERSION = "5.0.0"

-- ── Doppel-Load-Schutz ───────────────────────────────────────
if _G._SummonModuleLoaded then
    return _G._SummonModuleLoaded
end

-- ════════════════════════════════════════════════════════════
--  1. Warte auf HazeShared Kern  (KEIN SummonPage hier)
-- ════════════════════════════════════════════════════════════
do
    local t = 0
    while not (_G.HazeHUB ~= nil and _G.HazeShared ~= nil
        and type(_G.HazeShared.Card) == "function"
        and type(_G.HazeShared.Tw)   == "function"
        and _G.HazeShared.D ~= nil) do
        task.wait(0.3); t = t + 0.3
        if t > 25 then
            warn("[Summon] HazeShared Kern nicht bereit"); 
            return { Version=VERSION, Init=function()end, Refresh=function()end }
        end
    end
end

-- ════════════════════════════════════════════════════════════
--  2. Warte separat auf SummonPage
-- ════════════════════════════════════════════════════════════
do
    local t = 0
    while not _G.HazeShared.SummonPage do
        task.wait(0.3); t = t + 0.3
        if t > 15 then
            warn("[Summon] SummonPage nicht bereit")
            return { Version=VERSION, Init=function()end, Refresh=function()end }
        end
    end
end

-- ════════════════════════════════════════════════════════════
--  3. Player_Data Dependency Check
-- ════════════════════════════════════════════════════════════
local RS = game:GetService("ReplicatedStorage")
local LP = game:GetService("Players").LocalPlayer
do
    local ok, t = false, 0
    repeat
        task.wait(0.5); t = t + 0.5
        pcall(function()
            RS:WaitForChild("Player_Data",2):WaitForChild(LP.Name,2); ok=true
        end)
    until ok or t > 20
    if not ok then warn("[Summon] Player_Data/" .. LP.Name .. " – timeout, fahre fort") end
end

-- ════════════════════════════════════════════════════════════
--  4. Remote-Validator  (lazy, blockiert nicht)
-- ════════════════════════════════════════════════════════════
local _remGacha, _remSettings = nil, nil
local function GetGachaRemote()
    if _remGacha then return _remGacha end
    pcall(function()
        _remGacha = RS:WaitForChild("Remote",3):WaitForChild("Server",3)
                      :WaitForChild("Gambling",3):WaitForChild("UnitsGacha",3)
    end)
    if not _remGacha then warn("[Summon] UnitsGacha Remote nicht gefunden") end
    return _remGacha
end
local function GetSettingsRemote()
    if _remSettings then return _remSettings end
    pcall(function()
        _remSettings = RS:WaitForChild("Remote",3):WaitForChild("Server",3)
                         :WaitForChild("Settings",3):WaitForChild("Setting_Event",3)
    end)
    if not _remSettings then warn("[Summon] Setting_Event Remote nicht gefunden") end
    return _remSettings
end
task.spawn(function()
    task.wait(2)
    if GetGachaRemote()    then print("[Summon] ✅ UnitsGacha verifiziert") end
    if GetSettingsRemote() then print("[Summon] ✅ Setting_Event verifiziert") end
end)

