    -- ── BYPASS: Schließt den "Click anywhere"-Screen ──────────
    local function BypassClickScreen()
        task.spawn(function()
            -- Mehrere Versuche über 6 Sekunden (Screen erscheint mit Verzögerung)
            for attempt = 1, 20 do
                task.wait(0.3)
                local closed = false

                pcall(function()
                    local pg = LP:FindFirstChildOfClass("PlayerGui")
                    if not pg then return end

                    for _, desc in ipairs(pg:GetDescendants()) do
                        if not desc or not desc.Parent then continue end

                        local cls  = desc.ClassName
                        local name = desc.Name:lower()

                        -- Suche nach TextButton/ImageButton mit "click"-Schlüsselwörtern
                        if (cls == "TextButton" or cls == "ImageButton") then
                            if name:find("click") or name:find("anywhere")
                            or name:find("continue") or name:find("tap") then
                                -- Direktes Deaktivieren des Parent-Screens
                                pcall(function()
                                    local p = desc.Parent
                                    if p and (p:IsA("Frame") or p:IsA("ScreenGui")) then
                                        p.Visible = false
                                    end
                                    desc.Visible = false
                                end)
                                closed = true
                            end
                        end

                        -- Frame-basierter Ergebnis-Screen
                        if cls == "Frame" and desc.Visible then
                            if name:find("result") or name:find("gacha")
                            or name:find("pull") or name:find("reward") then
                                -- VirtualInputManager-Click in der Mitte
                                pcall(function()
                                    local abs = desc.AbsolutePosition
                                    local sz  = desc.AbsoluteSize
                                    local cx  = math.floor(abs.X + sz.X * 0.5)
                                    local cy  = math.floor(abs.Y + sz.Y * 0.5)
                                    game:GetService("VirtualInputManager")
                                        :SendMouseButtonEvent(cx, cy, 0, true,  game, 0)
                                    task.wait(0.05)
                                    game:GetService("VirtualInputManager")
                                        :SendMouseButtonEvent(cx, cy, 0, false, game, 0)
                                end)
                                closed = true
                            end
                        end
                    end
                end)

                if closed then
                    print("[Summon] Bypass: Click-Screen geschlossen (Versuch " .. attempt .. ")")
                    return
                end
            end
        end)
    end

    -- ── Summon-Kern-Funktion ───────────────────────────────────
    local function DoSummon(amount)
        if summonBusy then
            sumStatusLbl.Text      = "⏳  Warte auf vorherigen Summon..."
            sumStatusLbl.TextColor3 = D.Yellow
            return
        end
        summonBusy = true

        local ban    = BANNERS[selectedBanner]
        local asSells = BuildAutoSellTable()

        sumStatusLbl.Text      = string.format("⏳  Summone %s auf %s ...", amount, ban.display)
        sumStatusLbl.TextColor3 = D.Yellow

        task.spawn(function()
            -- Remote: UnitsGacha:FireServer(Menge, BannerName, AutoSellTable)
            local ok, err = pcall(function()
                RS:WaitForChild("Remote",   3)
                  :WaitForChild("Server",   3)
                  :WaitForChild("Gambling", 3)
                  :WaitForChild("UnitsGacha", 3)
                  :FireServer(amount, ban.remote, asSells)
            end)

            if ok then
                sumStatusLbl.Text      = string.format("✅  %s auf %s!", amount, ban.display)
                sumStatusLbl.TextColor3 = D.GreenBright
                -- Pity nach kurzer Verzögerung aktualisieren
                task.delay(1.5, function() pcall(RefreshPity) end)
            else
                local errShort = tostring(err):sub(1, 80)
                sumStatusLbl.Text      = "❌  " .. errShort
                sumStatusLbl.TextColor3 = D.Red
                warn("[Summon] UnitsGacha Fehler: " .. tostring(err))
            end

            -- Bypass starten
            BypassClickScreen()

            -- Debounce nach 2.5s freigeben
            task.wait(2.5)
            summonBusy = false
            sumStatusLbl.Text      = "Bereit."
            sumStatusLbl.TextColor3 = D.TextMid
        end)
    end

