    _G.HazeHUB   ~= nil and
    _G.HazeShared ~= nil and
    type(_G.HazeShared.Card) == "function" and
    type(_G.HazeShared.Tw)   == "function" and
    _G.HazeShared.D ~= nil
)

-- ================================================================
--  SCHRITT 2: Warte separat auf SummonPage (eigener Timeout)
-- ================================================================
local _spT = 0
repeat
    task.wait(0.25)
    _spT = _spT + 0.25
    if _spT > 15 then
        warn("[Summon] SummonPage nicht bereit nach 15s – Abbruch")
        _G._SummonLoaded = false
