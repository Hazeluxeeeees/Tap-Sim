-- Liest einen IntValue/NumberValue-Wert aus dem Pfad
-- RS.Player_Data[LP.Name].BannerPity.<key>
local function ReadBannerPity(key)
    local val = 0
    pcall(function()
        val = tonumber(
            RS:WaitForChild("Player_Data", 3)
              :WaitForChild(LP.Name, 3)
              :WaitForChild("BannerPity", 3)
              :WaitForChild(key, 2).Value
        ) or 0
    end)
    return val
end

-- Gibt eine Tabelle der aktiven Auto-Sell-Raritäten zurück
-- Format: { ["Rare"] = true, ["Epic"] = true, ... }
local function BuildAutoSellTable()
    local t = {}
    for _, rar in ipairs(RARITIES) do
        if autoSellActive[rar] then
            t[rar] = true
        end
    end
    return t
end

-- Feuert den Setting_Event Remote
local function FireAutoSellRemote(rarity, state)
    pcall(function()
        RS:WaitForChild("Remote", 3)
          :WaitForChild("Server", 3)
          :WaitForChild("Settings", 3)
          :WaitForChild("Setting_Event", 3)
          :FireServer("Sell Auto " .. rarity, state)
    end)
end

-- Baut eine Fortschrittsbalken-Zeile (gibt ValueLabel + FillFrame zurück)
local function BuildProgressRow(parent, label, col, layoutOrder)
    local row = Instance.new("Frame", parent)
    row.Name            = "PityRow_" .. label
    row.Size            = UDim2.new(1, 0, 0, 46)
    row.BackgroundColor3= D.CardHover
    row.BackgroundTransparency = D.GlassPane
    row.BorderSizePixel = 0
    row.LayoutOrder     = layoutOrder or 0
    Corner(row, 8)
    Stroke(row, col, 1, 0.45)

    -- Farbstreifen links
    local bar = Instance.new("Frame", row)
    bar.Size            = UDim2.new(0, 3, 1, 0)
    bar.BackgroundColor3= col
    bar.BorderSizePixel = 0
    Corner(bar, 2)

    -- Label-Text
    local nameLbl = Instance.new("TextLabel", row)
    nameLbl.Position    = UDim2.new(0, 10, 0, 4)
    nameLbl.Size        = UDim2.new(0.62, -10, 0, 16)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text        = label
    nameLbl.TextColor3  = col
    nameLbl.TextSize    = 11
    nameLbl.Font        = Enum.Font.GothamBold
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.TextScaled  = false
    nameLbl.RichText    = true
    nameLbl.TextStrokeTransparency = 1

    -- Wert-Anzeige (z.B. "1200 / 3500")
    local valLbl = Instance.new("TextLabel", row)
    valLbl.Position     = UDim2.new(0.62, 0, 0, 4)
    valLbl.Size         = UDim2.new(0.37, -6, 0, 16)
    valLbl.BackgroundTransparency = 1
    valLbl.Text         = "0 / –"
    valLbl.TextColor3   = D.TextHi
    valLbl.TextSize     = 11
    valLbl.Font         = Enum.Font.GothamBold
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.TextScaled   = false
    valLbl.RichText     = true
    valLbl.TextStrokeTransparency = 1

    -- Balken-Hintergrund
    local barBg = Instance.new("Frame", row)
    barBg.Position      = UDim2.new(0, 10, 0, 28)
    barBg.Size          = UDim2.new(1, -16, 0, 10)
    barBg.BackgroundColor3 = Color3.fromRGB(18, 14, 30)
    barBg.BorderSizePixel  = 0
    Corner(barBg, 5)

    -- Balken-Füllung
    local barFill = Instance.new("Frame", barBg)
    barFill.Size        = UDim2.new(0, 0, 1, 0)
    barFill.BackgroundColor3 = col
    barFill.BorderSizePixel  = 0
    Corner(barFill, 5)

    -- Gradient auf Füllung
    local grad = Instance.new("UIGradient", barFill)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, col),
        ColorSequenceKeypoint.new(1, Color3.new(
            math.min(1, col.R + 0.25),
            math.min(1, col.G + 0.25),
            math.min(1, col.B + 0.25)
        )),
    })

    return valLbl, barFill
end

